---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../data/archive';
import type { Category } from '../data/archive';

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const total = blogPosts.length;
const counts = categories.reduce((acc, c) => {
  acc[c] = blogPosts.filter((p) => p.data.category === c).length;
  return acc;
}, {} as Record<Category, number>);
const yearsActive = new Date().getFullYear() - 2017;
---

<Layout
  title="Media Kit — Iman Abdul Rahim"
  description="Media kit for brand collaborations with Iman Abdul Rahim — Malaysian beauty, parenting & lifestyle blogger."
>
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <div class="mk-hero">
      <div class="mk-hero-inner">
        <p class="section-label">Media Kit</p>
        <h1 class="hero-title">Iman Abdul Rahim</h1>
        <p class="hero-sub">Beauty · Parenting · Lifestyle · Malaysia</p>
        <div class="hero-tags">
          <span class="tag">#BeautyBlogger</span>
          <span class="tag">#MomBlogger</span>
          <span class="tag">#MalaysiaBlogger</span>
          <span class="tag">#Skincare</span>
        </div>
        <a href="/contact/" class="cta-btn">Work With Me</a>
      </div>
      <div class="deco-a"></div>
      <div class="deco-b"></div>
    </div>

    <div class="mk-page">

      <!-- Stats row -->
      <section class="stats-section">
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-num">{yearsActive}+</span>
            <span class="stat-label">Years Blogging</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">{total}+</span>
            <span class="stat-label">Blog Posts</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">5</span>
            <span class="stat-label">Content Categories</span>
          </div>
          <div class="stat-card">
            <span class="stat-num">MY</span>
            <span class="stat-label">Based in Malaysia</span>
          </div>
        </div>
      </section>

      <!-- About -->
      <section class="mk-section">
        <div class="mk-section-inner two-col">
          <div>
            <p class="section-label">About</p>
            <h2 class="section-heading">Who I am</h2>
            <div class="about-text">
              <p>Hi, I'm Iman — a Malaysian blogger writing honest, relatable content on beauty, skincare, motherhood, parenting, and lifestyle since 2017.</p>
              <p>My blog started as a personal space to share real reviews and everyday experiences. Over the years it has grown into a trusted resource for Malaysian women — especially new mums — looking for genuine product recommendations and lifestyle inspiration.</p>
              <p>I write in a warm, honest voice. My readers trust me because I only share products I truly use and believe in.</p>
            </div>
          </div>
          <div class="about-details">
            <div class="detail-item">
              <span class="detail-label">Based in</span>
              <span class="detail-value">Malaysia</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Language</span>
              <span class="detail-value">English & Bahasa Malaysia</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Blogging since</span>
              <span class="detail-value">2017</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Niche</span>
              <span class="detail-value">Beauty, Skincare, Motherhood, Parenting, Lifestyle</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Content breakdown -->
      <section class="mk-section mk-section--tinted">
        <div class="mk-section-inner">
          <p class="section-label">Content</p>
          <h2 class="section-heading">What I write about</h2>
          <div class="cats-breakdown">
            <div class="cat-bar-item">
              <div class="cat-bar-top">
                <span class="cat-bar-name">Skincare</span>
                <span class="cat-bar-count">{counts.Skincare} posts</span>
              </div>
              <div class="bar-track"><div class="bar-fill" style={`width: ${Math.round(counts.Skincare / total * 100)}%`}></div></div>
              <p class="cat-bar-desc">Low pH cleansers, AHA/BHA, SPF, ingredient deep-dives, routines & Malaysian drugstore finds.</p>
            </div>
            <div class="cat-bar-item">
              <div class="cat-bar-top">
                <span class="cat-bar-name">Motherhood</span>
                <span class="cat-bar-count">{counts.Motherhood} posts</span>
              </div>
              <div class="bar-track"><div class="bar-fill bar-fill--petal" style={`width: ${Math.round(counts.Motherhood / total * 100)}%`}></div></div>
              <p class="cat-bar-desc">Pregnancy journeys, hospital bags, breastfeeding, pantang and newborn essentials.</p>
            </div>
            <div class="cat-bar-item">
              <div class="cat-bar-top">
                <span class="cat-bar-name">Parenting</span>
                <span class="cat-bar-count">{counts.Parenting} posts</span>
              </div>
              <div class="bar-track"><div class="bar-fill bar-fill--gold" style={`width: ${Math.round(counts.Parenting / total * 100)}%`}></div></div>
              <p class="cat-bar-desc">Baby food, toddler milestones, diapers, strollers, carseats and baby gear reviews.</p>
            </div>
            <div class="cat-bar-item">
              <div class="cat-bar-top">
                <span class="cat-bar-name">Beauty</span>
                <span class="cat-bar-count">{counts.Beauty} posts</span>
              </div>
              <div class="bar-track"><div class="bar-fill" style={`width: ${Math.round(counts.Beauty / total * 100)}%`}></div></div>
              <p class="cat-bar-desc">Makeup reviews, lipstick swatches, foundations, concealers and beauty tools.</p>
            </div>
            <div class="cat-bar-item">
              <div class="cat-bar-top">
                <span class="cat-bar-name">Lifestyle</span>
                <span class="cat-bar-count">{counts.Lifestyle} posts</span>
              </div>
              <div class="bar-track"><div class="bar-fill bar-fill--rose" style={`width: ${Math.round(counts.Lifestyle / total * 100)}%`}></div></div>
              <p class="cat-bar-desc">Travel (Japan, Korea, Bali), food finds, recipes and home organisation.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Audience -->
      <section class="mk-section">
        <div class="mk-section-inner">
          <p class="section-label">Audience</p>
          <h2 class="section-heading">Who reads my blog</h2>
          <div class="audience-grid">
            <div class="audience-card">
              <span class="audience-icon">◈</span>
              <h3 class="audience-title">Malaysian Women</h3>
              <p class="audience-desc">Primary audience based in Malaysia — readers who relate to local brands, Malaysian living costs, and Malay/English bilingual content.</p>
            </div>
            <div class="audience-card">
              <span class="audience-icon">◇</span>
              <h3 class="audience-title">Age 25–38</h3>
              <p class="audience-desc">Young professionals, new mums, and women navigating skincare, motherhood, and daily life together.</p>
            </div>
            <div class="audience-card">
              <span class="audience-icon">✦</span>
              <h3 class="audience-title">Beauty & Skincare Enthusiasts</h3>
              <p class="audience-desc">Readers who actively research products, follow ingredient science, and trust honest, long-form reviews over ads.</p>
            </div>
            <div class="audience-card">
              <span class="audience-icon">○</span>
              <h3 class="audience-title">New & Expecting Mums</h3>
              <p class="audience-desc">A strong community of first-time mums seeking product guidance for pregnancy, newborns, and early parenting.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Social & Platforms -->
      <section class="mk-section mk-section--tinted">
        <div class="mk-section-inner">
          <p class="section-label">Platforms</p>
          <h2 class="section-heading">Where to find me</h2>
          <div class="platforms-grid">
            <a href="https://www.imanabdulrahim.com" target="_blank" rel="noopener" class="platform-card">
              <div class="platform-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <p class="platform-name">Blog</p>
              <p class="platform-handle">imanabdulrahim.com</p>
            </a>
            <a href="https://www.instagram.com/imanabdulrahim" target="_blank" rel="noopener" class="platform-card">
              <div class="platform-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </div>
              <p class="platform-name">Instagram</p>
              <p class="platform-handle">@imanabdulrahim</p>
            </a>
            <a href="https://www.facebook.com/imanabdulrahimblog" target="_blank" rel="noopener" class="platform-card">
              <div class="platform-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              </div>
              <p class="platform-name">Facebook</p>
              <p class="platform-handle">imanabdulrahimblog</p>
            </a>
            <a href="https://twitter.com/imanabdulrahim" target="_blank" rel="noopener" class="platform-card">
              <div class="platform-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.261 5.628L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
              </div>
              <p class="platform-name">Twitter / X</p>
              <p class="platform-handle">@imanabdulrahim</p>
            </a>
            <a href="https://www.tiktok.com/@imanabdulrahim_" target="_blank" rel="noopener" class="platform-card">
              <div class="platform-icon-wrap">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.72a8.19 8.19 0 0 0 4.76 1.52V6.79a4.84 4.84 0 0 1-1-.1z"/></svg>
              </div>
              <p class="platform-name">TikTok</p>
              <p class="platform-handle">@imanabdulrahim_</p>
            </a>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="mk-cta">
        <div class="mk-cta-inner">
          <h2 class="cta-heading">Ready to collaborate?</h2>
          <p class="cta-sub">I'd love to partner with brands that align with my values — honest, quality products for real Malaysian women.</p>
          <div class="cta-actions">
            <a href="/contact/" class="cta-btn-primary">Send a Collaboration Brief</a>
            <a href="mailto:iman.abdrahim@yahoo.com" class="cta-btn-secondary">Email Directly</a>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="page-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(250, 244, 240, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  :global([data-theme="dark"]) .site-header {
    background: rgba(20, 16, 14, 0.9);
  }

  :global([data-theme="dark"]) .logo-text {
    color: #f0dce0;
  }

  :global([data-theme="dark"]) .logo-sub {
    color: #8a5a63;
  }

  .site-header nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo { display: flex; align-items: baseline; gap: 2px; font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; text-decoration: none; }
  .logo-text { color: var(--text-primary); font-style: italic; font-weight: 500; }
  .logo-dot { color: var(--rose-gold); font-size: 1.6rem; line-height: 1; margin: 0 1px; }
  .logo-sub { color: var(--text-muted); font-weight: 300; font-size: 1rem; letter-spacing: 0.08em; font-family: 'DM Sans', sans-serif; }
  .back-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-secondary); text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: var(--text-primary); }

  /* Hero */
  .mk-hero {
    padding: 9rem 2rem 5rem;
    background: var(--cream);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .mk-hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .section-label {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--rose-gold); font-weight: 500;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: var(--text-primary);
    line-height: 1;
  }

  .hero-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 300;
    letter-spacing: 0.1em;
  }

  .hero-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }

  .tag {
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    background: var(--blush);
    color: var(--text-secondary);
    font-weight: 400;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.9rem 2.2rem;
    background: var(--text-primary);
    color: var(--cream);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: background 0.2s, transform 0.15s;
    margin-top: 0.5rem;
  }

  .cta-btn:hover { background: var(--rose-gold); transform: translateY(-2px); }

  .deco-a {
    position: absolute; width: 350px; height: 350px; border-radius: 50%;
    background: radial-gradient(circle, var(--blush), transparent 70%);
    top: -60px; right: -80px; opacity: 0.5;
  }

  .deco-b {
    position: absolute; width: 250px; height: 250px; border-radius: 50%;
    background: radial-gradient(circle, var(--petal), transparent 70%);
    bottom: -40px; left: -60px; opacity: 0.4;
  }

  /* Page layout */
  .mk-page { }

  .mk-section { padding: 4rem 2rem; }
  .mk-section--tinted { background: var(--white); }
  .mk-section-inner { max-width: 1100px; margin: 0 auto; }
  .two-col { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: start; }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  /* Stats */
  .stats-section {
    background: var(--footer-bg);
    padding: 3rem 2rem;
  }

  .stats-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-card { display: flex; flex-direction: column; gap: 0.4rem; }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--rose-gold);
    font-weight: 300;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    font-weight: 400;
  }

  /* About */
  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-weight: 300;
  }

  .about-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 1.8rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .detail-item:last-child { border-bottom: none; padding-bottom: 0; }

  .detail-label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
  }

  .detail-value {
    font-size: 0.92rem;
    color: var(--text-primary);
    font-weight: 400;
  }

  /* Category bars */
  .cats-breakdown { display: flex; flex-direction: column; gap: 2rem; }

  .cat-bar-item { }

  .cat-bar-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .cat-bar-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .cat-bar-count {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .bar-track {
    height: 6px;
    background: var(--border);
    border-radius: 100px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .bar-fill {
    height: 100%;
    background: var(--rose-gold);
    border-radius: 100px;
    transition: width 1s ease;
  }

  .bar-fill--petal { background: var(--rose); }
  .bar-fill--gold { background: var(--gold); }
  .bar-fill--rose { background: var(--deep-rose); }

  .cat-bar-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    font-weight: 300;
  }

  /* Audience */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 2rem;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 20px;
  }

  .audience-icon {
    font-size: 1.2rem;
    color: var(--rose-gold);
    display: block;
    margin-bottom: 0.8rem;
  }

  .audience-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .audience-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 300;
  }

  /* Platforms */
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.2rem;
  }

  .platform-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 2rem 1rem;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s;
    text-align: center;
  }

  .platform-card:hover {
    transform: translateY(-4px);
    border-color: var(--rose-gold);
  }

  .platform-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--blush);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--rose-gold);
  }

  .platform-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .platform-handle {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  /* CTA */
  .mk-cta {
    background: var(--blush);
    padding: 5rem 2rem;
    text-align: center;
  }

  .mk-cta-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .cta-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-primary);
  }

  .cta-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 300;
  }

  .cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  .cta-btn-primary {
    padding: 0.9rem 2.2rem;
    background: var(--text-primary);
    color: var(--cream);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: background 0.2s, transform 0.15s;
  }

  .cta-btn-primary:hover { background: var(--rose-gold); transform: translateY(-2px); }

  .cta-btn-secondary {
    padding: 0.9rem 2.2rem;
    border: 1.5px solid var(--text-primary);
    color: var(--text-primary);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    transition: background 0.2s, color 0.2s, transform 0.15s;
