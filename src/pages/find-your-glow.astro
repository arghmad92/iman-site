---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Find Your Glow . Skincare Guide | Iman Abdul Rahim" description="Find your glow . answer 3 simple questions and get personalised skincare product recommendations.">
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-word">iman<sup>·</sup></span>
        <span class="logo-divider"></span>
        <span class="logo-sub">A Journal</span>
      </a>
      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        <span>Home</span>
      </a>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <div class="quiz-hero">
      <!-- Aurora background -->
      <div class="quiz-hero-aurora">
        <div class="qh-a1"></div>
        <div class="qh-a2"></div>
        <div class="qh-a3"></div>
      </div>
      <div class="quiz-hero-grain"></div>

      <div class="hero-inner">
        <div class="hero-top">
          <span class="hero-top-label">— A special feature · No. III</span>
          <div class="lang-toggle">
            <button class="lang-btn active" data-lang="en">EN</button>
            <button class="lang-btn" data-lang="ms">BM</button>
          </div>
        </div>

        <h1 class="quiz-title" data-en="Find your <em>glow.</em>" data-ms="Cari <em>cahaya</em> kulit anda.">Find your <em>glow.</em></h1>
        <p class="quiz-sub" data-en="A short editorial of three questions — skin type, concerns, and a note on motherhood. I'll write you a routine that's actually yours." data-ms="Tiga soalan ringkas — jenis kulit, masalah kulit, dan satu soalan tentang keibuan. Saya akan tulis rutin yang sebenar-benarnya untuk anda.">A short editorial of three questions — skin type, concerns, and a note on motherhood. I'll write you a routine that's actually yours.</p>

        <div class="quiz-meta-strip">
          <div class="quiz-meta-item">
            <span class="quiz-meta-num">03</span>
            <span class="quiz-meta-label">Questions</span>
          </div>
          <div class="quiz-meta-divider"></div>
          <div class="quiz-meta-item">
            <span class="quiz-meta-num">2<em>min</em></span>
            <span class="quiz-meta-label">To complete</span>
          </div>
          <div class="quiz-meta-divider"></div>
          <div class="quiz-meta-item">
            <span class="quiz-meta-num" id="quizCount">—</span>
            <span class="quiz-meta-label" data-en="Readers taken" data-ms="Pembaca">Readers taken</span>
          </div>
        </div>
      </div>
    </div>

    <div class="quiz-page">
      <!-- Quiz container . all questions on one page -->
      <div id="quizContainer" class="quiz-container">

        <!-- Q1: Skin Type -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 1" data-ms="Soalan 1">Question 1</div>
          <h2 data-en="What is your skin type?" data-ms="Apakah jenis kulit anda?">What is your skin type?</h2>
          <div class="quiz-options" id="skinTypeOptions">
            <button class="quiz-opt" data-value="dry" data-en="Dry" data-ms="Kering">Dry</button>
            <button class="quiz-opt" data-value="oily" data-en="Oily" data-ms="Berminyak">Oily</button>
            <button class="quiz-opt" data-value="combo" data-en="Combination" data-ms="Kombinasi">Combination</button>
            <button class="quiz-opt" data-value="normal" data-en="Normal" data-ms="Normal">Normal</button>
          </div>
        </div>

        <!-- Q2: Skin Concern (multi-select) -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 2" data-ms="Soalan 2">Question 2</div>
          <h2 data-en="What is your skin concern?" data-ms="Apakah masalah kulit anda?">What is your skin concern?</h2>
          <p class="quiz-hint" data-en="Select all that apply" data-ms="Pilih semua yang berkenaan">Select all that apply</p>
          <div class="quiz-options quiz-options--multi" id="concernOptions">
            <button class="quiz-opt quiz-opt--multi" data-concern="acne" data-en="Acne & Breakouts" data-ms="Jerawat & Breakouts">Acne & Breakouts</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dryness" data-en="Dryness & Dehydration" data-ms="Kering & Dehidrasi">Dryness & Dehydration</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pigmentation" data-en="Hyperpigmentation & Dark Spots" data-ms="Hiperpigmentasi & Bintik Gelap">Hyperpigmentation & Dark Spots</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pores" data-en="Large Pores & Blackheads" data-ms="Pori Besar & Blackheads">Large Pores & Blackheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="whitehead" data-en="Whiteheads" data-ms="Whiteheads">Whiteheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="aging" data-en="Anti-aging & Fine Lines" data-ms="Anti-penuaan & Garis Halus">Anti-aging & Fine Lines</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dull" data-en="Dull Skin" data-ms="Kulit Kusam">Dull Skin</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="sensitivity" data-en="Sensitivity & Redness" data-ms="Sensitif & Kemerahan">Sensitivity & Redness</button>
          </div>
        </div>

        <!-- Q3: Pregnant/Breastfeeding -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 3" data-ms="Soalan 3">Question 3</div>
          <h2 data-en="Are you pregnant or breastfeeding?" data-ms="Adakah anda mengandung atau menyusu?">Are you pregnant or breastfeeding?</h2>
          <div class="quiz-options" id="pregnantOptions">
            <button class="quiz-opt" data-value="pregnant_yes" data-en="Yes" data-ms="Ya">Yes</button>
            <button class="quiz-opt" data-value="pregnant_no" data-en="No" data-ms="Tidak">No</button>
          </div>
        </div>

        <!-- Submit button -->
        <button class="quiz-submit-btn" id="quizSubmitBtn" disabled data-en="Get My Routine" data-ms="Dapatkan Rutin Saya">Get My Routine</button>
        <p class="quiz-submit-hint" id="quizSubmitHint" data-en="Please answer all 3 questions above" data-ms="Sila jawab semua 3 soalan di atas">Please answer all 3 questions above</p>
      </div>

      <!-- Results (hidden until quiz complete) -->
      <div id="quizResults" class="quiz-results" style="display:none">
        <div class="result-card">
          <p class="section-label" data-en="Your Skin Type" data-ms="Jenis Kulit Anda">Your Skin Type</p>
          <h2 class="result-type" id="resultType"></h2>
          <p class="result-desc" id="resultDesc"></p>
        </div>

        <div id="resultInserts"></div>

        <div class="download-inline">
          <button class="download-btn-sm" id="downloadBtnTop" data-en="Save my routine" data-ms="Simpan rutin saya">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Save my routine
          </button>
        </div>

        <div class="result-section">
          <div class="routine-header routine-header--morning">
            <span class="routine-emoji">☀️</span>
            <div>
              <h3 data-en="Morning Routine" data-ms="Rutin Pagi">Morning Routine</h3>
              <p class="routine-subtitle" data-en="Start your day with these steps" data-ms="Mulakan hari anda dengan langkah ini">Start your day with these steps</p>
            </div>
          </div>
          <div id="morningSteps" class="routine-steps"></div>
        </div>

        <div class="result-section">
          <div class="routine-header routine-header--night">
            <span class="routine-emoji">🌙</span>
            <div>
              <h3 data-en="Night Routine" data-ms="Rutin Malam">Night Routine</h3>
              <p class="routine-subtitle" data-en="Wind down and repair your skin" data-ms="Berehat dan pulihkan kulit anda">Wind down and repair your skin</p>
            </div>
          </div>
          <div id="nightSteps" class="routine-steps"></div>
          <div id="extraSerums"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Recommended <em>Products</em>" data-ms="Produk <em>Disyorkan</em>">Recommended <em>Products</em></h3>
          <p class="result-note" data-en="Products tailored for your skin type and concerns. <span class='shop-hint'>Tap any product to shop</span>" data-ms="Produk yang sesuai untuk jenis kulit dan masalah anda. <span class='shop-hint'>Tekan mana-mana produk untuk beli</span>">Products tailored for your skin type and concerns. <span class="shop-hint">Tap any product to shop</span></p>
          <div id="allProductRecs"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Products I've <em>Reviewed</em>" data-ms="Produk Yang Saya <em>Review</em>">Products I've <em>Reviewed</em></h3>
          <p class="result-note" data-en="Products I've personally tried and reviewed on this blog:" data-ms="Produk yang saya dah cuba dan review di blog ini:">Products I've personally tried and reviewed on this blog:</p>
          <div id="productRecs" class="product-grid"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Helpful <em>Guides</em>" data-ms="Panduan <em>Berguna</em>">Helpful <em>Guides</em></h3>
          <div id="guideLinks" class="guide-grid"></div>
        </div>

        <div class="quiz-disclaimer">
          <p data-en="This is a general skincare guidance only and is not a substitute for professional advice. Product recommendations are based on general skin type guidelines . individual results may vary." data-ms="Ini hanyalah panduan penjagaan kulit umum dan bukan pengganti nasihat profesional. Cadangan produk berdasarkan garis panduan jenis kulit umum . hasil mungkin berbeza.">This is a general skincare guidance only and is not a substitute for professional advice. Product recommendations are based on general skin type guidelines . individual results may vary.</p>
        </div>

        <div class="result-cta">
          <button class="retake-btn" id="retakeBtn" data-en="Retake Quiz" data-ms="Ulang Kuiz">Retake Quiz</button>
          <a href="/posts/?cat=Skincare" class="browse-btn" data-en="Browse All Skincare Posts" data-ms="Lihat Semua Post Skincare">Browse All Skincare Posts</a>
        </div>
      </div>
    </div>
  </main>

  <footer class="post-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<script>
  let skinType = '';
  let concerns: string[] = [];
  let isPregnant: boolean | null = null;
  let currentLang = 'en';

  // Language toggle
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentLang = (btn as HTMLElement).dataset.lang || 'en';
      document.querySelectorAll('[data-en][data-ms]').forEach(el => {
        const text = (el as HTMLElement).dataset[currentLang] || (el as HTMLElement).dataset.en || '';
        (el as HTMLElement).innerHTML = text;
      });
      // If results are visible, re-render them in the new language
      const resultsEl = document.getElementById('quizResults');
      if (resultsEl && resultsEl.style.display !== 'none') {
        _skipScroll = true;
        showResults();
      }
    });
  });

  const submitBtn = document.getElementById('quizSubmitBtn') as HTMLButtonElement;
  const submitHint = document.getElementById('quizSubmitHint')!;

  function checkReady() {
    const ready = skinType !== '' && concerns.length > 0 && isPregnant !== null;
    submitBtn.disabled = !ready;
    submitHint.style.display = ready ? 'none' : '';
  }

  // Q1: Skin type (single select within group)
  document.getElementById('skinTypeOptions')!.querySelectorAll('.quiz-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.parentElement!.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      skinType = (btn as HTMLElement).dataset.value!;
      checkReady();
    });
  });

  // Q2: Multi-select concerns
  document.querySelectorAll('.quiz-opt--multi').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('selected');
      concerns = [];
      document.querySelectorAll('.quiz-opt--multi.selected').forEach(b => {
        concerns.push((b as HTMLElement).dataset.concern!);
      });
      checkReady();
    });
  });

  // Q3: Pregnant (single select within group)
  document.getElementById('pregnantOptions')!.querySelectorAll('.quiz-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.parentElement!.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      isPregnant = (btn as HTMLElement).dataset.value === 'pregnant_yes';
      checkReady();
    });
  });

  // Load quiz counter on page load
  fetch('https://api.counterapi.dev/v1/imanabdulrahim-skinquiz/completions/get')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('quizCount');
      if (el && typeof data.count === 'number') el.textContent = data.count.toLocaleString('en-MY');
    })
    .catch(() => {});

  // Submit
  submitBtn.addEventListener('click', () => {
    if (skinType && concerns.length > 0 && isPregnant !== null) {
      // Increment quiz counter
      fetch('https://api.counterapi.dev/v1/imanabdulrahim-skinquiz/completions/up')
        .then(r => r.json())
        .then(data => {
          const el = document.getElementById('quizCount');
          if (el && typeof data.count === 'number') el.textContent = data.count.toLocaleString('en-MY');
        })
        .catch(() => {});
      showResults();
    }
  });

  const skinData: Record<string, {
    label: string; labelMs: string;
    desc: string; descMs: string;
    morning: { step: string; stepMs: string; tip: string; tipMs: string }[];
    night: { step: string; stepMs: string; tip: string; tipMs: string }[];
    products: { name: string; slug: string; category: string }[];
    guides: { title: string; slug: string }[];
  }> = {
    oily: {
      label: 'Oily Skin', labelMs: 'Kulit Berminyak',
      desc: 'Your skin produces excess sebum, especially on the T-zone. You likely have visible pores and are prone to blackheads and breakouts. The good news? Oily skin ages slower! Focus on oil control without over-stripping.',
      descMs: 'Kulit anda menghasilkan lebih sebum, terutamanya di T-zone. Anda mungkin ada pori yang jelas dan cenderung kepada komedo dan jerawat. Berita baiknya? Kulit berminyak lambat berkedut! Fokus pada kawalan minyak tanpa mengeringkan kulit.',
      morning: [
        { step: 'Cleanser', stepMs: 'Pencuci Muka', tip: 'Use a gentle low pH cleanser.', tipMs: 'Gunakan pencuci muka lembut dengan pH rendah.' },
        { step: 'Toner', stepMs: 'Toner', tip: 'Use lightweight and gentle toner.', tipMs: 'Gunakan toner yang ringan dan lembut.' },
        { step: 'Moisturizer', stepMs: 'Pelembap', tip: 'Use lightweight gel or water-based moisturizer. Skipping moisturizer actually makes oily skin worse because your skin overproduces oil to compensate.', tipMs: 'Gunakan pelembap gel atau berasaskan air. Melangkau pelembap sebenarnya memburukkan kulit berminyak kerana kulit akan menghasilkan lebih minyak untuk mengimbangi.' },
        { step: 'Sunscreen', stepMs: 'Pelindung Matahari', tip: 'Use a non-greasy gel or watery essence formula that absorbs fast to protect your skin from harmful UV rays.', tipMs: 'Gunakan formula gel atau watery essence yang tidak berminyak dan cepat meresap untuk melindungi kulit daripada sinaran UV.' },
      ],
      night: [
        { step: 'First Cleanser', stepMs: 'Pencuci Pertama', tip: 'Use either oil-based cleanser, cleansing balm, or micellar water to break down sunscreen, makeup or sebum buildup from the day.', tipMs: 'Gunakan pencuci berasaskan minyak, cleansing balm, atau micellar water untuk membersihkan pelindung matahari, solekan atau sebum sepanjang hari.' },
        { step: 'Second Cleanser', stepMs: 'Pencuci Kedua', tip: 'Use a gentle low pH cleanser to finish off the double cleanse. This ensures your skin is truly clean and ready to absorb your night treatments.', tipMs: 'Gunakan pencuci muka lembut pH rendah untuk menghabiskan double cleanse. Ini memastikan kulit benar-benar bersih dan bersedia menyerap rawatan malam.' },
        { step: 'Toner', stepMs: 'Toner', tip: 'Use lightweight and gentle toner.', tipMs: 'Gunakan toner yang ringan dan lembut.' },
        { step: 'Serum', stepMs: 'Serum', tip: 'Niacinamide (Vitamin B3) serum to regulate sebum, minimize pores, and fade post-acne marks. Your skin repairs at night, so serums work best here.', tipMs: 'Serum Niacinamide (Vitamin B3) untuk mengawal sebum, mengecilkan pori, dan memudarkan parut jerawat. Kulit membaiki diri pada waktu malam, jadi serum paling berkesan di sini.' },
        { step: 'Moisturizer', stepMs: 'Pelembap', tip: 'Lightweight gel moisturizer to lock everything in.', tipMs: 'Pelembap gel ringan untuk mengunci semua bahan aktif.' },
      ],
      products: [
        { name: 'CosRx AHA/BHA Clarifying Treatment Toner', slug: 'cosrx-ahabha-clarifying-treatment-toner-review', category: 'Toner' },
        { name: 'Innisfree Daily UV Protection Essence Sensitive', slug: 'innisfree-daily-uv-protection-essence-sensitive-review', category: 'Sunscreen' },
        { name: 'Biore UV Aqua Rich Watery Essence', slug: 'biore-uv-aqua-rich-watery-essence-review', category: 'Sunscreen' },
        { name: 'Pixi Glow Tonic', slug: 'pixi-glow-tonic-review', category: 'Toner' },
        { name: 'Canmake Mermaid Skin Gel UV', slug: 'canmake-mermaid-skin-gel-uv-review', category: 'Sunscreen' },
        { name: 'The Ordinary Niacinamide 10% + Zinc 1%', slug: 'the-ordinary-niacinamide-10-zinc-1-review', category: 'Serum' },
      ],
      guides: [
        { title: 'Skincare 101: Low pH Cleanser', slug: 'skincare-101-low-ph-cleanser' },
        { title: 'Macam Mana Nak Kecilkan Pori', slug: 'macam-mana-nak-kecilkan-pori-pores' },
        { title: 'AHA & BHA Exfoliation Guide', slug: 'exfoliate-aha-bha' },
        { title: 'How to Treat Acne', slug: 'how-i-treat-acne-acne-skincare-routine' },
      ],
    },
    dry: {
      label: 'Dry Skin', labelMs: 'Kulit Kering',
      desc: 'Your skin lacks moisture and natural oils, often feeling tight or flaky. You need hydration-focused products.',
      descMs: 'Kulit anda kekurangan kelembapan dan minyak semula jadi, sering terasa ketat atau mengelupas. Anda perlukan produk yang fokus pada hidrasi.',
      morning: [
        { step: 'Cleanser', stepMs: 'Pencuci Muka', tip: 'Use a gentle low pH cream cleanser.', tipMs: 'Gunakan pencuci muka krim yang lembut dengan pH rendah.' },
        { step: 'Toner', stepMs: 'Toner', tip: 'Use a hydrating toner.', tipMs: 'Gunakan toner yang menghidrat.' },
        { step: 'Moisturizer', stepMs: 'Pelembap', tip: 'Rich cream with ceramides, shea butter, or squalane. These form a protective barrier that locks moisture in and keeps irritants out so your skin stays plump all day.', tipMs: 'Krim yang kaya dengan ceramide, shea butter, atau squalane. Bahan-bahan ini membentuk lapisan pelindung yang mengunci kelembapan dan menghalang iritasi supaya kulit kekal lembap sepanjang hari.' },
        { step: 'Sunscreen', stepMs: 'Pelindung Matahari', tip: 'Cream-type sunscreen with a moisturizing formula to protect your skin from harmful UV rays.', tipMs: 'Pelindung matahari jenis krim dengan formula melembapkan untuk melindungi kulit daripada sinaran UV.' },
      ],
      night: [
        { step: 'First Cleanser', stepMs: 'Pencuci Pertama', tip: 'Use either oil-based cleanser, cleansing balm, or micellar water to break down sunscreen, makeup or sebum buildup from the day.', tipMs: 'Gunakan pencuci berasaskan minyak, cleansing balm, atau micellar water untuk membersihkan pelindung matahari, solekan atau sebum sepanjang hari.' },
        { step: 'Second Cleanser', stepMs: 'Pencuci Kedua', tip: 'Use a gentle low pH cleanser to finish off the double cleanse. This ensures your skin is truly clean and ready to absorb your night treatments.', tipMs: 'Gunakan pencuci muka lembut pH rendah untuk menghabiskan double cleanse. Ini memastikan kulit benar-benar bersih dan bersedia menyerap rawatan malam.' },
        { step: 'Toner', stepMs: 'Toner', tip: 'Use hydrating toner again for extra moisture. You can even do 2-3 layers for a deeper boost.', tipMs: 'Gunakan toner hidrat sekali lagi untuk kelembapan tambahan. Boleh juga sapukan 2-3 lapisan untuk hidrasi lebih mendalam.' },
        { step: 'Serum', stepMs: 'Serum', tip: 'Hyaluronic acid or ceramide serum for moisture repair. HA pulls moisture into your skin while ceramides fix the gaps in your barrier that cause water loss.', tipMs: 'Serum hyaluronic acid atau ceramide untuk membaiki kelembapan. HA menarik kelembapan ke dalam kulit manakala ceramide membaiki jurang dalam barrier kulit yang menyebabkan kehilangan air.' },
        { step: 'Moisturizer', stepMs: 'Pelembap', tip: 'Rich night cream or moisturizer to seal everything in.', tipMs: 'Krim malam yang kaya atau pelembap untuk mengunci semua bahan aktif.' },
      ],
      products: [
        { name: 'CeraVe Hydrating Cleanser', slug: 'cerave-hydrating-cleanser-review', category: 'Cleanser' },
        { name: 'CeraVe Moisturizing Cream', slug: 'cerave-moisturizing-cream-review', category: 'Moisturizer' },
        { name: 'Hada Labo Gokujyun Hydrating Lotion', slug: 'hada-labo-gokujyun-hydrating-lotion-review', category: 'Toner' },
        { name: 'Dr. Jart+ Ceramidin Cream', slug: 'dr-jart-ceramidin-cream-review', category: 'Moisturizer' },
        { name: 'The Ordinary Hyaluronic Acid 2% + B5', slug: 'the-ordinary-hyaluronic-acid-2-b5-review', category: 'Serum' },
        { name: 'Laneige Lip Sleeping Mask', slug: 'laneige-lip-sleeping-mask-review', category: 'Lip Care' },
      ],
      guides: [
        { title: 'Why Hydration is Important', slug: 'why-hydration-is-important-and-how-to-keep-your-skin-hydrated' },
        { title: 'Moisturizers with Ceramide', slug: 'moisturizers-with-ceramide-that-i-have-tried' },
        { title: 'Skincare 101: Sheet Mask', slug: 'skincare-101-sheet-mask' },
        { title: 'My Skincare Routine (Dry Skin)', slug: 'my-current-skincare-routine-2017-dry-skin' },
      ],
    },
    combo: {
      label: 'Combination Skin', labelMs: 'Kulit Kombinasi',
      desc: 'You have the best of both worlds . oily T-zone (forehead, nose, chin) but normal-to-dry cheeks. The key is using lightweight products that balance both areas without over-moisturizing or over-drying.',
      descMs: 'Anda ada gabungan kedua-dua jenis kulit. T-zone (dahi, hidung, dagu) berminyak tetapi pipi normal hingga kering. Kuncinya adalah menggunakan produk ringan yang mengimbangkan kedua-dua kawasan.',
      morning: [
        { step: 'Cleanser', stepMs: 'Pencuci Muka', tip: 'Gentle low pH gel or mild foam cleanser. The key with combo skin is balancing both zones: clearing oil on your T-zone without drying out your cheeks.', tipMs: 'Pencuci muka gel pH rendah atau buih lembut. Kunci kulit kombinasi adalah mengimbangkan kedua-dua zon: membersihkan minyak di T-zone tanpa mengeringkan pipi.' },
        { step: 'Toner', stepMs: 'Toner', tip: 'Balancing, hydrating toner.', tipMs: 'Toner yang mengimbang dan menghidrat.' },
