              <span class="kayman-brand">${p.brand}</span>
              <span class="kayman-name">${p.name}</span>
              <span class="kayman-shop">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                ${shopText}
              </span>
            </a>`;
          }).join('')}
        </div>
      </div>`;
    });

    document.getElementById('allProductRecs')!.innerHTML = allHTML;

    // Blog product recommendations
    document.getElementById('productRecs')!.innerHTML = data.products.map(p =>
      `<a href="/posts/${p.slug}/" class="product-card">
        <span class="product-cat">${p.category}</span>
        <span class="product-name">${p.name}</span>
        <span class="product-link">${readReviewText}</span>
      </a>`
    ).join('');

    // Combine skin type guides + concern-specific guides (deduplicated)
    const allGuides = [...data.guides];
    const slugSet = new Set(allGuides.map(g => g.slug));
    concerns.forEach(c => {
      (concernGuides[c] || []).forEach(g => {
        if (!slugSet.has(g.slug)) { allGuides.push(g); slugSet.add(g.slug); }
      });
    });
    if (isPregnant) {
      if (!slugSet.has('skincare-during-pregnant-breastfeeding')) {
        allGuides.unshift({ title: 'Skincare During Pregnant/Breastfeeding', slug: 'skincare-during-pregnant-breastfeeding' });
      }
    }

    document.getElementById('guideLinks')!.innerHTML = allGuides.map(g =>
      `<a href="/posts/${g.slug}/" class="guide-card">
        <span class="guide-title">${g.title}</span>
        <span class="guide-arrow">→</span>
      </a>`
    ).join('');

    if (!_skipScroll) window.scrollTo({ top: 0, behavior: 'smooth' });
    _skipScroll = false;
  }

  document.getElementById('retakeBtn')!.addEventListener('click', () => {
    skinType = '';
    concerns = [];
    isPregnant = null;
    document.getElementById('quizResults')!.style.display = 'none';
    document.getElementById('quizContainer')!.style.display = '';
    document.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
    submitBtn.disabled = true;
    submitHint.style.display = '';
    document.getElementById('resultInserts')!.innerHTML = '';
    document.getElementById('extraSerums')!.innerHTML = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Download results as image
  document.getElementById('downloadBtnTop')!.addEventListener('click', () => {
    const isMs = currentLang === 'ms';
    const data = skinData[skinType] || skinData.normal;
    const routineType = (skinType === 'dry' && concerns.includes('acne')) ? 'combo' : skinType;
    const routineData = skinData[routineType] || data;

    const concernLabelsEn: Record<string, string> = {
      acne: 'Acne', dryness: 'Dryness', pigmentation: 'Pigmentation',
      pores: 'Large Pores', whitehead: 'Whiteheads', aging: 'Anti-aging',
      dull: 'Dull Skin', sensitivity: 'Sensitivity',
    };
    const concernLabelsMs: Record<string, string> = {
      acne: 'Jerawat', dryness: 'Kering', pigmentation: 'Pigmentasi',
      pores: 'Pori Besar', whitehead: 'Whiteheads', aging: 'Anti-penuaan',
      dull: 'Kulit Kusam', sensitivity: 'Sensitif',
    };
    const cLabels = isMs ? concernLabelsMs : concernLabelsEn;

    // Build the same serum override as the display logic
    const dlIngredientMapEn: Record<string, string> = {
      acne: 'Niacinamide to control breakouts and calm inflammation without over-drying your skin, Salicylic Acid (BHA) to go deep into pores to clear acne and Centella Asiatica + Panthenol to soothe redness, calm irritation',
      dryness: 'Hyaluronic Acid + Ceramides for deep hydration and to repair your moisture barrier so skin holds water better and Panthenol to soothe and heal dryness',
      pigmentation: 'Vitamin C + Arbutin + Niacinamide to fade dark spots and even out skin tone over time with consistent use',
      pores: 'Niacinamide + Zinc to tighten the appearance of pores and regulate excess oil that stretches them out',
      whitehead: 'AHA (Glycolic or Lactic Acid) to gently dissolve dead skin buildup that traps oil and causes clogged pores',
      aging: 'Retinol + Peptides to boost collagen production and reduce fine lines. Start slow (2-3x/week) to avoid irritation',
      dull: 'Vitamin C + Arbutin + Niacinamide to brighten and bring back that healthy glow by targeting uneven tone',
      sensitivity: 'Centella Asiatica + Panthenol to soothe redness, calm irritation, and strengthen your skin barrier',
    };
    const dlIngredientMapMs: Record<string, string> = {
      acne: 'Niacinamide untuk mengawal jerawat dan meredakan keradangan tanpa mengeringkan kulit, Salicylic Acid (BHA) untuk menembusi pori dan membersihkan jerawat dan Centella Asiatica + Panthenol untuk meredakan kemerahan dan kerengsaan',
      dryness: 'Hyaluronic Acid + Ceramides untuk hidrasi mendalam dan membaiki barrier kelembapan supaya kulit menahan air lebih baik dan Panthenol untuk menenangkan dan memulihkan kekeringan',
      pigmentation: 'Vitamin C + Arbutin + Niacinamide untuk memudarkan tompok gelap dan menyekatakan tona kulit',
      pores: 'Niacinamide + Zinc untuk mengetatkan rupa pori dan mengawal minyak berlebihan',
      whitehead: 'AHA (Glycolic atau Lactic Acid) untuk melarutkan sel kulit mati yang memerangkap minyak',
      aging: 'Retinol + Peptides untuk merangsang kolagen dan mengurangkan garis halus. Mulakan perlahan (2-3x/minggu)',
      dull: 'Vitamin C + Arbutin + Niacinamide untuk mencerahkan dan mengembalikan seri kulit yang sihat',
      sensitivity: 'Centella Asiatica + Panthenol untuk meredakan kemerahan dan mengukuhkan barrier kulit',
    };
    const dlPregnantMapEn: Record<string, string> = {
      acne: 'Niacinamide to control breakouts safely during pregnancy',
      whitehead: 'Low % Lactic Acid or Niacinamide for pregnancy-safe exfoliation',
      aging: 'Peptides + Vitamin C for collagen support without retinol',
      dull: 'Niacinamide + Vitamin C for safe brightening during pregnancy',
      pigmentation: 'Niacinamide + Vitamin C to fade dark spots safely',
    };
    const dlPregnantMapMs: Record<string, string> = {
      acne: 'Niacinamide untuk mengawal jerawat dengan selamat semasa mengandung',
      whitehead: 'Low % Lactic Acid atau Niacinamide untuk exfoliation selamat semasa mengandung',
      aging: 'Peptides + Vitamin C untuk sokongan kolagen tanpa retinol',
      dull: 'Niacinamide + Vitamin C untuk pencerahan selamat semasa mengandung',
      pigmentation: 'Niacinamide + Vitamin C untuk memudarkan tompok gelap dengan selamat',
    };
    const dlIngMap = isMs ? dlIngredientMapMs : dlIngredientMapEn;
    const dlPregMap = isMs ? dlPregnantMapMs : dlPregnantMapEn;

    // Build serum tip matching the displayed version
    let dlSerumTip = isMs
      ? (routineData.night[3]?.tipMs || 'Pilih serum berdasarkan masalah kulit anda')
      : (routineData.night[3]?.tip || 'Choose a serum based on your skin concern');
    let dlSerumTipMs = routineData.night[3]?.tipMs || dlSerumTip;
    let dlSerumTipEn = routineData.night[3]?.tip || dlSerumTip;
    if (concerns.length > 0) {
      const ingredientLines = concerns.map(c => {
        const ing = (isPregnant && dlPregMap[c]) ? dlPregMap[c] : dlIngMap[c];
        return ing ? `${cLabels[c] || c}: ${ing}` : '';
      }).filter(Boolean);
      const intro = isMs ? 'Gunakan serum dengan bahan-bahan ini berdasarkan masalah kulit anda:' : 'Use serum with these ingredients based on your concerns:';
      dlSerumTip = intro + '\n' + ingredientLines.join('\n');
    }

    // Build final night steps with serum override
    const dlNightSteps = routineData.night.map((r, i) => {
      if (i === 3) {
        return { ...r, step: 'Serum', stepMs: 'Serum', tip: dlSerumTip, tipMs: dlSerumTip };
      }
      return r;
    });

    const W = 1080;
    const pad = 60;
    const contentW = W - pad * 2;
    const stepTextX = pad + 48;
    const stepTextW = contentW - 48;

    const canvas = document.createElement('canvas');
    canvas.width = W;
    // Start with a tall canvas, we'll trim after drawing
    canvas.height = 8000;
    const ctx = canvas.getContext('2d')!;
    ctx.textBaseline = 'top';

    // Helper: wrap text
    function wrapText(text: string, maxW: number, font: string): string[] {
      ctx.font = font;
      const words = text.split(' ');
      const lines: string[] = [];
      let line = '';
      for (const word of words) {
        const test = line ? line + ' ' + word : word;
        if (ctx.measureText(test).width > maxW && line) {
          lines.push(line);
          line = word;
        } else {
          line = test;
        }
      }
      if (line) lines.push(line);
      return lines;
    }

    // Helper: get all tip lines (handles newlines in serum tips)
    function getTipLines(tip: string): string[] {
      const clean = tip.replace(/<[^>]*>/g, '').replace(/•/g, '').trim();
      const allLines: string[] = [];
      for (const para of clean.split('\n')) {
        if (!para.trim()) continue;
        allLines.push(...wrapText(para.trim(), stepTextW, '300 19px DM Sans, sans-serif'));
      }
      return allLines;
    }

    let y = pad;

    // === HEADER ===
    // Logo
    ctx.font = 'italic 500 32px Cormorant Garamond, serif';
    ctx.fillStyle = '#2a1a18';
    const logoText = 'iman';
    ctx.fillText(logoText, pad, y);
    const logoW = ctx.measureText(logoText).width;
    ctx.fillStyle = '#c08878';
    ctx.font = '600 38px Cormorant Garamond, serif';
    ctx.fillText('·', pad + logoW + 2, y - 4);
    ctx.font = '300 24px Cormorant Garamond, serif';
    ctx.fillStyle = '#5a4038';
    ctx.fillText('blog', pad + logoW + 18, y + 6);

    // Tagline right-aligned
    ctx.font = '300 18px DM Sans, sans-serif';
    ctx.fillStyle = '#c08878';
    const tagline = isMs ? 'Panduan Penjagaan Kulit' : 'Skincare Guide';
    const tagW = ctx.measureText(tagline).width;
    ctx.fillText(tagline, W - pad - tagW, y + 10);
    y += 48;

    // Divider
    ctx.strokeStyle = 'rgba(42,26,24,0.12)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad, y);
    ctx.lineTo(W - pad, y);
    ctx.stroke();
    y += 24;

    // === SKIN TYPE TITLE ===
    ctx.font = '400 36px Cormorant Garamond, serif';
    ctx.fillStyle = '#2a1a18';
    ctx.fillText(isMs ? data.labelMs : data.label, pad, y);
    y += 48;

    // === CONCERN PILLS ===
    if (concerns.length > 0) {
      let cx = pad;
      for (const c of concerns) {
        const label = cLabels[c] || c;
        ctx.font = '500 15px DM Sans, sans-serif';
        const tw = ctx.measureText(label).width;
        const pillW = tw + 24;
        if (cx + pillW > W - pad) { cx = pad; y += 34; }
        ctx.fillStyle = '#f5c8ce';
        ctx.beginPath();
        ctx.roundRect(cx, y, pillW, 28, 14);
        ctx.fill();
        ctx.fillStyle = '#9e4c56';
        ctx.fillText(label, cx + 12, y + 7);
        cx += pillW + 8;
      }
      y += 44;
    }

    // === DESCRIPTION ===
    const descText = isMs ? data.descMs : data.desc;
    const descLines = wrapText(descText, contentW, '300 20px DM Sans, sans-serif');
    ctx.font = '300 20px DM Sans, sans-serif';
    ctx.fillStyle = '#5a4038';
    for (const line of descLines) {
      ctx.fillText(line, pad, y);
      y += 28;
    }
    y += 32;

    // === ROUTINE RENDERER ===
    function drawRoutine(title: string, emoji: string, steps: typeof routineData.morning) {
      const isMorning = title.includes('Pagi') || title.includes('Morning');

      // Header bar — warm tones matching blog palette
      ctx.fillStyle = isMorning ? '#fef6e8' : '#eee8f0';
      ctx.beginPath();
      ctx.roundRect(pad, y, contentW, 42, 10);
      ctx.fill();
      ctx.strokeStyle = isMorning ? '#f0d8c0' : '#d8c8d8';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.roundRect(pad, y, contentW, 42, 10);
      ctx.stroke();

      ctx.font = '26px sans-serif';
      ctx.fillText(emoji, pad + 14, y + 8);
      ctx.font = '400 21px Cormorant Garamond, serif';
      ctx.fillStyle = '#2a1a18';
      ctx.fillText(title, pad + 50, y + 12);
      y += 58;

      // Steps
      for (let i = 0; i < steps.length; i++) {
        const step = steps[i];
        const stepName = isMs ? step.stepMs : step.step;
        const tipText = isMs ? step.tipMs : step.tip;
        const tipLines = getTipLines(tipText);

        const stepStartY = y;

        // Step number circle (vertically centered with step name)
        ctx.fillStyle = '#c08878';
        ctx.beginPath();
        ctx.arc(pad + 16, y + 12, 13, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#ffffff';
        ctx.font = '700 13px DM Sans, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(String(i + 1), pad + 16, y + 6);
        ctx.textAlign = 'left';

        // Step name
        ctx.font = '600 19px DM Sans, sans-serif';
        ctx.fillStyle = '#2a1a18';
        ctx.fillText(stepName, stepTextX, y);
        y += 26;

        // Tip lines
        ctx.font = '300 19px DM Sans, sans-serif';
        ctx.fillStyle = '#5a4038';
        for (const line of tipLines) {
          ctx.fillText(line, stepTextX, y);
          y += 24;
        }

        y += 10;

        // Divider between steps
        if (i < steps.length - 1) {
          ctx.strokeStyle = 'rgba(42,26,24,0.12)';
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(stepTextX, y);
          ctx.lineTo(W - pad, y);
          ctx.stroke();
          y += 10;
        }
      }
      y += 24;
    }

    drawRoutine(isMs ? 'Rutin Pagi' : 'Morning Routine', '☀️', routineData.morning);
    drawRoutine(isMs ? 'Rutin Malam' : 'Night Routine', '🌙', dlNightSteps);

    // === FOOTER ===
    y += 8;
    ctx.strokeStyle = 'rgba(42,26,24,0.12)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad, y);
    ctx.lineTo(W - pad, y);
    ctx.stroke();
    y += 24;

    ctx.font = '300 17px DM Sans, sans-serif';
    ctx.fillStyle = '#a08478';
    ctx.fillText('imanabdulrahim.com', pad, y);

    ctx.font = 'italic 500 17px Cormorant Garamond, serif';
    ctx.fillStyle = '#c08878';
    const brand = 'iman·blog';
    const brandW = ctx.measureText(brand).width;
    ctx.fillText(brand, W - pad - brandW, y);
    y += pad;

    // === TRIM & RENDER FINAL IMAGE ===
    // Copy drawn content to a correctly-sized canvas
    const finalCanvas = document.createElement('canvas');
    finalCanvas.width = W;
    finalCanvas.height = y;
    const fCtx = finalCanvas.getContext('2d')!;

    // Background — warm cream to match blog palette
    fCtx.fillStyle = '#fdf6f0';
    fCtx.fillRect(0, 0, W, y);

    // Decorative blush gradient (top-right)
    const grd1 = fCtx.createRadialGradient(W - 100, 150, 0, W - 100, 150, 250);
    grd1.addColorStop(0, 'rgba(245, 213, 208, 0.35)');
    grd1.addColorStop(1, 'rgba(245, 213, 208, 0)');
    fCtx.fillStyle = grd1;
    fCtx.fillRect(0, 0, W, y);

    // Decorative sage gradient (bottom-left)
    const grd2 = fCtx.createRadialGradient(80, y - 200, 0, 80, y - 200, 200);
    grd2.addColorStop(0, 'rgba(168, 181, 160, 0.2)');
    grd2.addColorStop(1, 'rgba(168, 181, 160, 0)');
    fCtx.fillStyle = grd2;
    fCtx.fillRect(0, 0, W, y);

    // Draw the content on top
    fCtx.drawImage(canvas, 0, 0);

    // Download
    const link = document.createElement('a');
    link.download = `my-skincare-routine-${skinType}.png`;
    link.href = finalCanvas.toDataURL('image/png');
    link.click();
  });
</script>

