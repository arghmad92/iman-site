---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Iman Abdul Rahim" description="The page you're looking for doesn't exist.">
  <main class="not-found">
    <div class="not-found-inner">
      <span class="not-found-code">404</span>
      <h1 class="not-found-title">Oops, page not found.</h1>
      <p class="not-found-sub">The page you're looking for might have been moved or no longer exists.</p>
      <div class="not-found-actions">
        <a href="/" class="nf-btn nf-btn--primary">Go Home</a>
        <a href="/posts/" class="nf-btn nf-btn--outline">Browse Posts</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    background: var(--cream);
    text-align: center;
    position: relative;
  }

  .not-found-inner {
    max-width: 460px;
  }

  .not-found-code {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(5rem, 15vw, 8rem);
    font-weight: 300;
    color: var(--blush);
    line-height: 1;
    display: block;
    margin-bottom: 0.5rem;
  }

  .not-found-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--text-primary);
    margin-bottom: 0.8rem;
    font-weight: 400;
  }

  .not-found-sub {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .not-found-actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nf-btn {
    padding: 0.7rem 1.8rem;
    border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .nf-btn--primary {
    background: var(--rose-gold);
    color: white;
  }
  .nf-btn--primary:hover {
    background: var(--deep-rose);
    transform: translateY(-1px);
  }

  .nf-btn--outline {
    border: 1.5px solid var(--rose-gold);
    color: var(--rose-gold);
  }
  .nf-btn--outline:hover {
    background: var(--rose-gold);
    color: white;
  }
</style>
