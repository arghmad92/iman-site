---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SideLabel from '../components/SideLabel.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import OrnamentDivider from '../components/OrnamentDivider.astro';
import Topics from '../components/Topics.astro';
import Posts from '../components/Posts.astro';
import PullQuote from '../components/PullQuote.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Iman Abdul Rahim — A Journal on Beauty, Motherhood & Lifestyle">
  <Header />
  <SideLabel />
  <main>
    <Hero />
    <Stats />
    <OrnamentDivider label="The Index" />
    <Topics />
    <OrnamentDivider label="Recent Writing" background="var(--ivory)" />
    <Posts />
    <PullQuote />
    <OrnamentDivider label="Correspondence" background="var(--cream)" />
  </main>
  <Footer />
</Layout>
