---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

const isExternal = !!post.data.externalUrl;
const { Content, headings } = isExternal ? { Content: null, headings: [] } : await render(post);

const categoryColorMap: Record<string, string> = {
  Skincare: '#fad4dc',
  Beauty: '#f0dbc8',
  Motherhood: '#fde8ec',
  Parenting: '#fde8ec',
  Lifestyle: '#fad4dc',
};
const catColor = categoryColorMap[post.data.category] ?? '#fad4dc';

// Adjacent posts for prev/next nav
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const idx = allPosts.findIndex((p) => p.id === post.id);
const prev = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
const next = idx > 0 ? allPosts[idx - 1] : null;

// Related posts: same category, exclude current
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

// TOC: h2 and h3 headings only
const tocHeadings = headings.filter((h) => h.depth <= 3);

// Social share URLs
const siteUrl = 'https://imanabdulrahim.com';
const postUrl = `${siteUrl}/posts/${post.id}/`;
const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(postUrl);
const whatsappUrl = `https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + postUrl)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
const twitterUrl = `https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}&via=imanabdulrahim`;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

// JSON-LD structured data
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "datePublished": new Date(post.data.date).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Iman Abdul Rahim",
    "url": siteUrl
  },
  "description": post.data.excerpt,
  ...(post.data.image ? { "image": post.data.image.startsWith('http') ? post.data.image : `${siteUrl}${post.data.image}` } : {}),
  "url": postUrl,
  "publisher": {
    "@type": "Person",
    "name": "Iman Abdul Rahim"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": post.data.category,
      "item": `${siteUrl}/#posts`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": postUrl
    }
  ]
};
---

{isExternal ? (
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${post.data.externalUrl}`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={post.data.externalUrl}>{post.data.title}</a>...</p>
  </body>
</html>
) : (
<Layout
  title={`${post.data.title} — Iman Abdul Rahim`}
  description={post.data.excerpt}
  image={post.data.image}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Reading progress bar -->
  <div class="reading-bar" id="readingBar"></div>

  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/#posts" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        All Posts
      </a>
    </nav>
  </header>

  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><a href="/#posts">{post.data.category}</a></li>
        <li aria-current="page">{post.data.title}</li>
      </ol>
    </nav>

    <div class="post-hero" style={`--accent: ${catColor}`}>
      <div class="post-hero-inner">
        <span class="post-category">{post.data.category}</span>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <span>{formatDate(post.data.date)}</span>
          <span class="meta-dot">·</span>
          <span>{post.data.readTime}</span>
        </div>
        <p class="post-excerpt">{post.data.excerpt}</p>
      </div>
      <div class="hero-deco">
        <div class="deco-a"></div>
        <div class="deco-b"></div>
      </div>
    </div>

    {post.data.image && (
      <div class="post-image-wrap">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="post-featured-image"
          loading="lazy"
        />
      </div>
    )}

    {tocHeadings.length > 0 && (
      <div class="toc-wrap">
        <details class="toc" open>
          <summary class="toc-title">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Table of Contents
          </summary>
          <nav class="toc-nav">
            <ol>
              {tocHeadings.map((h) => (
                <li class={`toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      </div>
    )}

    <article class="post-body" id="postArticle">
      <div class="post-content">
        <Content />
      </div>

      <!-- Like button -->
      <div class="like-section">
        <button class="like-btn" id="likeBtn" aria-label="Like this post">
          <span class="like-heart" id="likeHeart">♡</span>
          <span class="like-count" id="likeCount">—</span>
        </button>
        <p class="like-label">Did you enjoy this post?</p>
      </div>

      <!-- Social share -->
      <div class="share-section">
        <p class="share-label">Share this post</p>
        <div class="share-buttons">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-wa">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-fb">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="share-btn share-tw">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.261 5.628L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
            Twitter / X
          </a>
          <button class="share-btn share-ig" id="shareIgStory" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            IG Story
          </button>
        </div>
      </div>
    </article>

    {related.length > 0 && (
      <section class="related-posts">
        <div class="related-inner">
          <p class="section-label">Read Next</p>
          <h2 class="related-heading">More in <em>{post.data.category}</em></h2>
          <div class="related-grid">
            {related.map((p) => (
              <a href={`/posts/${p.id}/`} class="related-card">
                {p.data.image && (
                  <div class="related-img-wrap">
                    <img src={p.data.image} alt={p.data.title} loading="lazy" class="related-img" />
                  </div>
                )}
                <div class="related-body">
                  <span class="related-date">{formatDate(p.data.date)}</span>
                  <h3 class="related-title">{p.data.title}</h3>
                  <p class="related-excerpt">{p.data.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <nav class="post-nav">
      {prev ? (
        <a href={`/posts/${prev.id}/`} class="post-nav-link prev">
          <span class="nav-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Previous
          </span>
          <span class="nav-title">{prev.data.title}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={`/posts/${next.id}/`} class="post-nav-link next">
          <span class="nav-label">
            Next
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </span>
          <span class="nav-title">{next.data.title}</span>
        </a>
      ) : <div />}
    </nav>
  </main>

  <footer class="post-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>
)}

<script define:vars={{
  slug: post.id,
  storyTitle: post.data.title,
  storyCategory: post.data.category,
  storyImage: post.data.image || '',
  storyUrl: `https://imanabdulrahim.com/posts/${post.id}/`,
}}>
  // Reading progress bar
  const bar = document.getElementById('readingBar');
  const article = document.getElementById('postArticle');
  if (bar && article) {
    window.addEventListener('scroll', () => {
      const rect = article.getBoundingClientRect();
      const articleH = article.offsetHeight;
      const scrolled = -rect.top;
      const progress = Math.min(Math.max(scrolled / (articleH - window.innerHeight), 0), 1);
      bar.style.width = `${progress * 100}%`;
    }, { passive: true });
  }

  // Like button — uses abacus.jasoncameron.dev (free, no auth, reliable)
  const LIKE_KEY = `like-post-${slug}`;
  const NAMESPACE = 'imanabdulrahim';
  // Abacus requires keys: 3-64 chars, alphanumeric/underscore/hyphen only
  const counterKey = `like-${slug}`.slice(0, 64).replace(/[^a-zA-Z0-9_-]/g, '-');
  const LIKE_GET = `https://abacus.jasoncameron.dev/get/${NAMESPACE}/${counterKey}`;
  const LIKE_HIT = `https://abacus.jasoncameron.dev/hit/${NAMESPACE}/${counterKey}`;

  const likeBtn = document.getElementById('likeBtn');
  const likeCount = document.getElementById('likeCount');
  const likeHeart = document.getElementById('likeHeart');
  let liked = localStorage.getItem(LIKE_KEY) === '1';

  // Helper: parse abacus response (shape: { value: number })
  function readCount(data) {
    if (data && typeof data.value === 'number') return data.value;
    return null;
  }

  // Load current count — if the counter doesn't exist yet, abacus 404s.
  // Fall back to 0 so the UI is always populated.
  fetch(LIKE_GET)
    .then((r) => (r.ok ? r.json() : { value: 0 }))
    .then((data) => {
      const n = readCount(data);
      if (likeCount) likeCount.textContent = (n ?? 0).toLocaleString('en-MY');
    })
    .catch(() => {
      if (likeCount) likeCount.textContent = '0';
    });

  // Restore "already liked" state from localStorage
  if (liked && likeBtn && likeHeart) {
    likeBtn.classList.add('liked');
    likeHeart.textContent = '♥';
  }

  likeBtn?.addEventListener('click', async () => {
    if (liked) return;
    liked = true;
    localStorage.setItem(LIKE_KEY, '1');
    likeBtn.classList.add('liked');
    if (likeHeart) likeHeart.textContent = '♥';

    // Optimistic: bump the displayed count immediately so the UI feels responsive
    if (likeCount) {
      const current = parseInt((likeCount.textContent || '0').replace(/\D/g, ''), 10) || 0;
      likeCount.textContent = (current + 1).toLocaleString('en-MY');
    }

    // Fire-and-forget increment — /hit both creates (if missing) and increments
    try {
      const res = await fetch(LIKE_HIT);
      if (res.ok) {
        const data = await res.json();
        const n = readCount(data);
        if (likeCount && n != null) likeCount.textContent = n.toLocaleString('en-MY');
      }
    } catch {
      // Network error — keep the optimistic +1, localStorage remembers the like
    }
  });

  // ─────────── Instagram Story Card Generator ───────────
  const igBtn = document.getElementById('shareIgStory');

  function wrapText(ctx, text, x, y, maxWidth, lineHeight) {
    const words = text.split(' ');
    let line = '';
    const lines = [];
    for (const word of words) {
      const test = line + word + ' ';
      if (ctx.measureText(test).width > maxWidth && line) {
        lines.push(line.trim());
        line = word + ' ';
      } else {
        line = test;
      }
    }
    lines.push(line.trim());
    // Center the block vertically around y
    const startY = y - ((lines.length - 1) * lineHeight) / 2;
    lines.forEach((l, i) => ctx.fillText(l, x, startY + i * lineHeight));
    return lines.length;
  }

  function generateStoryCard(bgImage) {
    const W = 1080, H = 1920;
    const canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // ── Background ──
    if (bgImage) {
      // Draw cover image filling the canvas (cover fit)
      const imgRatio = bgImage.naturalWidth / bgImage.naturalHeight;
      const canvasRatio = W / H;
      let sw, sh, sx, sy;
      if (imgRatio > canvasRatio) {
        sh = bgImage.naturalHeight;
        sw = sh * canvasRatio;
        sx = (bgImage.naturalWidth - sw) / 2;
        sy = 0;
      } else {
        sw = bgImage.naturalWidth;
        sh = sw / canvasRatio;
        sx = 0;
        sy = (bgImage.naturalHeight - sh) / 2;
      }
      ctx.drawImage(bgImage, sx, sy, sw, sh, 0, 0, W, H);

      // Darken overlay — heavier at top and bottom for text readability
      const topGrad = ctx.createLinearGradient(0, 0, 0, H * 0.45);
      topGrad.addColorStop(0, 'rgba(30, 16, 12, 0.85)');
      topGrad.addColorStop(1, 'rgba(30, 16, 12, 0.15)');
      ctx.fillStyle = topGrad;
      ctx.fillRect(0, 0, W, H * 0.45);

      const botGrad = ctx.createLinearGradient(0, H * 0.5, 0, H);
      botGrad.addColorStop(0, 'rgba(30, 16, 12, 0.1)');
      botGrad.addColorStop(1, 'rgba(30, 16, 12, 0.92)');
      ctx.fillStyle = botGrad;
      ctx.fillRect(0, H * 0.5, W, H * 0.5);
    } else {
      // Solid gradient fallback if no image
      const grad = ctx.createLinearGradient(0, 0, W, H);
      grad.addColorStop(0, '#3a2820');
      grad.addColorStop(0.5, '#4a1e2e');
      grad.addColorStop(1, '#1c1410');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, W, H);
    }

    // ── Top: Blog logo ──
    ctx.textAlign = 'center';
    ctx.fillStyle = 'rgba(255, 255, 255, 0.55)';
    ctx.font = 'italic 42px "Cormorant Garamond", Georgia, serif';
    ctx.fillText('iman · blog', W / 2, 120);

    // ── Top: Category pill ──
    const catText = storyCategory.toUpperCase();
    ctx.font = '500 28px "DM Sans", sans-serif';
    const catWidth = ctx.measureText(catText).width + 56;
    const catX = (W - catWidth) / 2;
    const catY = 170;

    ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
    const pillRadius = 24;
    ctx.beginPath();
    ctx.roundRect(catX, catY, catWidth, 48, pillRadius);
    ctx.fill();

    ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
    ctx.font = '500 24px "DM Sans", sans-serif';
    ctx.letterSpacing = '4px';
    ctx.fillText(catText, W / 2, catY + 33);
    ctx.letterSpacing = '0px';

    // ── Center: Post title ──
    ctx.fillStyle = '#fff';
    ctx.font = '500 72px "Cormorant Garamond", Georgia, serif';
    const titleY = bgImage ? H * 0.42 : H * 0.44;
    wrapText(ctx, storyTitle, W / 2, titleY, W - 160, 92);

    // ── Decorative line ──
    ctx.strokeStyle = 'rgba(192, 136, 120, 0.6)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(W / 2 - 60, H - 320);
    ctx.lineTo(W / 2 + 60, H - 320);
    ctx.stroke();

    // ── Bottom: URL ──
    ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
    ctx.font = '300 30px "DM Sans", sans-serif';
    ctx.fillText('Read more at', W / 2, H - 240);

    ctx.fillStyle = '#fff';
    ctx.font = '500 38px "DM Sans", sans-serif';
    ctx.fillText('imanabdulrahim.com', W / 2, H - 185);

    // ── Bottom: Swipe up hint ──
    ctx.fillStyle = 'rgba(255, 255, 255, 0.35)';
    ctx.font = '300 26px "DM Sans", sans-serif';
    ctx.letterSpacing = '6px';
    ctx.fillText('SWIPE UP', W / 2, H - 80);
    ctx.letterSpacing = '0px';

    // ── Decorative corner dots ──
    ctx.fillStyle = 'rgba(192, 136, 120, 0.3)';
    ctx.beginPath(); ctx.arc(80, 80, 6, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(W - 80, 80, 6, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(80, H - 80, 6, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(W - 80, H - 80, 6, 0, Math.PI * 2); ctx.fill();

    return canvas;
  }

  igBtn?.addEventListener('click', () => {
    const btn = igBtn;
    const origHTML = btn.innerHTML;
    btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/></path></svg> Creating...`;
    btn.disabled = true;

    function downloadCard(canvas) {
      canvas.toBlob((blob) => {
        if (!blob) return;
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `iman-story-${slug.slice(0, 40)}.png`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);

        btn.innerHTML = origHTML;
        btn.disabled = false;

        // On mobile, try opening Instagram after a brief delay
        const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
        if (isMobile) {
          setTimeout(() => {
            window.location.href = 'instagram://story-camera';
          }, 800);
        }
      }, 'image/png');
    }

    // Try loading the cover image for the background
    if (storyImage) {
      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.onload = () => {
        const canvas = generateStoryCard(img);
        if (canvas) downloadCard(canvas);
      };
      img.onerror = () => {
        // CORS blocked or image failed — generate without background
        const canvas = generateStoryCard(null);
        if (canvas) downloadCard(canvas);
      };
      img.src = storyImage;
    } else {
      const canvas = generateStoryCard(null);
      if (canvas) downloadCard(canvas);
    }
  });
</script>

<style>
  /* Reading progress */
  .reading-bar {
    position: fixed;
