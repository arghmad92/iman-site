---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Skin Type Quiz — Find Your Perfect Routine | Iman Abdul Rahim" description="Take our skin type quiz to discover your skin type and get personalised skincare product recommendations.">
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <div class="quiz-hero">
      <div class="hero-inner">
        <p class="section-label">Skincare Quiz</p>
        <h1 class="quiz-title">Find your perfect <em>skincare routine.</em></h1>
        <p class="quiz-sub">Answer 3 simple questions and I'll recommend the best products for your skin — all personally reviewed on this blog.</p>
      </div>
      <div class="deco-a"></div>
    </div>

    <div class="quiz-page">
      <!-- Quiz container -->
      <div id="quizContainer" class="quiz-container">
        <!-- Progress -->
        <div class="quiz-progress">
          <div class="quiz-progress-bar" id="progressBar" style="width:0%"></div>
        </div>
        <p class="quiz-step" id="stepLabel">Question 1 of 3</p>

        <!-- Q1: Skin Type -->
        <div class="quiz-question active" data-q="0">
          <h2>What is your skin type?</h2>
          <div class="quiz-options">
            <button class="quiz-opt" data-value="dry">Dry</button>
            <button class="quiz-opt" data-value="oily">Oily</button>
            <button class="quiz-opt" data-value="combo">Combination</button>
            <button class="quiz-opt" data-value="normal">Normal</button>
          </div>
        </div>

        <!-- Q2: Skin Concern (multi-select) -->
        <div class="quiz-question" data-q="1">
          <h2>What is your skin concern?</h2>
          <p class="quiz-hint">Select all that apply</p>
          <div class="quiz-options quiz-options--multi">
            <button class="quiz-opt quiz-opt--multi" data-concern="acne">Acne & Breakouts</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dryness">Dryness & Dehydration</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pigmentation">Hyperpigmentation & Dark Spots</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pores">Large Pores & Blackheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="whitehead">Whiteheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="aging">Anti-aging & Fine Lines</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dull">Dull Skin</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="sensitivity">Sensitivity & Redness</button>
          </div>
          <button class="quiz-next-btn" id="concernNextBtn" disabled>Next</button>
        </div>

        <!-- Q3: Pregnant/Breastfeeding -->
        <div class="quiz-question" data-q="2">
          <h2>Are you pregnant or breastfeeding?</h2>
          <div class="quiz-options">
            <button class="quiz-opt" data-value="pregnant_yes">Yes</button>
            <button class="quiz-opt" data-value="pregnant_no">No</button>
          </div>
        </div>
      </div>

      <!-- Results (hidden until quiz complete) -->
      <div id="quizResults" class="quiz-results" style="display:none">
        <div class="result-card">
          <p class="section-label">Your Skin Type</p>
          <h2 class="result-type" id="resultType"></h2>
          <p class="result-desc" id="resultDesc"></p>
        </div>

        <div id="resultInserts"></div>

        <div class="result-section">
          <div class="routine-header routine-header--morning">
            <span class="routine-emoji">☀️</span>
            <div>
              <h3>Morning Routine</h3>
              <p class="routine-subtitle">Start your day with these steps</p>
            </div>
          </div>
          <div id="morningSteps" class="routine-steps"></div>
        </div>

        <div class="result-section">
          <div class="routine-header routine-header--night">
            <span class="routine-emoji">🌙</span>
            <div>
              <h3>Night Routine</h3>
              <p class="routine-subtitle">Wind down and repair your skin</p>
            </div>
          </div>
          <div id="nightSteps" class="routine-steps"></div>
          <div id="extraSerums"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading">Products I've <em>Reviewed</em></h3>
          <p class="result-note">Products I've personally tried and reviewed on this blog:</p>
          <div id="productRecs" class="product-grid"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading">Helpful <em>Guides</em></h3>
          <div id="guideLinks" class="guide-grid"></div>
        </div>

        <div class="result-cta">
          <button class="retake-btn" id="retakeBtn">Retake Quiz</button>
          <a href="/posts/?cat=Skincare" class="browse-btn">Browse All Skincare Posts</a>
        </div>
      </div>
    </div>
  </main>

  <footer class="post-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<script>
  let currentQ = 0;
  const totalQ = 3;
  let skinType = '';
  let concerns: string[] = [];
  let isPregnant = false;

  const questions = document.querySelectorAll('.quiz-question');
  const progressBar = document.getElementById('progressBar')!;
  const stepLabel = document.getElementById('stepLabel')!;

  function nextQuestion() {
    currentQ++;
    if (currentQ >= totalQ) {
      showResults();
    } else {
      questions.forEach(q => q.classList.remove('active'));
      questions[currentQ].classList.add('active');
      progressBar.style.width = `${(currentQ / totalQ) * 100}%`;
      stepLabel.textContent = `Question ${currentQ + 1} of ${totalQ}`;
    }
  }

  // Q1 & Q3: Single select
  document.querySelectorAll('.quiz-opt:not(.quiz-opt--multi)').forEach(btn => {
    btn.addEventListener('click', () => {
      const val = (btn as HTMLElement).dataset.value!;
      btn.parentElement!.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      if (currentQ === 0) skinType = val;
      if (currentQ === 2) isPregnant = val === 'pregnant_yes';

      setTimeout(nextQuestion, 300);
    });
  });

  // Q2: Multi-select concerns
  document.querySelectorAll('.quiz-opt--multi').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('selected');
      concerns = [];
      document.querySelectorAll('.quiz-opt--multi.selected').forEach(b => {
        concerns.push((b as HTMLElement).dataset.concern!);
      });
      (document.getElementById('concernNextBtn') as HTMLButtonElement).disabled = concerns.length === 0;
    });
  });

  document.getElementById('concernNextBtn')!.addEventListener('click', () => {
    if (concerns.length > 0) nextQuestion();
  });

  const skinData: Record<string, {
    label: string;
    desc: string;
    morning: { step: string; tip: string }[];
    night: { step: string; tip: string }[];
    products: { name: string; slug: string; category: string }[];
    guides: { title: string; slug: string }[];
  }> = {
    oily: {
      label: 'Oily Skin',
