---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Find Your Glow — Skincare Suggestion | Iman Abdul Rahim" description="Find your glow — answer 3 simple questions and get personalised skincare product recommendations.">
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
    </nav>
  </header>

  <main>
    <!-- Hero -->
    <div class="quiz-hero">
      <div class="hero-inner">
        <div class="lang-toggle">
          <button class="lang-btn active" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="ms">BM</button>
        </div>
        <p class="section-label" data-en="Skincare Suggestion" data-ms="Cadangan Penjagaan Kulit">Skincare Suggestion</p>
        <h1 class="quiz-title" data-en="Find your <em>glow.</em>" data-ms="Cari <em>cahaya</em> kulit anda.">Find your <em>glow.</em></h1>
        <p class="quiz-sub" data-en="Answer 3 simple questions and I'll suggest the best products for your skin." data-ms="Jawab 3 soalan mudah dan saya akan cadangkan produk terbaik untuk kulit anda.">Answer 3 simple questions and I'll suggest the best products for your skin.</p>
        <div class="quiz-counter">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span id="quizCount">—</span> <span data-en="people have taken this quiz" data-ms="orang telah mengambil kuiz ini">people have taken this quiz</span>
        </div>
      </div>
      <div class="deco-a"></div>
    </div>

    <div class="quiz-page">
      <!-- Quiz container — all questions on one page -->
      <div id="quizContainer" class="quiz-container">

        <!-- Q1: Skin Type -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 1" data-ms="Soalan 1">Question 1</div>
          <h2 data-en="What is your skin type?" data-ms="Apakah jenis kulit anda?">What is your skin type?</h2>
          <div class="quiz-options" id="skinTypeOptions">
            <button class="quiz-opt" data-value="dry" data-en="Dry" data-ms="Kering">Dry</button>
            <button class="quiz-opt" data-value="oily" data-en="Oily" data-ms="Berminyak">Oily</button>
            <button class="quiz-opt" data-value="combo" data-en="Combination" data-ms="Kombinasi">Combination</button>
            <button class="quiz-opt" data-value="normal" data-en="Normal" data-ms="Normal">Normal</button>
          </div>
        </div>

        <!-- Q2: Skin Concern (multi-select) -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 2" data-ms="Soalan 2">Question 2</div>
          <h2 data-en="What is your skin concern?" data-ms="Apakah masalah kulit anda?">What is your skin concern?</h2>
          <p class="quiz-hint" data-en="Select all that apply" data-ms="Pilih semua yang berkenaan">Select all that apply</p>
          <div class="quiz-options quiz-options--multi" id="concernOptions">
            <button class="quiz-opt quiz-opt--multi" data-concern="acne" data-en="Acne & Breakouts" data-ms="Jerawat & Breakouts">Acne & Breakouts</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dryness" data-en="Dryness & Dehydration" data-ms="Kering & Dehidrasi">Dryness & Dehydration</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pigmentation" data-en="Hyperpigmentation & Dark Spots" data-ms="Hiperpigmentasi & Bintik Gelap">Hyperpigmentation & Dark Spots</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="pores" data-en="Large Pores & Blackheads" data-ms="Pori Besar & Blackheads">Large Pores & Blackheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="whitehead" data-en="Whiteheads" data-ms="Whiteheads">Whiteheads</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="aging" data-en="Anti-aging & Fine Lines" data-ms="Anti-penuaan & Garis Halus">Anti-aging & Fine Lines</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="dull" data-en="Dull Skin" data-ms="Kulit Kusam">Dull Skin</button>
            <button class="quiz-opt quiz-opt--multi" data-concern="sensitivity" data-en="Sensitivity & Redness" data-ms="Sensitif & Kemerahan">Sensitivity & Redness</button>
          </div>
        </div>

        <!-- Q3: Pregnant/Breastfeeding -->
        <div class="quiz-section">
          <div class="quiz-q-label" data-en="Question 3" data-ms="Soalan 3">Question 3</div>
          <h2 data-en="Are you pregnant or breastfeeding?" data-ms="Adakah anda mengandung atau menyusu?">Are you pregnant or breastfeeding?</h2>
          <div class="quiz-options" id="pregnantOptions">
            <button class="quiz-opt" data-value="pregnant_yes" data-en="Yes" data-ms="Ya">Yes</button>
            <button class="quiz-opt" data-value="pregnant_no" data-en="No" data-ms="Tidak">No</button>
          </div>
        </div>

        <!-- Submit button -->
        <button class="quiz-submit-btn" id="quizSubmitBtn" disabled data-en="Get My Routine" data-ms="Dapatkan Rutin Saya">Get My Routine</button>
        <p class="quiz-submit-hint" id="quizSubmitHint" data-en="Please answer all 3 questions above" data-ms="Sila jawab semua 3 soalan di atas">Please answer all 3 questions above</p>
      </div>

      <!-- Results (hidden until quiz complete) -->
      <div id="quizResults" class="quiz-results" style="display:none">
        <div class="result-card">
          <p class="section-label">Your Skin Type</p>
          <h2 class="result-type" id="resultType"></h2>
          <p class="result-desc" id="resultDesc"></p>
        </div>

        <div id="resultInserts"></div>

        <div class="result-section">
          <div class="routine-header routine-header--morning">
            <span class="routine-emoji">☀️</span>
            <div>
              <h3 data-en="Morning Routine" data-ms="Rutin Pagi">Morning Routine</h3>
              <p class="routine-subtitle" data-en="Start your day with these steps" data-ms="Mulakan hari anda dengan langkah ini">Start your day with these steps</p>
            </div>
          </div>
          <div id="morningSteps" class="routine-steps"></div>
        </div>

        <div class="result-section">
          <div class="routine-header routine-header--night">
            <span class="routine-emoji">🌙</span>
            <div>
              <h3 data-en="Night Routine" data-ms="Rutin Malam">Night Routine</h3>
              <p class="routine-subtitle" data-en="Wind down and repair your skin" data-ms="Berehat dan pulihkan kulit anda">Wind down and repair your skin</p>
            </div>
          </div>
          <div id="nightSteps" class="routine-steps"></div>
          <div id="extraSerums"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Recommended <em>Products</em>" data-ms="Produk <em>Disyorkan</em>">Recommended <em>Products</em></h3>
          <p class="result-note" data-en="Products tailored for your skin type and concerns. <span class='shop-hint'>Tap any product to shop</span>" data-ms="Produk yang sesuai untuk jenis kulit dan masalah anda. <span class='shop-hint'>Tekan mana-mana produk untuk beli</span>">Products tailored for your skin type and concerns. <span class="shop-hint">Tap any product to shop</span></p>
          <div id="allProductRecs"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Products I've <em>Reviewed</em>" data-ms="Produk Yang Saya <em>Review</em>">Products I've <em>Reviewed</em></h3>
          <p class="result-note" data-en="Products I've personally tried and reviewed on this blog:" data-ms="Produk yang saya dah cuba dan review di blog ini:">Products I've personally tried and reviewed on this blog:</p>
          <div id="productRecs" class="product-grid"></div>
        </div>

        <div class="result-section">
          <h3 class="result-heading" data-en="Helpful <em>Guides</em>" data-ms="Panduan <em>Berguna</em>">Helpful <em>Guides</em></h3>
          <div id="guideLinks" class="guide-grid"></div>
        </div>

        <div class="quiz-disclaimer">
          <p data-en="This is a general skincare guidance only and is not a substitute for professional advice. Product recommendations are based on general skin type guidelines — individual results may vary." data-ms="Ini hanyalah panduan penjagaan kulit umum dan bukan pengganti nasihat profesional. Cadangan produk berdasarkan garis panduan jenis kulit umum — hasil mungkin berbeza.">This is a general skincare guidance only and is not a substitute for professional advice. Product recommendations are based on general skin type guidelines — individual results may vary.</p>
        </div>

        <div class="result-cta">
          <button class="retake-btn" id="retakeBtn" data-en="Retake Quiz" data-ms="Ulang Kuiz">Retake Quiz</button>
          <a href="/posts/?cat=Skincare" class="browse-btn" data-en="Browse All Skincare Posts" data-ms="Lihat Semua Post Skincare">Browse All Skincare Posts</a>
        </div>
      </div>
    </div>
  </main>

  <footer class="post-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<script>
  let skinType = '';
  let concerns: string[] = [];
  let isPregnant: boolean | null = null;
  let currentLang = 'en';

  // Language toggle
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentLang = (btn as HTMLElement).dataset.lang || 'en';
      document.querySelectorAll('[data-en][data-ms]').forEach(el => {
        const text = (el as HTMLElement).dataset[currentLang] || (el as HTMLElement).dataset.en || '';
        (el as HTMLElement).innerHTML = text;
      });
    });
  });

  const submitBtn = document.getElementById('quizSubmitBtn') as HTMLButtonElement;
  const submitHint = document.getElementById('quizSubmitHint')!;

  function checkReady() {
    const ready = skinType !== '' && concerns.length > 0 && isPregnant !== null;
    submitBtn.disabled = !ready;
    submitHint.style.display = ready ? 'none' : '';
  }

  // Q1: Skin type (single select within group)
  document.getElementById('skinTypeOptions')!.querySelectorAll('.quiz-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.parentElement!.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      skinType = (btn as HTMLElement).dataset.value!;
      checkReady();
    });
  });

  // Q2: Multi-select concerns
  document.querySelectorAll('.quiz-opt--multi').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('selected');
      concerns = [];
      document.querySelectorAll('.quiz-opt--multi.selected').forEach(b => {
        concerns.push((b as HTMLElement).dataset.concern!);
      });
      checkReady();
    });
  });

  // Q3: Pregnant (single select within group)
  document.getElementById('pregnantOptions')!.querySelectorAll('.quiz-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.parentElement!.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      isPregnant = (btn as HTMLElement).dataset.value === 'pregnant_yes';
      checkReady();
    });
  });

  // Load quiz counter on page load
  fetch('https://api.counterapi.dev/v1/imanabdulrahim-skinquiz/completions/get')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('quizCount');
      if (el && typeof data.count === 'number') el.textContent = data.count.toLocaleString('en-MY');
    })
    .catch(() => {});

  // Submit
  submitBtn.addEventListener('click', () => {
    if (skinType && concerns.length > 0 && isPregnant !== null) {
      // Increment quiz counter
      fetch('https://api.counterapi.dev/v1/imanabdulrahim-skinquiz/completions/up')
        .then(r => r.json())
        .then(data => {
          const el = document.getElementById('quizCount');
          if (el && typeof data.count === 'number') el.textContent = data.count.toLocaleString('en-MY');
        })
        .catch(() => {});
      showResults();
    }
  });

  const skinData: Record<string, {
    label: string;
    desc: string;
    morning: { step: string; tip: string }[];
    night: { step: string; tip: string }[];
    products: { name: string; slug: string; category: string }[];
    guides: { title: string; slug: string }[];
  }> = {
    oily: {
      label: 'Oily Skin',
      desc: 'Your skin produces excess sebum, especially on the T-zone. You likely have visible pores and are prone to blackheads and breakouts. The good news? Oily skin ages slower! Focus on oil control without over-stripping.',
      morning: [
        { step: 'Cleanser', tip: 'Gentle low pH cleanser — controls oil without stripping' },
        { step: 'Toner', tip: 'BHA/AHA toner to control oil and unclog pores' },
        { step: 'Moisturizer', tip: 'Lightweight gel-type, non-comedogenic' },
        { step: 'Sunscreen', tip: 'Non-greasy gel or watery essence formula' },
