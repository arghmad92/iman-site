        { name: 'Primera Essence Miracle Seed', slug: 'primera-essence-miracle-seed-review', category: 'Essence' },
        { name: 'Purito Comfy Water Sun Block', slug: 'purito-comfy-water-sun-block-spf50-pa-review', category: 'Sunscreen' },
        { name: 'The Inkey List Moisturizer', slug: 'the-inkey-list-moisturizer-review', category: 'Moisturizer' },
      ],
      guides: [
        { title: 'Skincare Routine for Combo/Acne Prone', slug: 'my-skincare-routine-for-combinationacne-prone-skin' },
        { title: 'How to Create a Simple Routine', slug: 'how-to-create-a-simple-skincare-routine' },
        { title: 'Skincare 101: Double Cleansing', slug: 'skincare-101-double-cleansing-method' },
        { title: 'Skincare 101: How to Choose a Cleanser', slug: 'skincare-101-how-to-choose-a-facial-cleanser' },
      ],
    },
    sensitive: {
      label: 'Sensitive Skin',
      desc: 'Your skin is easily irritated by products, weather, or stress. Redness, stinging, and reactions are common. Stick to fragrance-free, minimal-ingredient products and always patch test. Less is more!',
      morning: [
        { step: 'Cleanser', tip: 'Fragrance-free gentle cleanser — minimal ingredients, no SLS' },
        { step: 'Toner', tip: 'Calming toner with centella, aloe, or chamomile' },
        { step: 'Moisturizer', tip: 'Barrier repair cream with ceramides' },
        { step: 'Sunscreen', tip: 'Mineral/physical sunscreen — less irritating than chemical' },
      ],
      night: [
        { step: '1st Cleanser', tip: 'Gentle micellar water or mild cleansing balm' },
        { step: '2nd Cleanser', tip: 'Fragrance-free, pH-balanced gentle cleanser' },
        { step: 'Toner', tip: 'Calming, soothing toner — avoid alcohol-based' },
