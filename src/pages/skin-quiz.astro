  .logo-sub { color: var(--text-muted); font-weight: 300; font-size: 1rem; letter-spacing: 0.08em; }
  .back-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-secondary); transition: color 0.2s; }
  .back-link:hover { color: var(--text-primary); }

  .quiz-hero { padding: 8rem 2rem 4rem; background: var(--cream); position: relative; overflow: hidden; }
  .hero-inner { max-width: 700px; margin: 0 auto; position: relative; z-index: 1; }
  .section-label { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--rose-gold); margin-bottom: 0.8rem; font-weight: 500; }
  .quiz-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 5vw, 3rem); color: var(--text-primary); margin-bottom: 0.8rem; }
  .quiz-title em { font-style: italic; color: var(--rose-gold); }
  .quiz-sub { font-size: 0.95rem; color: var(--text-secondary); font-weight: 300; line-height: 1.8; }
