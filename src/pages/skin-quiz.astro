      { title: 'Soothing Ingredients Guide', slug: 'soothing-ingredients' },
      { title: 'Skincare 101: Skin Barrier', slug: 'skincare-101-skin-barrier' },
    ],
  };

  function showResults() {
    const data = skinData[skinType] || skinData.normal;

    document.getElementById('quizContainer')!.style.display = 'none';
    document.getElementById('quizResults')!.style.display = '';

    document.getElementById('resultType')!.textContent = data.label;

    // Build description with pregnancy warning if needed
    let desc = data.desc;
    if (isPregnant) {
      desc += '\n\n⚠️ Since you\'re pregnant/breastfeeding, please avoid retinol, salicylic acid (BHA), high-dose vitamin C, and chemical peels. Stick to gentle, pregnancy-safe products. When in doubt, check with your doctor.';
    }
    document.getElementById('resultDesc')!.textContent = desc;

    // Show pregnancy banner if applicable
    const pregnancyBanner = isPregnant
      ? `<div class="pregnancy-warning">
          <strong>🤰 Pregnancy/Breastfeeding Note</strong>
          <p>Avoid: Retinol, BHA (Salicylic Acid), Benzoyl Peroxide, high-dose Vitamin C. Stick to gentle hydrating products. I've written about this — <a href="/posts/skincare-during-pregnant-breastfeeding/">read my safe skincare guide here</a>.</p>
        </div>`
      : '';

    // Concern tags — readable labels
    const concernLabels: Record<string, string> = {
      acne: 'Acne & Breakouts', dryness: 'Dryness', pigmentation: 'Pigmentation',
      pores: 'Large Pores', whitehead: 'Whiteheads', aging: 'Anti-aging',
      dull: 'Dull Skin', sensitivity: 'Sensitivity',
    };
    const concernTags = concerns.length > 0
      ? `<div class="concern-tags"><span class="concern-tags-label">Your concerns:</span>${concerns.map(c => `<span class="concern-tag">${concernLabels[c] || c}</span>`).join('')}</div>`
      : '';

    // Personalise night serum based on concerns + pregnancy
    const serumMap: Record<string, { name: string; tip: string }> = {
      acne: { name: 'Acne-fighting Serum', tip: 'Niacinamide + Tea Tree — controls breakouts and reduces inflammation' },
      dryness: { name: 'Hydrating Serum', tip: 'Hyaluronic Acid + Ceramides — deep hydration and barrier repair' },
      pigmentation: { name: 'Brightening Serum', tip: 'Vitamin C + Arbutin + Niacinamide — fades dark spots and evens skin tone' },
      pores: { name: 'Pore-refining Serum', tip: 'Niacinamide + Zinc — tightens pores and controls oil' },
      whitehead: { name: 'Exfoliating Serum', tip: 'AHA (Glycolic/Lactic Acid) — dissolves dead skin and prevents clogging' },
      aging: { name: 'Anti-aging Serum', tip: 'Retinol + Peptides — boosts collagen and reduces fine lines' },
      dull: { name: 'Brightening Serum', tip: 'Vitamin C + Arbutin + Niacinamide — fades dark spots and adds radiance' },
      sensitivity: { name: 'Calming Serum', tip: 'Centella Asiatica + Panthenol — soothes redness and repairs skin barrier' },
    };

    // Pregnancy-safe swaps
    const pregnantSerumMap: Record<string, { name: string; tip: string }> = {
      acne: { name: 'Pregnancy-safe Acne Serum', tip: 'Niacinamide — controls breakouts safely during pregnancy' },
      whitehead: { name: 'Gentle Exfoliating Serum', tip: 'Low % Lactic Acid or Niacinamide — pregnancy-safe option' },
      aging: { name: 'Pregnancy-safe Anti-aging Serum', tip: 'Peptides + Vitamin C — collagen support without retinol' },
      dull: { name: 'Pregnancy-safe Brightening Serum', tip: 'Niacinamide + Vitamin C — safe brightening' },
      pigmentation: { name: 'Pregnancy-safe Brightening Serum', tip: 'Niacinamide + Vitamin C — fades dark spots safely' },
    };

    // Build personalised serum recommendation
    let serumRec = { name: 'Serum', tip: data.night[3]?.tip || 'Choose based on your concern' };
    if (concerns.length > 0) {
      const primaryConcern = concerns[0];
      if (isPregnant && pregnantSerumMap[primaryConcern]) {
        serumRec = pregnantSerumMap[primaryConcern];
      } else if (serumMap[primaryConcern]) {
        serumRec = serumMap[primaryConcern];
      }
    }

    // Override serum in night routine
    const nightSteps = data.night.map((r, i) => i === 3 ? { step: serumRec.name, tip: serumRec.tip } : r);

    // Build routine HTML
    function renderRoutine(steps: { step: string; tip: string }[]) {
      return steps.map((r, i) =>
        `<div class="routine-step">
          <span class="step-num">${i + 1}</span>
          <div class="step-body">
            <span class="step-name">${r.step}</span>
            <span class="step-tip">${r.tip}</span>
          </div>
        </div>`
      ).join('');
    }

    // Inject pregnancy banner and concern tags
    document.getElementById('resultInserts')!.innerHTML = pregnancyBanner + concernTags;

    // Render routines
    document.getElementById('morningSteps')!.innerHTML = renderRoutine(data.morning);
    document.getElementById('nightSteps')!.innerHTML = renderRoutine(nightSteps);

    // Show extra serum concerns if multiple selected
    const extraSerumsEl = document.getElementById('extraSerums')!;
    if (concerns.length > 1) {
      const extraSerums = concerns.slice(1).map(c => {
        const s = (isPregnant && pregnantSerumMap[c]) ? pregnantSerumMap[c] : serumMap[c];
        return s ? `<div class="extra-serum-card">
          <span class="extra-serum-name">${s.name}</span>
          <span class="extra-serum-tip">${s.tip}</span>
        </div>` : '';
      }).filter(Boolean).join('');
      if (extraSerums) {
        extraSerumsEl.innerHTML = `<div class="extra-serums-box">
          <p class="extra-serums-title">Also consider alternating these serums for your other concerns:</p>
          <div class="extra-serum-list">${extraSerums}</div>
        </div>`;
      }
    } else {
      extraSerumsEl.innerHTML = '';
    }

    // Product recommendations
    document.getElementById('productRecs')!.innerHTML = data.products.map(p =>
      `<a href="/posts/${p.slug}/" class="product-card">
        <span class="product-cat">${p.category}</span>
        <span class="product-name">${p.name}</span>
        <span class="product-link">Read review →</span>
      </a>`
    ).join('');

    // Combine skin type guides + concern-specific guides (deduplicated)
    const allGuides = [...data.guides];
    const slugSet = new Set(allGuides.map(g => g.slug));
    concerns.forEach(c => {
      (concernGuides[c] || []).forEach(g => {
        if (!slugSet.has(g.slug)) { allGuides.push(g); slugSet.add(g.slug); }
      });
    });
    if (isPregnant) {
      if (!slugSet.has('skincare-during-pregnant-breastfeeding')) {
        allGuides.unshift({ title: 'Skincare During Pregnant/Breastfeeding', slug: 'skincare-during-pregnant-breastfeeding' });
      }
    }

    document.getElementById('guideLinks')!.innerHTML = allGuides.map(g =>
      `<a href="/posts/${g.slug}/" class="guide-card">
        <span class="guide-title">${g.title}</span>
        <span class="guide-arrow">→</span>
      </a>`
    ).join('');

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.getElementById('retakeBtn')!.addEventListener('click', () => {
    skinType = '';
    concerns = [];
    isPregnant = false;
    currentQ = 0;
    document.getElementById('quizResults')!.style.display = 'none';
    document.getElementById('quizContainer')!.style.display = '';
    questions.forEach((q, i) => q.classList.toggle('active', i === 0));
    document.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
    progressBar.style.width = '0%';
    stepLabel.textContent = 'Question 1 of 3';
    (document.getElementById('concernNextBtn') as HTMLButtonElement).disabled = true;
    document.getElementById('resultInserts')!.innerHTML = '';
    document.getElementById('extraSerums')!.innerHTML = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

