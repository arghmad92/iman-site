        { title: 'How to Choose Vitamin C Serum', slug: 'how-to-choose-vitamin-c-serum-for-your-skincare-routine' },
        { title: 'Brightening Ingredients', slug: 'brightening-ingredients' },
        { title: 'Sunblock/Sunscreen 101', slug: 'sunblock-sunscreen-101' },
      ],
    },
  };

  // Concern-specific extra guides
  const concernGuides: Record<string, { title: string; slug: string }[]> = {
    acne: [
      { title: 'How I Treat Acne', slug: 'how-i-treat-acne-acne-skincare-routine' },
      { title: 'How to Reduce Acne Scars', slug: 'how-to-reduce-acne-scars' },
    ],
    dryness: [
      { title: 'Why Hydration is Important', slug: 'why-hydration-is-important-and-how-to-keep-your-skin-hydrated' },
      { title: 'Hydrating During Ramadhan', slug: 'how-to-keep-your-skin-stay-hydrated-during-ramadhan' },
    ],
    pigmentation: [
      { title: 'Brightening Ingredients', slug: 'brightening-ingredients' },
      { title: 'How to Choose Vitamin C Serum', slug: 'how-to-choose-vitamin-c-serum-for-your-skincare-routine' },
    ],
    pores: [
      { title: 'Macam Mana Nak Kecilkan Pori', slug: 'macam-mana-nak-kecilkan-pori-pores' },
      { title: 'AHA & BHA Exfoliation', slug: 'exfoliate-aha-bha' },
    ],
    whitehead: [
      { title: 'Whitehead and Blackhead Guide', slug: 'whitehead-and-blackhead' },
      { title: 'AHA & BHA Exfoliation', slug: 'exfoliate-aha-bha' },
    ],
    aging: [
      { title: 'Brightening Ingredients', slug: 'brightening-ingredients' },
      { title: 'Vitamins in Skincare', slug: 'vitamins-in-skincare' },
    ],
    dull: [
      { title: 'Macam Mana Nak Kurangkan Kulit Kusam', slug: 'macam-mana-nak-kurangkan-kulit-kusam' },
      { title: 'Brightening Ingredients', slug: 'brightening-ingredients' },
    ],
    sensitivity: [
      { title: 'Soothing Ingredients Guide', slug: 'soothing-ingredients' },
      { title: 'Skincare 101: Skin Barrier', slug: 'skincare-101-skin-barrier' },
    ],
  };

  function showResults() {
    // Smart routine override: certain concern + skin type combos use a different routine
    let routineType = skinType;
    if (skinType === 'dry' && concerns.includes('acne')) {
      routineType = 'combo';
    }

    const data = skinData[skinType] || skinData.normal;
    const routineData = skinData[routineType] || data;

    document.getElementById('quizContainer')!.style.display = 'none';
    document.getElementById('quizResults')!.style.display = '';

    document.getElementById('resultType')!.textContent = data.label;

    // Build description with pregnancy warning if needed
    let desc = data.desc;
    if (isPregnant) {
      desc += '\n\n⚠️ Since you\'re pregnant/breastfeeding, please avoid retinol, salicylic acid (BHA), high-dose vitamin C, and chemical peels. Stick to gentle, pregnancy-safe products. When in doubt, check with your doctor.';
    }
    document.getElementById('resultDesc')!.textContent = desc;

    // Show pregnancy banner if applicable
    const pregnancyBanner = isPregnant
      ? `<div class="pregnancy-warning">
          <strong>🤰 Pregnancy/Breastfeeding Note</strong>
          <p>Avoid: Retinol, BHA (Salicylic Acid), Benzoyl Peroxide, high-dose Vitamin C. Stick to gentle hydrating products. I've written about this — <a href="/posts/skincare-during-pregnant-breastfeeding/">read my safe skincare guide here</a>.</p>
        </div>`
      : '';

    // Concern tags — readable labels
    const concernLabels: Record<string, string> = {
      acne: 'Acne & Breakouts', dryness: 'Dryness', pigmentation: 'Pigmentation',
      pores: 'Large Pores', whitehead: 'Whiteheads', aging: 'Anti-aging',
      dull: 'Dull Skin', sensitivity: 'Sensitivity',
    };
    const concernTags = concerns.length > 0
      ? `<div class="concern-tags"><span class="concern-tags-label">Your concerns:</span>${concerns.map(c => `<span class="concern-tag">${concernLabels[c] || c}</span>`).join('')}</div>`
      : '';

    // Ingredient recommendations per concern
    const ingredientMap: Record<string, string> = {
      acne: 'Niacinamide + Tea Tree — controls breakouts and reduces inflammation',
      dryness: 'Hyaluronic Acid + Ceramides — deep hydration and barrier repair',
      pigmentation: 'Vitamin C + Arbutin + Niacinamide — fades dark spots and evens skin tone',
      pores: 'Niacinamide + Zinc — tightens pores and controls oil',
      whitehead: 'AHA (Glycolic/Lactic Acid) — dissolves dead skin and prevents clogging',
      aging: 'Retinol + Peptides — boosts collagen and reduces fine lines',
      dull: 'Vitamin C + Arbutin + Niacinamide — brightens and adds radiance',
      sensitivity: 'Centella Asiatica + Panthenol — soothes redness and repairs skin barrier',
    };

    // Pregnancy-safe ingredient swaps
    const pregnantIngredientMap: Record<string, string> = {
      acne: 'Niacinamide — controls breakouts safely during pregnancy',
      whitehead: 'Low % Lactic Acid or Niacinamide — pregnancy-safe exfoliation',
      aging: 'Peptides + Vitamin C — collagen support without retinol',
      dull: 'Niacinamide + Vitamin C — safe brightening',
      pigmentation: 'Niacinamide + Vitamin C — fades dark spots safely',
    };

    // Build serum step with all concern ingredients listed underneath
    let serumTip = routineData.night[3]?.tip || 'Choose a serum based on your skin concern';
    if (concerns.length > 0) {
      const ingredientLines = concerns.map(c => {
        const ing = (isPregnant && pregnantIngredientMap[c]) ? pregnantIngredientMap[c] : ingredientMap[c];
        return ing ? `<span class="serum-ingredient">• ${concernLabels[c] || c}: ${ing}</span>` : '';
      }).filter(Boolean).join('');
      serumTip = `Use serum with these ingredients based on your concerns:${ingredientLines ? `<div class="serum-ingredients">${ingredientLines}</div>` : ''}`;
    }

    // Override serum in night routine
    const nightSteps = routineData.night.map((r, i) => i === 3 ? { step: 'Serum', tip: serumTip } : r);

    // Build routine HTML (tip can contain HTML for serum ingredients)
    function renderRoutine(steps: { step: string; tip: string }[]) {
      return steps.map((r, i) =>
        `<div class="routine-step">
          <span class="step-num">${i + 1}</span>
          <div class="step-body">
            <span class="step-name">${r.step}</span>
            <div class="step-tip">${r.tip}</div>
          </div>
        </div>`
      ).join('');
    }

    // Inject pregnancy banner and concern tags
    document.getElementById('resultInserts')!.innerHTML = pregnancyBanner + concernTags;

    // Render routines
    document.getElementById('morningSteps')!.innerHTML = renderRoutine(routineData.morning);
    document.getElementById('nightSteps')!.innerHTML = renderRoutine(nightSteps);

    // Clear extra serums (no longer needed — all in serum step)
    document.getElementById('extraSerums')!.innerHTML = '';

    // Kayman Beauty product recommendations
    const kaymanProducts: Record<string, { name: string; img: string; url: string; step: string }> = {
      cleansing_sherbet: { name: 'HyaluMelon Micellar Water', img: '/kayman/micellar.png', url: 'https://s.shopee.com.my/1qXfvhYiDZ', step: '1st Cleanser' },
      coalberry: { name: 'CoalBerry Cleanser', img: '/kayman/coalberry.png', url: 'https://s.shopee.com.my/5Ao7tfH7nX', step: 'Cleanser' },
      coalface: { name: 'CoalFace Soap', img: '/kayman/coalface.png', url: 'https://s.shopee.com.my/4LF0uDIPnn', step: 'Cleanser' },
      hyalumelon: { name: 'HyaluMelon Mist Toner', img: '/kayman/hyalumelon.png', url: 'https://s.shopee.com.my/gLiXPKeZ2', step: 'Toner' },
      rosa_glow: { name: 'Rosa Glow Treatment Essence', img: '/kayman/rosa-glow.png', url: 'https://s.shopee.com.my/6fcvgSsXEV', step: 'Essence' },
      honeyglo: { name: 'HoneyGlo Facial Exfoliant', img: '/kayman/honeyglo.png', url: 'https://s.shopee.com.my/2LTwWUHcGq', step: 'Exfoliant' },
      skintella_serum: { name: 'Skintella Repairing Serum', img: '/kayman/skintella-serum.png', url: 'https://s.shopee.com.my/gLiXL8JU0', step: 'Serum' },
      blumarine_ampoule: { name: 'BluMarine Hydrating Ampoule', img: '/kayman/blumarine-ampoule.png', url: 'https://s.shopee.com.my/BPRwRA9mB', step: 'Ampoule' },
      blumarine_refining: { name: 'BluMarine Refining Serum', img: '/kayman/blumarine-refining.png', url: 'https://s.shopee.com.my/10yYw49NA9', step: 'Serum' },
      skintella_gel: { name: 'Skintella Moisturizing Gel', img: '/kayman/skintella-gel.png', url: 'https://s.shopee.com.my/900qSdmH1K', step: 'Moisturizer' },
      blumarine_cream: { name: 'BluMarine Moisturizing Cream', img: '/kayman/blumarine-cream.png', url: 'https://s.shopee.com.my/AACnqqJjjE', step: 'Moisturizer' },
      suntella: { name: 'Suntella UV Milk SPF50+', img: '/kayman/suntella.png', url: 'https://s.shopee.com.my/9AKGf5Lnc5', step: 'Sunscreen' },
    };

    // Build Kayman recs based on skin type + concerns
    const kaymanRecs: string[] = [];
    const addedKayman = new Set<string>();
    function addKayman(key: string) { if (!addedKayman.has(key) && kaymanProducts[key]) { addedKayman.add(key); kaymanRecs.push(key); } }

    // 1st Cleanser — all skin types
    addKayman('cleansing_sherbet');

    // 2nd Cleanser — by skin type
    if (skinType === 'oily') { addKayman('coalface'); }
    else if (skinType === 'combo') { addKayman('coalberry'); addKayman('coalface'); }
    else { addKayman('coalberry'); }

    // Toner — all
    addKayman('hyalumelon');

    // Essence — by concern
    if (concerns.some(c => ['dryness', 'pigmentation', 'aging', 'dull', 'sensitivity'].includes(c))) {
      addKayman('rosa_glow');
    }

    // Exfoliant — by concern (skip for dryness and sensitivity)
    if (concerns.some(c => ['acne', 'pigmentation', 'pores', 'whitehead', 'aging', 'dull'].includes(c))) {
      addKayman('honeyglo');
    }

    // Serum — by concern
    if (concerns.some(c => ['acne', 'sensitivity', 'pigmentation', 'aging', 'dull'].includes(c))) {
      addKayman('skintella_serum');
    }
    if (concerns.some(c => ['acne', 'pores', 'whitehead'].includes(c))) {
      addKayman('blumarine_refining');
    }
    if (concerns.some(c => ['dryness'].includes(c))) {
      addKayman('blumarine_ampoule');
    }

    // Moisturizer — by skin type
    if (skinType === 'dry' || skinType === 'sensitive') {
      addKayman('blumarine_cream');
    } else if (skinType === 'normal') {
      addKayman('skintella_gel');
      addKayman('blumarine_cream');
    } else {
      addKayman('skintella_gel');
    }

    // Sunscreen — all
    addKayman('suntella');

    // Group products by step/type
    const stepOrder = ['1st Cleanser', 'Cleanser', 'Toner', 'Essence', 'Exfoliant', 'Serum', 'Ampoule', 'Moisturizer', 'Sunscreen'];
    const stepLabels: Record<string, string> = {
      '1st Cleanser': 'First Cleanser',
      'Cleanser': 'Cleanser',
      'Toner': 'Toner',
      'Essence': 'Essence',
      'Exfoliant': 'Exfoliant',
      'Serum': 'Serum',
      'Ampoule': 'Ampoule',
      'Moisturizer': 'Moisturizer',
      'Sunscreen': 'Sunscreen',
      'Mask': 'Mask & Scrub',
    };

    // Group recs by step
    const grouped: Record<string, string[]> = {};
    kaymanRecs.forEach(key => {
      const step = kaymanProducts[key].step;
      if (!grouped[step]) grouped[step] = [];
      grouped[step].push(key);
    });

    // Render grouped
    let kaymanHTML = '';
    stepOrder.forEach(step => {
      if (!grouped[step] || grouped[step].length === 0) return;
      kaymanHTML += `<div class="kayman-group">
        <div class="kayman-group-label">${stepLabels[step] || step}</div>
        <div class="kayman-group-items">
          ${grouped[step].map(key => {
            const p = kaymanProducts[key];
            return `<a href="${p.url}" target="_blank" rel="noopener" class="kayman-card">
              <div class="kayman-img-wrap">
                <img src="${p.img}" alt="${p.name}" loading="lazy" />
              </div>
              <span class="kayman-name">${p.name}</span>
              <span class="kayman-shop">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Shop here
              </span>
            </a>`;
          }).join('')}
        </div>
      </div>`;
    });

    // === Yello Skincare products ===
    const yelloProducts: Record<string, { name: string; img: string; url: string; step: string }> = {
      oatmino: { name: 'Oatmino Refreshing Cream Cleanser', img: '/yello/oatmino.png', url: 'https://s.shopee.com.my/AACnuWtITk', step: 'Cleanser' },
      oatellia: { name: 'Oatellia Exfoliating Gel Cleanser', img: '/yello/oatellia.png', url: 'https://s.shopee.com.my/2g6myl8B2l', step: 'Cleanser' },
      cynara_essence: { name: 'Cynara Supple Plumping Essence', img: '/yello/cynara-essence.png', url: 'https://s.shopee.com.my/10yYziJCmj', step: 'Essence' },
      snowmeric: { name: 'Snowmeric Hydra-Boost Brightening Serum', img: '/yello/snowmeric.png', url: 'https://s.shopee.com.my/AUpeJBiQgq', step: 'Serum' },
      otms: { name: 'Oatmeal Turmeric Mask & Scrub', img: '/yello/otms.png', url: 'https://s.shopee.com.my/9Ux77MqREL', step: 'Mask' },
    };

    // === Cuura products ===
    const cuuraProducts: Record<string, { name: string; img: string; url: string; step: string }> = {
      cloud_lift: { name: 'Cloud Lift Hydration Spray', img: '/cuura/cloud-lift.png', url: 'https://s.shopee.com.my/10yZ1Zpwiz', step: 'Toner' },
      jeju_glow: { name: 'Jeju Glow Serum Infused Mist', img: '/cuura/jeju-glow.png', url: 'https://s.shopee.com.my/qf8pI3NMp', step: 'Essence' },
      vitamin_potion: { name: 'Vitamin Potion Brightening Serum', img: '/cuura/vitamin-potion.png', url: 'https://s.shopee.com.my/3fzKCNuf2p', step: 'Serum' },
      pure_beauty_oil: { name: 'Pure Beauty Oil Serum', img: '/cuura/pure-beauty-oil.png', url: 'https://s.shopee.com.my/4frrOBrw9h', step: 'Serum' },
      brightening_ss: { name: 'Brightening Sunscreen', img: '/cuura/brightening-sunscreen.png', url: 'https://s.shopee.com.my/3Vfu00SBLY', step: 'Sunscreen' },
      glow_defense: { name: 'Glow Defense Tone Up Sunscreen', img: '/cuura/glow-defense.png', url: 'https://s.shopee.com.my/W2IQVQ4Jk', step: 'Sunscreen' },
    };

    const cuuraRecs: string[] = [];
    const addedCuura = new Set<string>();
    function addCuura(key: string) { if (!addedCuura.has(key) && cuuraProducts[key]) { addedCuura.add(key); cuuraRecs.push(key); } }

    // Toner — all skin types
    addCuura('cloud_lift');

    // Essence — by concern
    if (concerns.some(c => ['dull', 'pigmentation'].includes(c))) {
      addCuura('jeju_glow');
    }

    // Serum — by concern
    if (concerns.some(c => ['dull', 'pigmentation', 'dryness'].includes(c))) {
      addCuura('vitamin_potion');
    }
    if (concerns.some(c => ['aging', 'dryness'].includes(c))) {
      addCuura('pure_beauty_oil');
    }

    // Sunscreen — by skin type
    if (skinType === 'oily' || skinType === 'combo') {
      addCuura('glow_defense');
    } else {
      addCuura('brightening_ss');
    }

    const yelloRecs: string[] = [];
    const addedYello = new Set<string>();
    function addYello(key: string) { if (!addedYello.has(key) && yelloProducts[key]) { addedYello.add(key); yelloRecs.push(key); } }

    // Cleanser — by skin type
    if (skinType === 'oily') { addYello('oatellia'); }
    else if (skinType === 'combo') { addYello('oatmino'); addYello('oatellia'); }
    else { addYello('oatmino'); }

    // Essence — by concern
    if (concerns.some(c => ['dryness', 'pigmentation', 'dull', 'sensitivity', 'aging'].includes(c))) {
      addYello('cynara_essence');
    }

    // Serum — by concern
    if (concerns.some(c => ['pigmentation', 'dull', 'dryness', 'aging'].includes(c))) {
      addYello('snowmeric');
    }

    // Mask — by concern (skip for dryness and sensitivity)
    if (concerns.some(c => ['acne', 'pores', 'whitehead', 'dull', 'pigmentation'].includes(c))) {
      addYello('otms');
    }

    // === Merge all products (Kayman + Yello + Cuura) into one grouped view ===
    const allProducts = { ...kaymanProducts, ...yelloProducts, ...cuuraProducts };
    const allRecs = [
      ...kaymanRecs.map(k => ({ key: k, source: 'kayman' as const })),
      ...yelloRecs.map(k => ({ key: k, source: 'yello' as const })),
      ...cuuraRecs.map(k => ({ key: k, source: 'cuura' as const })),
    ];

    // Group by step
    const allGrouped: Record<string, { key: string; source: string }[]> = {};
    allRecs.forEach(item => {
      const p = allProducts[item.key];
      if (!p) return;
      const step = p.step;
      if (!allGrouped[step]) allGrouped[step] = [];
      allGrouped[step].push(item);
    });

    const allStepOrder = ['1st Cleanser', 'Cleanser', 'Toner', 'Essence', 'Exfoliant', 'Serum', 'Ampoule', 'Moisturizer', 'Sunscreen', 'Mask'];

    let allHTML = '';
    allStepOrder.forEach(step => {
      if (!allGrouped[step] || allGrouped[step].length === 0) return;
      allHTML += `<div class="kayman-group">
        <div class="kayman-group-label">${stepLabels[step] || step}</div>
        <div class="kayman-group-items">
          ${allGrouped[step].map(item => {
            const p = allProducts[item.key];
            return `<a href="${p.url}" target="_blank" rel="noopener" class="kayman-card">
              <div class="kayman-img-wrap">
                <img src="${p.img}" alt="${p.name}" loading="lazy" />
              </div>
              <span class="kayman-name">${p.name}</span>
              <span class="kayman-shop">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Shop here
              </span>
            </a>`;
          }).join('')}
        </div>
      </div>`;
    });

    document.getElementById('allProductRecs')!.innerHTML = allHTML;

    // Blog product recommendations
    document.getElementById('productRecs')!.innerHTML = data.products.map(p =>
      `<a href="/posts/${p.slug}/" class="product-card">
        <span class="product-cat">${p.category}</span>
        <span class="product-name">${p.name}</span>
        <span class="product-link">Read review →</span>
      </a>`
    ).join('');

    // Combine skin type guides + concern-specific guides (deduplicated)
    const allGuides = [...data.guides];
    const slugSet = new Set(allGuides.map(g => g.slug));
    concerns.forEach(c => {
      (concernGuides[c] || []).forEach(g => {
        if (!slugSet.has(g.slug)) { allGuides.push(g); slugSet.add(g.slug); }
      });
    });
    if (isPregnant) {
      if (!slugSet.has('skincare-during-pregnant-breastfeeding')) {
        allGuides.unshift({ title: 'Skincare During Pregnant/Breastfeeding', slug: 'skincare-during-pregnant-breastfeeding' });
      }
    }

    document.getElementById('guideLinks')!.innerHTML = allGuides.map(g =>
      `<a href="/posts/${g.slug}/" class="guide-card">
        <span class="guide-title">${g.title}</span>
        <span class="guide-arrow">→</span>
      </a>`
    ).join('');

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  document.getElementById('retakeBtn')!.addEventListener('click', () => {
    skinType = '';
    concerns = [];
    isPregnant = null;
    document.getElementById('quizResults')!.style.display = 'none';
    document.getElementById('quizContainer')!.style.display = '';
    document.querySelectorAll('.quiz-opt').forEach(b => b.classList.remove('selected'));
    submitBtn.disabled = true;
    submitHint.style.display = '';
    document.getElementById('resultInserts')!.innerHTML = '';
    document.getElementById('extraSerums')!.innerHTML = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

