---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & Collaborate — Iman Abdul Rahim"
  description="Get in touch with Iman for brand collaborations, product reviews, sponsored posts, and general enquiries."
>
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
    </nav>
  </header>

  <main>
    <div class="page-hero">
      <div class="hero-inner">
        <p class="section-label">Let's Work Together</p>
        <h1 class="page-title">Get in Touch</h1>
        <p class="page-sub">Whether you're a brand, a reader, or just want to say hi — I'd love to hear from you.</p>
      </div>
      <div class="deco-a"></div>
    </div>

    <div class="contact-page">
      <div class="contact-grid">

        <!-- Collaboration types -->
        <div class="collab-types">
          <h2 class="section-heading">What I work on</h2>
          <div class="collab-list">
            <div class="collab-item">
              <span class="collab-icon">✦</span>
              <div>
                <h3 class="collab-title">Sponsored Posts</h3>
                <p class="collab-desc">In-depth blog posts featuring your product with honest, authentic reviews.</p>
              </div>
            </div>
            <div class="collab-item">
              <span class="collab-icon">◈</span>
              <div>
                <h3 class="collab-title">Product Reviews</h3>
                <p class="collab-desc">Detailed, unbiased reviews covering skincare, beauty, baby & lifestyle products.</p>
              </div>
            </div>
            <div class="collab-item">
              <span class="collab-icon">◇</span>
              <div>
                <h3 class="collab-title">Brand Mentions</h3>
                <p class="collab-desc">Social media shoutouts, Instagram stories, and feature inclusions in roundup posts.</p>
              </div>
            </div>
            <div class="collab-item">
              <span class="collab-icon">○</span>
              <div>
                <h3 class="collab-title">Giveaways</h3>
                <p class="collab-desc">Collaborative giveaways to grow your reach with my Malaysian audience.</p>
              </div>
            </div>
            <div class="collab-item">
              <span class="collab-icon">◎</span>
              <div>
                <h3 class="collab-title">Event Coverage</h3>
                <p class="collab-desc">Launch events, press days, and brand experiences — covered with warmth and honesty.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="form-wrap">
          <h2 class="section-heading">Send a message</h2>
          <p class="form-note">
            <!-- Replace YOUR_FORM_ID with your Formspree form ID from formspree.io -->
            Fill in the form below and I'll get back to you within 2–3 business days.
          </p>
          <form
            class="contact-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            id="contactForm"
          >
            <input type="hidden" name="_subject" value="New collaboration enquiry" />

            <div class="field">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" placeholder="Siti Nurhaliza" required />
            </div>

            <div class="field">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="hello@brand.com" required />
            </div>

            <div class="field">
              <label for="company">Brand / Company <span class="optional">(optional)</span></label>
              <input type="text" id="company" name="company" placeholder="Your brand name" />
            </div>

            <div class="field">
              <label for="type">Collaboration Type</label>
              <select id="type" name="type" required>
                <option value="" disabled selected>Select a type…</option>
                <option value="sponsored">Sponsored Post</option>
                <option value="review">Product Review</option>
                <option value="mention">Brand Mention</option>
                <option value="giveaway">Giveaway</option>
                <option value="event">Event Coverage</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell me about your brand, product, and what you have in mind…" required></textarea>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
              Send Message
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>

            <p class="form-success" id="formSuccess" style="display:none">
              Thank you! I'll be in touch soon. ✦
            </p>
          </form>
        </div>
      </div>

      <!-- Direct contact options -->
      <div class="direct-contact">
        <h2 class="section-heading">Or reach me directly</h2>
        <div class="direct-grid">
          <a href="mailto:iman.abdrahim@yahoo.com" class="direct-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <p class="direct-label">Email</p>
              <p class="direct-value">iman.abdrahim@yahoo.com</p>
            </div>
          </a>
          <a href="https://www.instagram.com/imanabdulrahim" target="_blank" rel="noopener" class="direct-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <div>
              <p class="direct-label">Instagram</p>
              <p class="direct-value">@imanabdulrahim</p>
            </div>
          </a>
          <a href="https://www.facebook.com/imanabdulrahimblog" target="_blank" rel="noopener" class="direct-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            <div>
              <p class="direct-label">Facebook</p>
              <p class="direct-value">imanabdulrahimblog</p>
            </div>
          </a>
          <a href="https://www.tiktok.com/@imanabdulrahim_" target="_blank" rel="noopener" class="direct-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.72a8.19 8.19 0 0 0 4.76 1.52V6.79a4.84 4.84 0 0 1-1-.1z"/></svg>
            <div>
              <p class="direct-label">TikTok</p>
              <p class="direct-value">@imanabdulrahim_</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </main>

  <footer class="page-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const success = document.getElementById('formSuccess');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;
    const original = btn.innerHTML;
    btn.innerHTML = 'Sending…';
    btn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        if (success) success.style.display = 'block';
        btn.style.display = 'none';
      } else {
        btn.innerHTML = original;
        btn.disabled = false;
      }
    } catch {
      btn.innerHTML = original;
      btn.disabled = false;
    }
  });
</script>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(254, 240, 243, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  [data-theme="dark"] .site-header {
    background: rgba(26, 15, 17, 0.92);
  }

  .site-header nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo { display: flex; align-items: baseline; gap: 2px; font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; text-decoration: none; }
  .logo-text { color: var(--text-primary); font-style: italic; font-weight: 500; }
  .logo-dot { color: var(--rose-gold); font-size: 1.6rem; line-height: 1; margin: 0 1px; }
  .logo-sub { color: var(--text-muted); font-weight: 300; font-size: 1rem; letter-spacing: 0.08em; font-family: 'DM Sans', sans-serif; }
  .back-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-secondary); text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: var(--text-primary); }

  .page-hero {
    padding: 8rem 2rem 4rem;
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .hero-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

  .section-label {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--rose-gold); margin-bottom: 0.8rem; font-weight: 500;
  }

  .page-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--text-primary);
    margin-bottom: 0.8rem;
  }

  .page-sub { font-size: 0.95rem; color: var(--text-secondary); font-weight: 300; }

  .deco-a {
    position: absolute; width: 280px; height: 280px; border-radius: 50%;
    background: radial-gradient(circle, var(--blush), transparent 70%);
    top: -40px; right: -60px; opacity: 0.5;
  }

  .contact-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  /* Collab types */
  .collab-list { display: flex; flex-direction: column; gap: 1.2rem; }

  .collab-item {
    display: flex;
    gap: 1rem;
    padding: 1.2rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .collab-item:hover {
    border-color: var(--rose);
    transform: translateX(4px);
  }

  .collab-icon {
    font-size: 1.1rem;
    color: var(--rose-gold);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .collab-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .collab-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
  }

  /* Form */
  .form-wrap { }

  .form-note {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-weight: 300;
    line-height: 1.6;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }

  .field label {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .optional { font-weight: 300; text-transform: none; color: var(--text-muted); }

  .field input,
  .field select,
  .field textarea {
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    background: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--rose-gold);
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--text-muted);
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.95rem 2rem;
    background: var(--text-primary);
    color: var(--cream);
    border: none;
    border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    align-self: flex-start;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--rose-gold);
    transform: translateY(-2px);
  }

  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-success {
    padding: 1rem 1.4rem;
    background: var(--petal);
    border: 1px solid var(--rose);
    border-radius: 12px;
    font-size: 0.9rem;
    color: var(--text-primary);
    text-align: center;
  }

  /* Direct contact */
  .direct-contact { }

  .direct-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .direct-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.4rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s;
  }

  .direct-card:hover {
    transform: translateY(-3px);
    border-color: var(--rose-gold);
  }

  .direct-card svg {
    color: var(--rose-gold);
    flex-shrink: 0;
  }

  .direct-label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
    font-weight: 500;
  }

  .direct-value {
    font-size: 0.88rem;
    color: var(--text-primary);
    font-weight: 400;
  }

  .page-footer {
    text-align: center;
    padding: 2rem;
    background: var(--footer-bg);
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    font-weight: 300;
  }

  .page-footer a { color: var(--rose); }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .direct-grid { grid-template-columns: 1fr; }
  }
</style>
