---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// ─── Edit these to update the page ───
const profile = {
  handle: '@imanabdulrahim',
  location: 'Kuala Lumpur, Malaysia',
  bio: 'Beauty, motherhood & quiet moments — a writer from Malaysia.',
  // Swap this for a real photo in /public/ e.g. '/me.jpg'
  photo: '/raya-34.jpeg',
};

const socials = [
  { label: 'Email',     href: 'mailto:iman.abdrahim@yahoo.com', icon: 'mail' },
  { label: 'Instagram', href: 'https://instagram.com/imanabdulrahim', icon: 'instagram' },
  { label: 'TikTok',    href: 'https://tiktok.com/@imanabdulrahim_', icon: 'tiktok' },
  { label: 'YouTube',   href: 'https://youtube.com/@imanabdulrahim', icon: 'youtube' },
  { label: 'X',         href: 'https://x.com/imanabdulrahim', icon: 'x' },
  { label: 'Facebook',  href: 'https://facebook.com/imanabdulrahim', icon: 'facebook' },
];

// Link cards, in display order. `thumb` is optional.
const links = [
  {
    title: 'Want to advertise your business?',
    sub: 'For local brands — Whatsapp for my rate card',
    href: 'https://wa.me/60000000000',
    featured: true,
  },
  {
    title: 'Sembang Kewangan with Iman',
    sub: 'Financial planning, honestly.',
    href: '#',
    thumb: '/raya-34.jpeg',
  },
  {
    title: 'Join my Telegram Channel',
    sub: 'Iman Ajak Shopping — deals, drops, codes.',
    href: 'https://t.me/imanabdulrahim',
  },
  {
    title: 'Shopee Storefront',
    sub: 'Everything I actually use & recommend.',
    href: 'https://shopee.com.my/imanabdulrahim',
  },
  // My own site links — so the landing page also feeds the blog
  {
    title: 'Read the Journal',
    sub: 'Notes on beauty, motherhood & everyday life.',
    href: '/posts/',
  },
  {
    title: 'Find Your Glow — skincare quiz',
    sub: 'Two minutes. A routine that\'s actually yours.',
    href: '/find-your-glow/',
    accent: true,
  },
  {
    title: 'Media Kit',
    sub: 'For collaborations & press.',
    href: '/media-kit/',
  },
];
---

<Layout
  title="Iman Abdul Rahim · Links"
  description="All my links in one place — the journal, the skincare quiz, socials, and current campaigns."
>
  <Header />

  <main class="links-main">
    <section class="links-wrap">
      <div class="links-card" id="linksCard">
        <!-- Aurora background -->
        <div class="lk-aurora">
          <div class="lk-a1"></div>
          <div class="lk-a2"></div>
          <div class="lk-a3"></div>
        </div>
        <div class="lk-grain"></div>

        <!-- Corner accents -->
        <div class="corner-accent corner-tl"></div>
        <div class="corner-accent corner-tr"></div>
        <div class="corner-accent corner-bl"></div>
        <div class="corner-accent corner-br"></div>

        <!-- Folio -->
        <div class="lk-folio">
          <span class="lk-folio-num">II</span>
          <span>·</span>
          <span>Hello</span>
        </div>

        <!-- Profile -->
        <div class="lk-profile reveal">
          <div class="lk-avatar-ring">
            <div class="lk-avatar">
              <img src={profile.photo} alt={profile.handle} loading="eager" />
            </div>
          </div>
          <h1 class="lk-handle">{profile.handle}</h1>
          <p class="lk-location">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {profile.location}
          </p>
          <p class="lk-bio">{profile.bio}</p>

          <!-- Social icons -->
          <div class="lk-socials">
            {socials.map((s) => (
              <a href={s.href} class="lk-social" aria-label={s.label} target="_blank" rel="noopener">
                {s.icon === 'mail' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                )}
                {s.icon === 'instagram' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                )}
                {s.icon === 'tiktok' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"/>
                  </svg>
                )}
                {s.icon === 'youtube' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                )}
                {s.icon === 'x' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {s.icon === 'facebook' && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>
        </div>

        <!-- Small label -->
        <div class="lk-label reveal">
          <span>— A personal index —</span>
        </div>

        <!-- Link cards -->
        <div class="lk-list stagger">
          {links.map((link) => (
            <a
              href={link.href}
              class={`lk-item ${link.featured ? 'is-featured' : ''} ${link.accent ? 'is-accent' : ''}`}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener' : undefined}
            >
              {link.thumb && (
                <div class="lk-thumb">
                  <img src={link.thumb} alt="" loading="lazy" />
                </div>
              )}
              {!link.thumb && link.accent && (
                <div class="lk-thumb lk-thumb-dot"><span class="lk-pulse"></span></div>
              )}
              <div class="lk-item-text">
                <span class="lk-item-title">{link.title}</span>
                <span class="lk-item-sub">{link.sub}</span>
              </div>
              <svg class="lk-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          ))}
        </div>

        <!-- Footer inside card -->
        <div class="lk-card-footer">
          <span class="lk-footer-meta">Served from Kuala Lumpur · Since 2015</span>
          <span class="lk-footer-meta">imanabdulrahim.com</span>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .links-main {
    background: var(--cream);
    min-height: 100vh;
  }

  .links-wrap {
    padding: 7rem 1.5rem 4rem;
    position: relative;
  }

  .links-card {
    max-width: 620px;
    margin: 0 auto;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    background: var(--ivory);
    box-shadow:
      0 40px 80px rgba(42, 26, 24, 0.12),
      0 0 0 1px rgba(42, 26, 24, 0.04);
  }

  /* ── Aurora ── */
  .lk-aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    filter: saturate(1.05);
  }
  .lk-a1, .lk-a2, .lk-a3 {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }
  .lk-a1 {
    width: 80%; height: 60%;
    background: radial-gradient(circle, var(--blush) 0%, transparent 60%);
    top: -15%; left: -10%;
    animation: lkFloat1 22s ease-in-out infinite;
    opacity: 0.9;
  }
  .lk-a2 {
    width: 70%; height: 50%;
    background: radial-gradient(circle, var(--peach) 0%, transparent 60%);
    top: 30%; right: -15%;
    animation: lkFloat2 26s ease-in-out infinite;
    opacity: 0.7;
  }
  .lk-a3 {
    width: 60%; height: 50%;
    background: radial-gradient(circle, var(--petal) 0%, transparent 60%);
    bottom: -15%; left: 15%;
    animation: lkFloat1 20s ease-in-out infinite reverse;
    opacity: 0.75;
  }
  @keyframes lkFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -20px) scale(1.1); }
  }
  @keyframes lkFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, 30px) scale(1.12); }
  }

  .lk-grain {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0.1 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.5;
    pointer-events: none;
  }

  /* ── Corners ── */
  .corner-accent {
    position: absolute;
    width: 18px;
    height: 18px;
    z-index: 3;
    opacity: 0.45;
  }
  .corner-accent::before, .corner-accent::after {
    content: '';
    position: absolute;
    background: var(--ink);
  }
  .corner-accent::before { width: 100%; height: 1px; }
  .corner-accent::after { width: 1px; height: 100%; }
  .corner-tl { top: 1rem; left: 1rem; }
  .corner-tl::before, .corner-tl::after { top: 0; left: 0; }
  .corner-tr { top: 1rem; right: 1rem; }
  .corner-tr::before, .corner-tr::after { top: 0; right: 0; }
  .corner-bl { bottom: 1rem; left: 1rem; }
  .corner-bl::before, .corner-bl::after { bottom: 0; left: 0; }
  .corner-br { bottom: 1rem; right: 1rem; }
  .corner-br::before, .corner-br::after { bottom: 0; right: 0; }

  /* ── Folio ── */
  .lk-folio {
    position: absolute;
    top: 1.5rem;
    right: 1.8rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    z-index: 3;
    opacity: 0.7;
  }
  .lk-folio-num { color: var(--rose-gold); }

  /* ── Profile ── */
  .lk-profile {
    position: relative;
    z-index: 2;
    padding: 3.5rem 2rem 1.5rem;
    text-align: center;
  }

  .lk-avatar-ring {
    width: 136px;
    height: 136px;
    margin: 0 auto 1.4rem;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, var(--rose-gold), var(--blush), var(--peach));
    box-shadow: 0 14px 30px rgba(192, 136, 120, 0.25);
  }
  .lk-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: var(--cream);
    position: relative;
  }
  .lk-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lk-handle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.8rem, 5vw, 2.4rem);
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .lk-location {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    margin: 0.7rem 0 0.8rem;
  }
  .lk-location svg { color: var(--rose-gold); }

  .lk-bio {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.02rem;
    color: var(--ink);
    max-width: 380px;
    margin: 0 auto 1.6rem;
    line-height: 1.5;
  }

  /* Social icons row */
  .lk-socials {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .lk-social {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--border);
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
  }
  .lk-social:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
    transform: translateY(-2px);
  }

  /* ── Label ── */
  .lk-label {
    position: relative;
    z-index: 2;
    text-align: center;
    margin: 1rem 0 1.2rem;
  }
  .lk-label span {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.92rem;
    color: var(--rose-gold);
    letter-spacing: 0.04em;
  }

  /* ── Link list ── */
  .lk-list {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0 1.6rem;
  }

  .lk-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem 1.1rem;
    background: rgba(253, 246, 240, 0.65);
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--ink);
    text-decoration: none;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .lk-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--blush) 0%, var(--peach) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }
  .lk-item:hover {
    transform: translateY(-2px);
    border-color: var(--rose-gold);
    box-shadow: 0 14px 28px rgba(192, 136, 120, 0.18);
  }
  .lk-item:hover::before { opacity: 0.25; }
  .lk-item:hover .lk-arrow { transform: translateX(4px); color: var(--rose-gold); }

  .lk-item.is-featured {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--cream);
  }
  .lk-item.is-featured:hover {
    background: var(--plum);
    border-color: var(--plum);
    box-shadow: 0 14px 28px rgba(90, 32, 48, 0.25);
  }
  .lk-item.is-featured:hover::before { opacity: 0; }
  .lk-item.is-featured .lk-item-sub { color: rgba(253, 246, 240, 0.7); }

  .lk-item.is-accent {
    border-color: var(--rose-gold);
    background: linear-gradient(135deg, rgba(245, 200, 206, 0.2), rgba(245, 200, 176, 0.2));
  }

  .lk-thumb {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--cream);
    border: 1px solid var(--border);
  }
  .lk-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lk-thumb-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(192, 136, 120, 0.12);
    border-color: var(--rose-gold);
  }
  .lk-pulse {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--rose-gold);
    animation: lkPulse 2s ease-in-out infinite;
  }
  @keyframes lkPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(0.7); opacity: 0.5; }
  }

  .lk-item-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .lk-item-title {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    line-height: 1.3;
  }
  .lk-item-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.92rem;
    color: var(--ink-soft);
    line-height: 1.3;
  }

  .lk-arrow {
    flex-shrink: 0;
    color: var(--ink-soft);
    transition: transform 0.3s, color 0.3s;
  }

  /* ── Card footer ── */
  .lk-card-footer {
    position: relative;
    z-index: 2;
    margin: 2rem 1.6rem 0;
    padding: 1.2rem 0 1.6rem;
    border-top: 1px solid var(--border-soft);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .lk-footer-meta {
    font-size: 0.56rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  /* ── Dark mode ── */
  :global([data-theme="dark"]) .links-card {
    background: #1f1814;
  }
  :global([data-theme="dark"]) .lk-a1 {
    background: radial-gradient(circle, rgba(224, 168, 144, 0.32) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .lk-a2 {
    background: radial-gradient(circle, rgba(240, 168, 184, 0.28) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .lk-a3 {
    background: radial-gradient(circle, rgba(224, 168, 144, 0.25) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .lk-grain {
    mix-blend-mode: overlay;
    opacity: 0.3;
  }
  :global([data-theme="dark"]) .lk-item {
    background: rgba(255, 255, 255, 0.04);
  }
  :global([data-theme="dark"]) .lk-item.is-featured {
    background: var(--rose-gold);
    border-color: var(--rose-gold);
    color: #1f1814;
  }
  :global([data-theme="dark"]) .lk-item.is-featured .lk-item-sub {
    color: rgba(31, 24, 20, 0.7);
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .links-wrap { padding: 6rem 1rem 3rem; }
    .links-card { border-radius: 18px; }
    .lk-folio { top: 1rem; right: 1rem; font-size: 0.65rem; }
    .corner-accent { width: 14px; height: 14px; }
    .corner-tl { top: 0.8rem; left: 0.8rem; }
    .corner-tr { top: 0.8rem; right: 0.8rem; }
    .corner-bl { bottom: 0.8rem; left: 0.8rem; }
    .corner-br { bottom: 0.8rem; right: 0.8rem; }
    .lk-profile { padding: 3rem 1.2rem 1rem; }
    .lk-avatar-ring { width: 112px; height: 112px; }
    .lk-list { padding: 0 1rem; }
    .lk-card-footer { margin: 1.5rem 1rem 0; }
    .lk-item { padding: 0.85rem 0.9rem; gap: 0.8rem; }
    .lk-thumb { width: 40px; height: 40px; }
    .lk-item-title { font-size: 0.64rem; letter-spacing: 0.18em; }
    .lk-item-sub { font-size: 0.85rem; }
    .lk-card-footer { flex-direction: column; align-items: center; text-align: center; }
  }
</style>

<script>
  // Small cursor-aware tilt on avatar (subtle)
  const card = document.getElementById('linksCard');
  const avatar = card?.querySelector('.lk-avatar-ring') as HTMLElement | null;
  if (card && avatar) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      avatar.style.transform = `translate(${x * 6}px, ${y * 6}px)`;
    });
    card.addEventListener('mouseleave', () => {
      avatar.style.transform = 'translate(0, 0)';
    });
  }
</script>
