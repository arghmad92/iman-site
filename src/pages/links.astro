---
import Layout from '../layouts/Layout.astro';

// ─── Profile ───
const profile = {
  handle: '@imanabdulrahim',
  location: 'Kuala Lumpur, Malaysia',
  bio: 'Beauty, motherhood & quiet moments.',
  photo: '/raya-34.jpeg',
};

// ─── Socials ───
const email = 'iman.abdrahim@yahoo.com';
const socials = [
  { label: 'Instagram', href: 'https://instagram.com/imanabdulrahim', icon: 'instagram' },
  { label: 'TikTok',    href: 'https://tiktok.com/@imanabdulrahim_', icon: 'tiktok' },
  { label: 'YouTube',   href: 'https://www.youtube.com/channel/UClA-ICSNw8EmCAXZ5cUtO3w/about', icon: 'youtube' },
  { label: 'X',         href: 'https://x.com/imanabdulrahim', icon: 'x' },
  { label: 'Facebook',  href: 'https://www.facebook.com/imanabdulrahimblog/', icon: 'facebook' },
];

// ─── Link rows ───
const links = [
  {
    title: 'Advertise your business',
    sub: 'For local brands — WhatsApp for my rate card',
    href: 'https://wa.me/60182669436',
  },
  {
    title: 'Sembang Kewangan with Iman',
    sub: 'Financial planning',
    href: '#',
  },
  {
    title: 'Iman Ajak Shopping',
    sub: 'Telegram channel — deals, drops, codes',
    href: 'https://t.me/imanajakshopping',
  },
  {
    title: 'Shopee Storefront',
    sub: 'What I use & recommend',
    href: 'https://collshp.com/imanabdulrahim?view=storefront',
  },
  {
    title: 'Read the Journal',
    sub: 'Beauty · Motherhood · Lifestyle',
    href: '/posts/',
  },
  {
    title: 'Find Your Glow',
    sub: 'A 2-minute skincare quiz',
    href: '/find-your-glow/',
  },
];
---

<Layout
  title="Iman Abdul Rahim · Links"
  description="All my links in one place."
>
  <main class="links-page">
    <div class="col">
      <!-- Profile -->
      <div class="profile">
        <div class="avatar">
          <img src={profile.photo} alt={profile.handle} loading="eager" />
        </div>
        <h1 class="handle">{profile.handle}</h1>
        <p class="location">{profile.location}</p>
        <p class="bio">{profile.bio}</p>

        <a class="email" href={`mailto:${email}`}>{email}</a>

        <div class="socials">
          {socials.map((s) => (
            <a href={s.href} class="social" aria-label={s.label} target="_blank" rel="noopener">
              {s.icon === 'instagram' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              )}
              {s.icon === 'tiktok' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"/>
                </svg>
              )}
              {s.icon === 'youtube' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {s.icon === 'x' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === 'facebook' && (
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Links list -->
      <nav class="rows">
        {links.map((link) => (
          <a
            href={link.href}
            class="row"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener' : undefined}
          >
            <span class="row-text">
              <span class="row-title">{link.title}</span>
              {link.sub && <span class="row-sub">{link.sub}</span>}
            </span>
            <svg class="row-arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        ))}
      </nav>

      <footer class="page-footer">
        <a href="/" class="footer-link">imanabdulrahim.com</a>
      </footer>
    </div>
  </main>
</Layout>

<style>
  .links-page {
    min-height: 100vh;
    background: var(--cream);
    padding: 4rem 1.5rem 3rem;
    display: flex;
    justify-content: center;
  }

  .col {
    width: 100%;
    max-width: 420px;
  }

  /* ── Profile ── */
  .profile {
    text-align: center;
    margin-bottom: 3rem;
  }

  .avatar {
    width: 88px;
    height: 88px;
    margin: 0 auto 1.4rem;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .handle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--ink);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .location {
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    margin: 0 0 1.2rem;
  }

  .bio {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 auto 1.8rem;
    max-width: 300px;
  }

  /* ── Email ── */
  .email {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 1.4rem;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--border);
    transition: color 0.3s, border-color 0.3s;
  }
  .email:hover {
    color: var(--rose-gold);
    border-color: var(--rose-gold);
  }

  /* ── Socials ── */
  .socials {
    display: flex;
    justify-content: center;
    gap: 1.4rem;
  }
  .social {
    color: var(--ink-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    transition: color 0.3s, transform 0.3s;
  }
  .social:hover {
    color: var(--rose-gold);
    transform: translateY(-1px);
  }

  /* ── Rows ── */
  .rows {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.3rem 0.2rem;
    border-bottom: 1px solid var(--border);
    color: var(--ink);
    text-decoration: none;
    transition: padding 0.4s cubic-bezier(.22,1,.36,1), color 0.3s;
  }

  .row-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .row-title {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 1.3;
    transition: color 0.3s;
  }

  .row-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.3;
  }

  .row-arrow {
    color: var(--muted);
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(.22,1,.36,1), color 0.3s;
  }

  .row:hover { padding-left: 0.7rem; }
  .row:hover .row-title { color: var(--rose-gold); }
  .row:hover .row-arrow { color: var(--rose-gold); transform: translateX(4px); }

  /* ── Footer ── */
  .page-footer {
    margin-top: 3rem;
    text-align: center;
  }
  .footer-link {
    font-size: 0.58rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    transition: color 0.3s;
  }
  .footer-link:hover { color: var(--rose-gold); }

  /* ── Dark mode ── */
  :global([data-theme="dark"]) .links-page {
    background: var(--cream);
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .links-page { padding: 3rem 1.2rem 2rem; }
    .avatar { width: 76px; height: 76px; }
    .handle { font-size: 1.35rem; }
    .row { padding: 1.15rem 0.2rem; }
    .row-title { font-size: 0.64rem; letter-spacing: 0.2em; }
    .row-sub { font-size: 0.86rem; }
  }
</style>
