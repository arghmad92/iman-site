---
import Layout from '../layouts/Layout.astro';

// ─── Profile ───
const profile = {
  handle: '@imanabdulrahim',
  location: 'Malaysia',
  bio: 'Beauty, motherhood & quiet moments.',
  photo: '/raya-34.jpeg', // swap for a portrait in /public/
};

// ─── Social icons ───
const socials = [
  { label: 'Email',     href: 'mailto:iman.abdrahim@yahoo.com',  icon: 'mail' },
  { label: 'Instagram', href: 'https://instagram.com/imanabdulrahim', icon: 'instagram' },
  { label: 'TikTok',    href: 'https://tiktok.com/@imanabdulrahim_',  icon: 'tiktok' },
  { label: 'YouTube',   href: 'https://youtube.com/@imanabdulrahim',  icon: 'youtube' },
  { label: 'X',         href: 'https://x.com/imanabdulrahim',         icon: 'x' },
  { label: 'Facebook',  href: 'https://facebook.com/imanabdulrahim',  icon: 'facebook' },
];

// ─── Link pills ───
const links = [
  {
    title: 'Want to advertise your business?',
    sub: 'For local brands — WhatsApp for my rate card',
    href: 'https://wa.me/60000000000',
  },
  {
    title: 'Sembang Kewangan with Iman',
    sub: 'Financial planning',
    href: '#',
    thumb: '/raya-34.jpeg',
  },
  {
    title: 'Join my Telegram channel',
    sub: '✨ Iman Ajak Shopping ✨',
    href: 'https://t.me/imanabdulrahim',
  },
  {
    title: 'Shopee Storefront ✨',
    sub: null,
    href: 'https://shopee.com.my/imanabdulrahim',
  },
  // Funnels to the blog
  {
    title: 'Read the Journal',
    sub: 'Beauty · Motherhood · Lifestyle',
    href: '/posts/',
  },
  {
    title: 'Find Your Glow',
    sub: 'A 2-minute skincare quiz ✨',
    href: '/find-your-glow/',
  },
];
---

<Layout
  title="Iman Abdul Rahim · Links"
  description="All my links in one place — the journal, the skincare quiz, socials, and more."
>
  <main class="links-page">
    <!-- Soft background pattern -->
    <div class="bg-pattern" aria-hidden="true">
      <span class="star s1">✦</span>
      <span class="star s2">✦</span>
      <span class="star s3">✦</span>
      <span class="star s4">✦</span>
      <span class="star s5">✦</span>
      <span class="star s6">✦</span>
      <span class="star s7">✧</span>
      <span class="star s8">✧</span>
      <span class="moon m1">☾</span>
      <span class="moon m2">☾</span>
      <span class="moon m3">☾</span>
    </div>

    <div class="links-inner">
      <!-- Profile -->
      <div class="profile">
        <div class="avatar-ring">
          <div class="avatar">
            <img src={profile.photo} alt={profile.handle} loading="eager" />
          </div>
        </div>
        <h1 class="handle">{profile.handle}</h1>
        <p class="location">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {profile.location}
        </p>
        <p class="bio">{profile.bio}</p>

        <!-- Socials -->
        <div class="socials">
          {socials.map((s) => (
            <a href={s.href} class="social" aria-label={s.label} target="_blank" rel="noopener">
              {s.icon === 'mail' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              )}
              {s.icon === 'instagram' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              )}
              {s.icon === 'tiktok' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"/>
                </svg>
              )}
              {s.icon === 'youtube' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              )}
              {s.icon === 'x' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {s.icon === 'facebook' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Link pills -->
      <div class="pills">
        {links.map((link) => (
          <a
            href={link.href}
            class={`pill ${link.thumb ? 'has-thumb' : ''}`}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener' : undefined}
          >
            {link.thumb && (
              <div class="pill-thumb">
                <img src={link.thumb} alt="" loading="lazy" />
              </div>
            )}
            <div class="pill-text">
              <span class="pill-title">{link.title}</span>
              {link.sub && <span class="pill-sub">{link.sub}</span>}
            </div>
          </a>
        ))}
      </div>

      <!-- Tiny footer -->
      <div class="page-footer">
        <a href="/" class="footer-link">imanabdulrahim.com</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* ─── Page background ─── */
  .links-page {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at top, #ffe5e8 0%, transparent 55%),
      radial-gradient(ellipse at bottom, #fde8df 0%, transparent 50%),
      linear-gradient(180deg, #fde5e8 0%, #fce0e5 50%, #fde8df 100%);
    position: relative;
    padding: 3rem 1.5rem 2rem;
    overflow: hidden;
  }

  /* ─── Scattered stars + moons ─── */
  .bg-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .star, .moon {
    position: absolute;
    color: rgba(255, 255, 255, 0.75);
    font-family: serif;
    user-select: none;
    line-height: 1;
  }
  .star { font-size: 2rem; }
  .moon { font-size: 2.4rem; color: rgba(255, 255, 255, 0.55); }

  .s1 { top: 6%;  left: 8%;   font-size: 2.4rem; animation: twinkle 4s ease-in-out infinite; }
  .s2 { top: 14%; right: 10%; font-size: 1.8rem; animation: twinkle 5s ease-in-out infinite 0.5s; }
  .s3 { top: 38%; left: 4%;   font-size: 1.4rem; animation: twinkle 6s ease-in-out infinite 1s; }
  .s4 { top: 50%; right: 6%;  font-size: 2.2rem; animation: twinkle 4.5s ease-in-out infinite 1.5s; }
  .s5 { bottom: 20%; left: 12%; font-size: 1.6rem; animation: twinkle 5.5s ease-in-out infinite 0.8s; }
  .s6 { bottom: 8%; right: 14%; font-size: 2rem;   animation: twinkle 4.8s ease-in-out infinite 2s; }
  .s7 { top: 72%; left: 40%;  font-size: 1.2rem; color: rgba(255,255,255,0.5); animation: twinkle 7s ease-in-out infinite; }
  .s8 { top: 24%; left: 50%;  font-size: 1.1rem; color: rgba(255,255,255,0.5); animation: twinkle 6.5s ease-in-out infinite 1.2s; }

  .m1 { top: 22%; left: 18%; animation: floaty 9s ease-in-out infinite; }
  .m2 { top: 55%; right: 16%; font-size: 1.8rem; animation: floaty 11s ease-in-out infinite 2s; }
  .m3 { bottom: 14%; left: 40%; font-size: 1.4rem; color: rgba(255,255,255,0.45); animation: floaty 10s ease-in-out infinite 1s; }

  @keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.85; transform: scale(1.2); }
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-14px) rotate(5deg); }
  }

  /* ─── Main column ─── */
  .links-inner {
    position: relative;
    z-index: 2;
    max-width: 520px;
    margin: 0 auto;
    padding: 2.5rem 0 3rem;
  }

  /* ─── Profile ─── */
  .profile {
    text-align: center;
    margin-bottom: 2.4rem;
  }

  .avatar-ring {
    width: 132px;
    height: 132px;
    margin: 0 auto 1.4rem;
    border-radius: 50%;
    padding: 4px;
    background: linear-gradient(135deg, #f5b8c4, #fbd4d2, #fac8b8);
    box-shadow: 0 10px 30px rgba(228, 145, 160, 0.3);
    transition: transform 0.6s cubic-bezier(.22,1,.36,1);
  }
  .avatar-ring:hover { transform: scale(1.04); }

  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: #fff;
  }
  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .handle {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: clamp(1.6rem, 5vw, 2rem);
    color: #3a1e22;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .location {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: #6e4044;
    font-weight: 500;
    margin: 0 0 0.8rem;
  }
  .location svg { color: #c46676; }

  .bio {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: #5e3036;
    max-width: 320px;
    margin: 0 auto 1.6rem;
    line-height: 1.5;
  }

  /* ─── Socials ─── */
  .socials {
    display: flex;
    justify-content: center;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  .social {
    color: #3a1e22;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    transition: all 0.3s;
  }
  .social:hover {
    color: #c46676;
    transform: translateY(-2px) scale(1.1);
  }

  /* ─── Pill buttons ─── */
  .pills {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1.15rem 1.6rem;
    background: #f5b5bf;
    color: #fff;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(228, 145, 160, 0.25);
  }
  .pill::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #f5a8b6 0%, #f0a5ba 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .pill:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(228, 145, 160, 0.35);
  }
  .pill:hover::before { opacity: 1; }

  .pill.has-thumb {
    padding-left: 0.5rem;
  }

  .pill-thumb {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #fff;
    border: 2px solid rgba(255, 255, 255, 0.8);
    position: relative;
    z-index: 1;
  }
  .pill-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pill-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .pill.has-thumb .pill-text { text-align: left; }

  .pill-title {
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.3;
    color: #fff;
  }
  .pill-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.3;
  }

  /* ─── Footer ─── */
  .page-footer {
    text-align: center;
    margin-top: 3rem;
  }
  .footer-link {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: #8e5560;
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-link:hover { color: #c46676; }

  /* ─── Dark mode ─── */
  :global([data-theme="dark"]) .links-page {
    background:
      radial-gradient(ellipse at top, rgba(140, 72, 80, 0.35) 0%, transparent 55%),
      radial-gradient(ellipse at bottom, rgba(140, 80, 64, 0.3) 0%, transparent 50%),
      linear-gradient(180deg, #1a0e10 0%, #170c10 50%, #1a100c 100%);
  }
  :global([data-theme="dark"]) .star,
  :global([data-theme="dark"]) .moon {
    color: rgba(240, 200, 208, 0.35);
  }
  :global([data-theme="dark"]) .handle { color: #fbe0e0; }
  :global([data-theme="dark"]) .location { color: #d4a8b0; }
  :global([data-theme="dark"]) .location svg { color: #e8a4b0; }
  :global([data-theme="dark"]) .bio { color: #d4a8b0; }
  :global([data-theme="dark"]) .social { color: #fbe0e0; }
  :global([data-theme="dark"]) .social:hover { color: #f0a8b8; }
  :global([data-theme="dark"]) .footer-link { color: #c49098; }
  :global([data-theme="dark"]) .footer-link:hover { color: #f0a8b8; }

  /* ─── Mobile ─── */
  @media (max-width: 540px) {
    .links-page { padding: 2rem 1rem 1.5rem; }
    .links-inner { padding: 1rem 0 2rem; }
    .avatar-ring { width: 110px; height: 110px; }
    .handle { font-size: 1.5rem; }
    .bio { font-size: 0.95rem; }
    .socials { gap: 1rem; }
    .pill { padding: 1rem 1.3rem; gap: 0.7rem; }
    .pill.has-thumb { padding-left: 0.45rem; }
    .pill-thumb { width: 44px; height: 44px; }
    .pill-title { font-size: 0.8rem; }
    .pill-sub { font-size: 0.8rem; }

    /* Tone down the decorations on mobile so they don't overwhelm */
    .star { font-size: 1.4rem !important; }
    .moon { font-size: 1.6rem !important; }
    .s7, .s8 { display: none; }
  }
</style>
