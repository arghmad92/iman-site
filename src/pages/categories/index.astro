---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../../data/archive';
import type { Category } from '../../data/archive';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allPosts = blogPosts.map((p) => ({
  title: p.data.title,
  date: p.data.date,
  url: p.data.externalUrl || `/posts/${p.slug}/`,
  category: p.data.category as Category,
  isLocal: !p.data.externalUrl,
}));

const counts = categories.reduce((acc, c) => {
  acc[c] = allPosts.filter((p) => p.category === c).length;
  return acc;
}, {} as Record<Category, number>);

const categoryMeta: Record<Category, { desc: string; color: string; icon: string }> = {
  Skincare: {
    desc: 'SPF, cleansers, toners, serums, moisturisers, AHA/BHA, ingredients guides and routines.',
    color: 'var(--blush)',
    icon: '✦',
  },
  Beauty: {
    desc: 'Makeup reviews, lipstick swatches, foundations, concealers, eyeshadow palettes and tools.',
    color: 'var(--gold-light)',
    icon: '◈',
  },
  Motherhood: {
    desc: 'Pregnancy journeys, breastfeeding tips, newborn checklists, pantang, nursing essentials.',
    color: 'var(--petal)',
    icon: '◇',
  },
  Parenting: {
    desc: "Baby food, toddler milestones, Maysaa's adventures, toys, diapers and baby gear reviews.",
    color: 'var(--petal)',
    icon: '○',
  },
  Lifestyle: {
    desc: 'Travel diaries (Japan, Korea, Bali), food finds, recipes, home organisation and daily life.',
    color: 'var(--blush)',
    icon: '◎',
  },
};

// Latest post per category
function latestPost(cat: Category) {
  return allPosts.find((p) => p.category === cat);
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title="Categories — Iman Abdul Rahim" description="Browse posts by category">
  <header class="site-header">
    <nav>
      <a href="/" class="logo">
        <span class="logo-text">iman</span>
        <span class="logo-dot">·</span>
        <span class="logo-sub">blog</span>
      </a>
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Home
      </a>
    </nav>
  </header>

  <main>
    <div class="page-hero">
      <div class="hero-inner">
        <p class="section-label">Explore</p>
        <h1 class="page-title">Categories</h1>
        <p class="page-sub">Find posts by topic — from skincare science to motherhood stories.</p>
      </div>
      <div class="deco-a"></div>
    </div>

    <div class="cats-page">
      <div class="cats-grid">
        {categories.map((cat) => {
          const meta = categoryMeta[cat];
          const latest = latestPost(cat);
          return (
            <a href={`/posts/?cat=${cat}`} class="cat-card" style={`--card-color: ${meta.color}`}>
              <div class="cat-top">
                <span class="cat-icon">{meta.icon}</span>
                <span class="cat-count">{counts[cat]} posts</span>
              </div>
              <h2 class="cat-name">{cat}</h2>
              <p class="cat-desc">{meta.desc}</p>
              {latest && (
                <div class="cat-latest">
                  <span class="latest-label">Latest</span>
                  <span class="latest-title">{latest.title}</span>
                  <span class="latest-date">{formatDate(latest.date)}</span>
                </div>
              )}
              <div class="cat-cta">
                Browse {cat}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </div>
            </a>
          );
        })}
      </div>

      <div class="all-link-wrap">
        <a href="/posts/" class="btn-all">
          View All {allPosts.length} Posts
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </div>
  </main>

  <footer class="page-footer">
    <p>&copy; {new Date().getFullYear()} Iman Abdul Rahim &mdash; <a href="/">Back to home</a></p>
  </footer>
</Layout>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(254, 240, 243, 0.9);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  :global([data-theme="dark"]) .site-header {
    background: rgba(26, 15, 17, 0.95);
  }

  :global([data-theme="dark"]) .logo-text {
    color: #f0dce0;
  }

  :global([data-theme="dark"]) .logo-sub {
    color: #8a5a63;
  }

  .site-header nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo { display: flex; align-items: baseline; gap: 2px; font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; text-decoration: none; }
  .logo-text { color: var(--text-primary); font-style: italic; font-weight: 500; }
  .logo-dot { color: var(--rose-gold); font-size: 1.6rem; line-height: 1; margin: 0 1px; }
  .logo-sub { color: var(--text-muted); font-weight: 300; font-size: 1rem; letter-spacing: 0.08em; font-family: 'DM Sans', sans-serif; }

  .back-link { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-secondary); text-decoration: none; transition: color 0.2s; }
  .back-link:hover { color: var(--text-primary); }

  .page-hero {
    padding: 8rem 2rem 4rem;
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .hero-inner { max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

  .section-label { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--rose-gold); margin-bottom: 0.8rem; font-weight: 500; }

  .page-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem, 6vw, 4rem); color: var(--text-primary); margin-bottom: 0.8rem; }

  .page-sub { font-size: 0.95rem; color: var(--text-secondary); font-weight: 300; }

  .deco-a { position: absolute; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle, var(--blush), transparent 70%); top: -40px; right: -60px; opacity: 0.5; }

  .cats-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }

  .cats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 2rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 24px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .cat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--card-color);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .cat-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(180, 90, 110, 0.1);
  }

  .cat-card:hover::before { opacity: 1; }

  .cat-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cat-icon { font-size: 1.3rem; color: var(--text-muted); }

  .cat-count {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--cream);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  .cat-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .cat-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.75;
    font-weight: 300;
    flex-grow: 1;
  }

  .cat-latest {
    background: var(--cream);
    border-radius: 12px;
    padding: 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .latest-label {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 500;
  }

  .latest-title {
    font-size: 0.83rem;
    color: var(--text-primary);
    line-height: 1.4;
    font-weight: 400;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .latest-date {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .cat-cta {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--rose-gold);
    letter-spacing: 0.03em;
    margin-top: 0.3rem;
  }

  .all-link-wrap { text-align: center; }

  .btn-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2.5rem;
    border: 1.5px solid var(--text-primary);
    border-radius: 100px;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--text-primary);
    text-decoration: none;
    transition: background 0.25s, color 0.25s, transform 0.2s;
  }

  .btn-all:hover {
    background: var(--text-primary);
    color: var(--cream);
    transform: translateY(-2px);
  }

  .page-footer {
    text-align: center;
    padding: 2rem;
    background: var(--footer-bg);
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    font-weight: 300;
  }

  .page-footer a { color: var(--rose); }

  @media (max-width: 860px) {
    .cats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .cats-grid { grid-template-columns: 1fr; }
    .cats-page { padding: 2rem 1.2rem 4rem; }
    .cat-card { padding: 1.5rem; }
    .page-hero { padding: 7rem 1.2rem 3rem; }
    .page-title { font-size: 2.2rem; }
    .cat-name { font-size: 1.3rem; }
    .latest-title { font-size: 0.78rem; }
    .btn-all { padding: 0.8rem 1.8rem; font-size: 0.8rem; }
    .deco-a { display: none; }
  }
</style>
