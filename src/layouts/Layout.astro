---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Beauty, parenting & lifestyle blog by Iman Abdul Rahim',
  image,
} = Astro.props;

const siteUrl = 'https://imanabdulrahim.com';
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image}`)
  : `${siteUrl}/og-default.jpg`;
const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-adsense-account" content="ca-pub-7812175461158939">
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Iman Abdul Rahim" />
    <meta property="og:locale" content="en_MY" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@imanabdulrahim" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Iman Abdul Rahim" href="/rss.xml" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Iman Abdul Rahim",
        "url": siteUrl,
        "description": "Beauty, parenting & lifestyle blog by Iman Abdul Rahim"
      })} />
    )}

    <!-- Dark mode: apply before render to prevent flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- Back to top button -->
    <button class="back-to-top" id="backToTop" aria-label="Back to top">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>
  </body>
</html>

<style is:global>
  :root {
    --cream: #fef0f3;
    --blush: #fad4dc;
    --petal: #fde8ec;
    --rose: #e8a0ad;
    --rose-gold: #c9848c;
    --gold: #c9a07a;
    --gold-light: #f0dbc8;
    --deep-rose: #b5616e;
    --text-primary: #4a2830;
    --text-secondary: #9e6b74;
    --text-muted: #c4979e;
    --border: #f5d5da;
    --white: #ffffff;
  }

  [data-theme="dark"] {
    --cream: #1a0f11;
    --blush: #2e1519;
    --petal: #261217;
    --rose: #7a3d47;
    --rose-gold: #d4919a;
    --gold: #c9a07a;
    --gold-light: #2a1e14;
    --deep-rose: #e88090;
    --text-primary: #f0dce0;
    --text-secondary: #c4979e;
    --text-muted: #8a5a63;
    --border: #3d2028;
    --white: #21151a;
    --footer-bg: #14090b;
    --footer-text: #f0dce0;
  }

  :root {
    --footer-bg: #4a2830;
    --footer-text: #fef0f3;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background-color: var(--cream);
    color: var(--text-primary);
    line-height: 1.7;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    transition: background-color 0.3s, color 0.3s;
    position: relative;
  }

  body::before,
  body::after {
    content: '';
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  body::before {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(250, 212, 220, 0.35) 0%, transparent 70%);
    top: 10%;
    left: -150px;
    animation: floatOrb1 18s ease-in-out infinite;
  }

  body::after {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(201, 160, 122, 0.2) 0%, transparent 70%);
    bottom: 15%;
    right: -120px;
    animation: floatOrb2 22s ease-in-out infinite;
  }

  @keyframes floatOrb1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, 30px); }
  }

  @keyframes floatOrb2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-30px, -40px); }
  }

  .glass {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(245, 213, 218, 0.4);
    border-radius: 20px;
  }

  h1, h2, h3, h4 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    line-height: 1.2;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  ::selection {
    background-color: var(--blush);
    color: var(--text-primary);
  }

  ::-webkit-scrollbar {
    width: 6px;
  }

  ::-webkit-scrollbar-track {
    background: var(--cream);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--rose);
    border-radius: 3px;
  }

  /* Back to top button */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 200;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--text-primary);
    color: var(--cream);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(74, 40, 48, 0.25);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.25s, transform 0.25s;
    pointer-events: none;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background: var(--rose-gold);
    transform: translateY(-2px);
  }
</style>

<script>
  // Back to top
  const backToTop = document.getElementById('backToTop');
  window.addEventListener('scroll', () => {
    backToTop?.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
  backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // Dark mode toggle — triggered by header button
  window.__toggleTheme = function () {
    const html = document.documentElement;
    const isDark = html.getAttribute('data-theme') === 'dark';
    html.setAttribute('data-theme', isDark ? 'light' : 'dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
    document.dispatchEvent(new CustomEvent('themechange', { detail: { dark: !isDark } }));
  };
</script>
