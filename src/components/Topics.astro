---
const topics = [
  {
    icon: '✦',
    title: 'Beauty & Skincare',
    color: 'blush',
    description:
      'From everyday makeup looks to targeted skincare routines — exfoliation, sunscreen picks, acne scar reduction, and pregnancy-safe beauty tips.',
    tags: ['Makeup', 'Sunscreen', 'Exfoliation', 'Acne Scars', 'Pregnancy-safe'],
  },
  {
    icon: '◇',
    title: 'Parenting & Motherhood',
    color: 'petal',
    description:
      'Honest stories about pregnancy, the newborn phase, baby product reviews, and everything a first-time mum wishes she had known sooner.',
    tags: ['Pregnancy', 'Newborn', 'Baby Products', 'First-time Mum'],
  },
  {
    icon: '○',
    title: 'Lifestyle',
    color: 'gold',
    description:
      'Study tips, food discoveries, and the quiet everyday moments that make life beautiful. A mix of practical and personal.',
    tags: ['Study Tips', 'Food', 'Daily Life'],
  },
];

const colorMap: Record<string, string> = {
  blush: 'var(--blush)',
  petal: 'var(--petal)',
  gold: 'var(--gold-light)',
};
---

<section id="topics" class="topics">
  <div class="topics-inner">
    <div class="topics-header">
      <p class="section-label">What I Write About</p>
      <h2 class="topics-heading">Three pillars,<br /><em>one honest voice.</em></h2>
    </div>
    <div class="topics-grid">
      {topics.map((topic, i) => (
        <div class="topic-card" style={`--card-accent: ${colorMap[topic.color]}`}>
          <div class="topic-icon">{topic.icon}</div>
          <div class="topic-number">0{i + 1}</div>
          <h3 class="topic-title">{topic.title}</h3>
          <p class="topic-desc">{topic.description}</p>
          <div class="topic-tags">
            {topic.tags.map(tag => (
              <span class="topic-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .topics {
    padding: 6rem 2rem;
    background: var(--cream);
  }

  .topics-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .topics-header {
    margin-bottom: 3.5rem;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .topics-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--text-primary);
  }

  .topics-heading em {
    font-style: italic;
    color: var(--rose-gold);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .topic-card {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(245, 213, 218, 0.4);
    border-radius: 24px;
    padding: 2.2rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s;
  }

  .topic-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--card-accent);
    opacity: 0;
    transition: opacity 0.25s;
  }

  .topic-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.05);
    background: rgba(255, 255, 255, 0.7);
  }

  .topic-card:hover::before {
    opacity: 1;
  }

  .topic-icon {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .topic-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    font-weight: 300;
    color: var(--card-accent);
    line-height: 1;
    position: absolute;
    top: 1.5rem;
    right: 1.8rem;
    opacity: 0.35;
  }

  .topic-title {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.9rem;
  }

  .topic-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 1.4rem;
  }

  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .topic-tag {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    background: var(--cream);
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    border: 1px solid var(--border);
  }

  @media (max-width: 860px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }

    .topic-number {
      font-size: 3rem;
    }
  }
</style>
