---
const topics = [
  {
    num: 'i.',
    name: 'Beauty',
    sub: '& Skincare',
    desc: 'Everyday makeup, targeted skincare, ingredient deep-dives, sunscreen reviews, and pregnancy-safe picks.',
    count: '142',
    href: '/categories/',
  },
  {
    num: 'ii.',
    name: 'Motherhood',
    sub: '& Parenting',
    desc: 'Pregnancy, newborn rhythms, baby product reviews, and the quiet truths of first-time motherhood.',
    count: '68',
    href: '/categories/',
  },
  {
    num: 'iii.',
    name: 'Quiet',
    sub: 'Lifestyle',
    desc: 'Slow mornings, study notes, food discoveries, and the everyday moments worth writing down.',
    count: '75',
    href: '/categories/',
  },
];
---

<section id="topics" class="section">
  <div class="section-inner">
    <div class="section-head reveal">
      <span class="section-num">01 · Index</span>
      <h2 class="section-title">Three pillars,<br /><em>one honest voice.</em></h2>
      <div class="section-meta">
        Edited by Iman<br />
        Est. 2015
      </div>
    </div>

    <div class="topics-grid stagger">
      {topics.map((t) => (
        <a href={t.href} class="topic-card">
          <span class="topic-line"></span>
          <span class="topic-num">{t.num}</span>
          <h3 class="topic-title">
            <em>{t.name}</em><br />{t.sub}
          </h3>
          <p class="topic-desc">{t.desc}</p>
          <div class="topic-meta">
            <span class="topic-count">{t.count} chapters</span>
            <span class="topic-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 6rem 2.5rem; position: relative; }
  .section-inner { max-width: 1400px; margin: 0 auto; }

  .section-head {
    display: grid;
    grid-template-columns: 200px 1fr 200px;
    gap: 3rem;
    align-items: end;
    margin-bottom: 5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .section-num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--rose-gold);
  }
  .section-num::before { content: '— '; color: var(--muted); }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .section-title em {
    font-style: italic;
    color: var(--rose-gold);
    font-weight: 300;
  }

  .section-meta {
    text-align: right;
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 2;
  }

  /* Topic cards */
  .topics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
  }
  .topic-card {
    position: relative;
    padding: 2.5rem 2rem 2rem;
    border-top: 1px solid var(--border);
    min-height: 340px;
    display: flex;
    flex-direction: column;
    transition: all 0.5s cubic-bezier(.22,1,.36,1);
    cursor: pointer;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .topic-card:hover { padding-top: 3rem; }
  .topic-card:hover .topic-line { width: 100%; background: var(--deep-rose); }

  .topic-card::before {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 200, 176, 0.3) 0%, transparent 60%);
    filter: blur(30px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s;
    transform: translate(-50%, -50%);
    top: var(--my, 50%);
    left: var(--mx, 50%);
  }
  .topic-card:hover::before { opacity: 1; }

  .topic-line {
    position: absolute;
    top: -1px; left: 0;
    width: 24px;
    height: 1px;
    background: var(--rose-gold);
    transition: all 0.5s cubic-bezier(.22,1,.36,1);
  }
  .topic-num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.95rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .topic-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 2.6rem;
    color: var(--ink);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .topic-title em {
    font-style: italic;
    color: var(--rose-gold);
  }
  .topic-desc {
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: auto;
    max-width: 320px;
    position: relative;
    z-index: 1;
  }
  .topic-meta {
    margin-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--border-soft);
    position: relative;
    z-index: 1;
  }
  .topic-count {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .topic-arrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: var(--ink);
    transition: transform 0.3s;
  }
  .topic-card:hover .topic-arrow { transform: translateX(8px); color: var(--deep-rose); }

  @media (max-width: 960px) {
    .section { padding: 4rem 1.5rem; }
    .section-head { grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 3rem; }
    .section-meta { text-align: left; }
    .topics-grid { grid-template-columns: 1fr; gap: 0; }
    .topic-card { min-height: auto; }
  }
</style>

<script>
  // Topic card hover spotlight
  document.querySelectorAll('.topic-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      (card as HTMLElement).style.setProperty('--mx', ((e as MouseEvent).clientX - rect.left) + 'px');
      (card as HTMLElement).style.setProperty('--my', ((e as MouseEvent).clientY - rect.top) + 'px');
    });
  });
</script>
