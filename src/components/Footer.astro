---
const year = new Date().getFullYear();
---

<!-- Editorial newsletter -->
<section class="newsletter-section">
  <div class="newsletter-inner reveal">
    <p class="newsletter-label">— Correspondence</p>
    <h2 class="newsletter-title">Letters from <em>Kuala Lumpur.</em></h2>
    <p class="newsletter-sub">New chapters in your inbox. No noise, no spam — just the writing.</p>
    <form class="newsletter-form" action="https://formspree.io/f/mojyjrra" method="POST">
      <input type="hidden" name="_subject" value="New newsletter subscriber" />
      <input type="email" name="email" placeholder="your@email.com" required />
      <button type="submit">Subscribe →</button>
    </form>
    <p class="newsletter-privacy">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <h3>iman<em>·</em>blog</h3>
      <p>A journal on beauty, motherhood, and the quiet moments in between. Written from Kuala Lumpur since 2015.</p>

      <!-- Visitor counter -->
      <div class="visitor-wrap">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
        </svg>
        <span class="visitor-label">Readers</span>
        <span class="visitor-count" id="visitorCount">—</span>
      </div>
    </div>
    <div class="footer-col">
      <h4>Index</h4>
      <a href="#topics">Beauty</a>
      <a href="#topics">Motherhood</a>
      <a href="#topics">Lifestyle</a>
      <a href="/posts/">Archive</a>
      <a href="/categories/">Categories</a>
      <a href="/rss.xml">RSS Feed</a>
    </div>
    <div class="footer-col">
      <h4>Correspondence</h4>
      <a href="https://www.instagram.com/imanabdulrahim" target="_blank" rel="noopener">Instagram</a>
      <a href="https://www.facebook.com/imanabdulrahimblog" target="_blank" rel="noopener">Facebook</a>
      <a href="https://www.tiktok.com/@imanabdulrahim_" target="_blank" rel="noopener">TikTok</a>
      <a href="https://twitter.com/imanabdulrahim" target="_blank" rel="noopener">Twitter / X</a>
      <a href="mailto:iman.abdrahim@yahoo.com">Email</a>
    </div>
    <div class="footer-col">
      <h4>Pages</h4>
      <a href="#topics">About</a>
      <a href="/contact/">Contact</a>
      <a href="/media-kit/">Media Kit</a>
      <a href="/find-your-glow/">Find Your Glow</a>
      <a href="/privacy/">Privacy</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {year} · Iman Abdul Rahim</span>
    <span>Kuala Lumpur · Malaysia</span>
  </div>
</footer>

<script>
  // Visitor counter (abacus)
  const VISITOR_API = 'https://abacus.jasoncameron.dev/hit/imanabdulrahim/visitors';
  const el = document.getElementById('visitorCount');
  fetch(VISITOR_API)
    .then((r) => r.json())
    .then((data) => {
      if (el && typeof data.value === 'number') {
        el.textContent = data.value.toLocaleString('en-MY');
      }
    })
    .catch(() => {});

  // Newsletter form
  const form = document.querySelector('.newsletter-form') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button') as HTMLButtonElement;
    const originalText = btn.textContent;
    btn.textContent = 'Subscribing…';
    btn.disabled = true;
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        btn.textContent = 'Subscribed ✓';
        form.reset();
      } else {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    } catch {
      btn.textContent = originalText ?? 'Subscribe →';
      btn.disabled = false;
    }
  });
</script>

<style>
  /* ═══════════ NEWSLETTER ═══════════ */
  .newsletter-section {
    padding: 7rem 2.5rem;
    background: linear-gradient(180deg, var(--cream) 0%, var(--petal) 100%);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .newsletter-section {
    background: linear-gradient(180deg, var(--cream) 0%, var(--blush) 100%);
  }
  .newsletter-section::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--rose) 0%, transparent 70%);
    top: -300px; left: 50%;
    transform: translateX(-50%);
    filter: blur(80px);
    opacity: 0.25;
  }
  .newsletter-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .newsletter-label {
    font-size: 0.62rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--rose-gold);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .newsletter-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.2rem;
  }
  .newsletter-title em { font-style: italic; color: var(--rose-gold); }
  .newsletter-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--ink-soft);
    margin-bottom: 3rem;
  }
  .newsletter-form {
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--ink);
    max-width: 480px;
    margin: 0 auto;
    padding-bottom: 0.8rem;
  }
  .newsletter-form input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.6rem 0;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--ink);
    outline: none;
  }
  .newsletter-form input::placeholder { color: var(--muted); }
  .newsletter-form button {
    background: transparent;
    border: none;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
    color: var(--ink);
    font-weight: 500;
    cursor: pointer;
    transition: color 0.3s;
    padding: 0.6rem 0;
  }
  .newsletter-form button:hover { color: var(--deep-rose); }
  .newsletter-form button:disabled { opacity: 0.6; cursor: not-allowed; }
  .newsletter-privacy {
    margin-top: 1rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  /* ═══════════ FOOTER ═══════════ */
  .footer {
    background: var(--cream);
    padding: 4rem 2.5rem 2rem;
    border-top: 1px solid var(--border-soft);
  }
  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .footer-brand h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 2.4rem;
    color: var(--ink);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    line-height: 1;
  }
  .footer-brand h3 em { font-style: italic; color: var(--rose-gold); }
  .footer-brand p {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-soft);
    max-width: 300px;
    margin-bottom: 1.4rem;
  }
  .visitor-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--ivory);
    border: 1px solid var(--border-soft);
    border-radius: 100px;
    padding: 0.45rem 1rem;
    color: var(--ink-soft);
  }
  .visitor-label {
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }
  .visitor-count {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: var(--rose-gold);
    font-weight: 500;
    font-style: italic;
  }

  .footer-col h4 {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
    margin-bottom: 1.4rem;
    font-family: 'Inter', sans-serif;
  }
  .footer-col a {
    display: block;
    font-size: 0.85rem;
    color: var(--ink);
    font-weight: 400;
    padding: 0.35rem 0;
    transition: color 0.25s;
  }
  .footer-col a:hover { color: var(--deep-rose); }

  .footer-bottom {
    max-width: 1400px;
    margin: 2rem auto 0;
    display: flex;
    justify-content: space-between;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .newsletter-section { padding: 5rem 1.5rem; }
    .footer { padding: 3rem 1.5rem 2rem; }
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; padding-bottom: 2.5rem; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
