---
const timeline = [
  {
    year: '2015',
    title: 'Started blogging',
    desc: 'Began sharing beauty finds & lifestyle snippets on a simple personal blog.',
  },
  {
    year: '2020',
    title: 'Pivoted to beauty',
    desc: 'Focused on skincare reviews, routines & honest product recommendations.',
  },
  {
    year: '2023',
    title: 'Motherhood chapter',
    desc: 'Began documenting pregnancy, newborn care & the realities of first-time mum life.',
  },
  {
    year: '2026',
    title: 'Here & growing',
    desc: 'Still writing, still learning, still figuring it out — one honest post at a time.',
  },
];
---

<section id="about" class="about">
  <div class="about-inner">
    <div class="about-content">
      <p class="section-label reveal">About Me</p>
      <h2 class="about-heading reveal">A storyteller at heart,<br /><em>a mother by grace.</em></h2>
      <p class="about-text reveal">
        Hi there! I'm Iman, a beauty and parenting content creator based in Malaysia.
        This little corner of the internet is where I share everything I genuinely love —
        from the skincare routines that transformed my skin, to the honest, unfiltered
        journey through pregnancy and new motherhood.
      </p>
      <p class="about-text reveal">
        Whether you're searching for a reliable sunscreen recommendation, tips on reducing
        acne scars, or simply want to feel less alone during the beautiful chaos of raising
        a little one — you can find it all here.
      </p>

      <!-- Inline stats row with count-up -->
      <div class="about-stats reveal">
        <div class="stat-inline">
          <span class="stat-num" data-count="195" data-suffix="+">0</span>
          <span class="stat-label">Posts</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-inline">
          <span class="stat-num">11<span class="stat-plus">yr</span></span>
          <span class="stat-label">Writing</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-inline">
          <span class="stat-num">3</span>
          <span class="stat-label">Pillars</span>
        </div>
      </div>

      <div class="about-tags reveal">
        <span class="tag">Skincare</span>
        <span class="tag">Makeup</span>
        <span class="tag">Pregnancy</span>
        <span class="tag">New Motherhood</span>
        <span class="tag">Baby Care</span>
        <span class="tag">Lifestyle</span>
      </div>
    </div>

    <!-- Vertical timeline -->
    <div class="about-timeline reveal-right">
      <div class="timeline-label">Journey so far</div>
      <div class="timeline-list stagger">
        {timeline.map((t, i) => (
          <div class="timeline-item">
            <div class="timeline-dot-wrap">
              <span class="timeline-dot"></span>
              {i < timeline.length - 1 && <span class="timeline-line"></span>}
            </div>
            <div class="timeline-content">
              <span class="timeline-year">{t.year}</span>
              <h3 class="timeline-title">{t.title}</h3>
              <p class="timeline-desc">{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 7rem 2rem;
    background: var(--white);
    position: relative;
  }

  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* Content side */
  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .about-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--text-primary);
    margin-bottom: 1.8rem;
    line-height: 1.2;
  }

  .about-heading em {
    font-style: italic;
    color: var(--rose-gold);
  }

  .about-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.9;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  /* Inline stats row */
  .about-stats {
    display: flex;
    align-items: center;
    gap: 1.8rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .stat-inline {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat-inline .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
  }

  .stat-plus {
    font-size: 1.2rem;
    color: var(--rose-gold);
    margin-left: 0.1em;
    font-style: italic;
  }

  .stat-label {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 34px;
    background: var(--border);
  }

  /* Tags */
  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.8rem;
  }

  .tag {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    background: var(--cream);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    transition: background 0.25s, border-color 0.25s, color 0.25s, transform 0.25s;
  }

  .tag:hover {
    background: var(--sage-light);
    border-color: var(--sage);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  /* ─────────── Timeline ─────────── */
  .about-timeline {
    position: sticky;
    top: 7rem;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 2rem 1.8rem 2rem 1.5rem;
  }

  .timeline-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 1.5rem;
    font-weight: 500;
    padding-left: 0.3rem;
  }

  .timeline-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    gap: 1rem;
    position: relative;
    padding-bottom: 1.5rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 18px;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid var(--rose-gold);
    margin-top: 5px;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
    position: relative;
    z-index: 2;
  }

  .timeline-item:hover .timeline-dot {
    background: var(--rose-gold);
    transform: scale(1.2);
    box-shadow: 0 0 0 4px rgba(192, 136, 120, 0.18);
  }

  .timeline-line {
    flex-grow: 1;
    width: 2px;
    background: linear-gradient(var(--rose-gold), var(--sage));
    opacity: 0.35;
    margin-top: 2px;
  }

  .timeline-content {
    flex: 1;
    padding-bottom: 0.3rem;
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .timeline-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.35rem;
  }

  .timeline-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 900px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-timeline {
      position: static;
    }
  }

  @media (max-width: 520px) {
    .about-stats {
      gap: 1.2rem;
    }

    .stat-inline .stat-num {
      font-size: 2rem;
    }
  }
</style>

<script>
  // ─────── Count-up animation ───────
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const countEls = document.querySelectorAll<HTMLElement>('[data-count]');

  function animateCount(el: HTMLElement) {
    const target = parseInt(el.dataset.count || '0', 10);
    const suffix = el.dataset.suffix || '';
    if (prefersReducedMotion) {
      el.textContent = target + suffix;
      return;
    }
    const duration = 1600;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const t = Math.min(1, elapsed / duration);
      // easeOutQuart
      const eased = 1 - Math.pow(1 - t, 4);
      const current = Math.round(target * eased);
      el.textContent = current + (t === 1 ? suffix : '');
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if ('IntersectionObserver' in window) {
    const countObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCount(entry.target as HTMLElement);
            countObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );
    countEls.forEach((el) => countObserver.observe(el));
  } else {
    countEls.forEach((el) => {
      el.textContent = (el.dataset.count || '0') + (el.dataset.suffix || '');
    });
  }
</script>
