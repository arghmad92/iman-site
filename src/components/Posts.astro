---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const categoryColorMap: Record<string, string> = {
  Skincare: 'var(--blush)',
  Beauty: 'var(--gold-light)',
  Motherhood: 'var(--petal)',
  Parenting: 'var(--petal)',
  Lifestyle: 'var(--blush)',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<section id="posts" class="posts">
  <div class="posts-inner">
    <div class="posts-header">
      <p class="section-label">Latest Posts</p>
      <h2 class="posts-heading">Stories worth<br /><em>reading.</em></h2>
    </div>
    <a href="/posts/" class="view-all-link">
      View all posts — archive
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
    <div class="posts-grid">
      {allPosts.map((post) => (
        <a
          href={`/posts/${post.slug}/`}
          class="post-card"
          style={`--cat-color: ${categoryColorMap[post.data.category] ?? 'var(--blush)'}`}
        >
          {post.data.image && (
            <div class="post-thumb-wrap">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="post-thumb"
                loading="lazy"
              />
            </div>
          )}
          <div class="post-body">
            <div class="post-top">
              <span class="post-category">{post.data.category}</span>
              <span class="post-read-time">{post.data.readTime}</span>
            </div>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-excerpt">{post.data.excerpt}</p>
            <div class="post-bottom">
              <span class="post-date">{formatDate(post.data.date)}</span>
              <span class="post-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .posts {
    padding: 6rem 2rem;
    background: var(--white);
  }

  .posts-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .posts-header {
    margin-bottom: 1.5rem;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--rose-gold);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }

  .view-all-link:hover { color: var(--deep-rose); }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .posts-heading {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--text-primary);
    font-family: 'Cormorant Garamond', serif;
  }

  .posts-heading em {
    font-style: italic;
    color: var(--rose-gold);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .post-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--cat-color);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    transform-origin: left;
  }

  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(180, 90, 110, 0.12);
    border-color: var(--rose);
  }

  .post-card:hover::after {
    transform: scaleX(1);
  }

  /* Thumbnail */
  .post-thumb-wrap {
    width: 100%;
    height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .post-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .post-card:hover .post-thumb {
    transform: scale(1.05);
  }

  /* Card body */
  .post-body {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.5rem;
    flex-grow: 1;
  }

  .post-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .post-category {
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--cat-color);
    padding: 0.22rem 0.7rem;
    border-radius: 100px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .post-read-time {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .post-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    color: var(--text-primary);
    line-height: 1.4;
    font-weight: 500;
    flex-grow: 1;
  }

  .post-excerpt {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.75;
    font-weight: 300;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border);
  }

  .post-date {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .post-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    transition: transform 0.2s, color 0.2s;
  }

  .post-card:hover .post-arrow {
    transform: translateX(4px);
    color: var(--rose-gold);
  }

  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 580px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
