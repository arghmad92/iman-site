---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);

const featured = allPosts[0];
const rest = allPosts.slice(1);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    month: 'short', year: 'numeric',
  });
}

const totalIndex = allPosts.length;
---

<section id="posts" class="section posts-section">
  <div class="section-inner">
    <div class="section-head reveal">
      <span class="section-num">02 · Latest</span>
      <h2 class="section-title">Recent<br /><em>chapters.</em></h2>
      <div class="section-meta">
        Updated weekly<br />
        <a href="/posts/" class="archive-link">View archive →</a>
      </div>
    </div>

    {featured && (
      <a href={`/posts/${featured.id}/`} class="posts-feature reveal">
        <div class="posts-feature-img" style={featured.data.image ? `background-image: url(${featured.data.image})` : ''}>
          <span class="posts-feature-num">No. {String(totalIndex).padStart(3, '0')}</span>
        </div>
        <div class="posts-feature-body">
          <span class="post-cat">{featured.data.category} · Featured</span>
          <h3 class="post-feat-title">{featured.data.title}</h3>
          <p class="post-feat-excerpt drop-cap">{featured.data.excerpt}</p>
          <div class="post-feat-meta">
            <span class="post-feat-meta-item">{featured.data.readTime}</span>
            <span class="post-feat-meta-item">{formatDate(featured.data.date)}</span>
            <span class="post-feat-meta-item">{featured.data.category}</span>
          </div>
        </div>
      </a>
    )}

    <div class="posts-grid stagger">
      {rest.map((post) => (
        <a href={`/posts/${post.id}/`} class="post-item">
          <div class="post-item-img" style={post.data.image ? `background-image: url(${post.data.image})` : ''}></div>
          <span class="post-cat">{post.data.category}</span>
          <h4 class="post-item-title">{post.data.title}</h4>
          <span class="post-item-meta">{post.data.readTime} · {formatDate(post.data.date)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .posts-section { padding: 6rem 2.5rem; background: var(--ivory); }
  .section-inner { max-width: 1400px; margin: 0 auto; }

  .section-head {
    display: grid;
    grid-template-columns: 200px 1fr 200px;
    gap: 3rem;
    align-items: end;
    margin-bottom: 5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .section-num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1rem;
    color: var(--rose-gold);
  }
  .section-num::before { content: '— '; color: var(--muted); }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .section-title em {
    font-style: italic;
    color: var(--rose-gold);
  }
  .section-meta {
    text-align: right;
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 2;
  }
  .archive-link {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.25s;
  }
  .archive-link:hover { color: var(--deep-rose); }

  /* Featured post */
  .posts-feature {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 6rem;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.3s;
  }
  .posts-feature:hover { opacity: 0.88; }

  .posts-feature-img {
    aspect-ratio: 4 / 5;
    background: linear-gradient(135deg, var(--petal) 0%, var(--blush) 40%, var(--peach) 100%);
    background-size: cover;
    background-position: center;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
    transition: transform 0.7s cubic-bezier(.22,1,.36,1);
  }
  .posts-feature:hover .posts-feature-img { transform: scale(1.02); }

  .posts-feature-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0.08 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.5;
  }
  .posts-feature-num {
    position: absolute;
    top: 1.5rem; left: 1.5rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.85rem;
    color: #fff;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.8rem;
    background: rgba(42, 26, 24, 0.35);
    backdrop-filter: blur(6px);
    border-radius: 100px;
    z-index: 1;
  }

  .posts-feature-body { padding: 1rem 0; }
  .post-cat {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rose-gold);
    font-weight: 500;
    margin-bottom: 1.2rem;
    display: block;
  }
  .post-feat-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .post-feat-title em { font-style: italic; color: var(--rose-gold); }
  .post-feat-excerpt {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  /* Drop cap */
  .drop-cap::first-letter {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 4.2rem;
    line-height: 0.9;
    float: left;
    margin: 0.2rem 0.6rem 0 0;
    color: var(--rose-gold);
  }

  .post-feat-meta {
    display: flex;
    gap: 2rem;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-soft);
    flex-wrap: wrap;
  }
  .post-feat-meta-item {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    border-top: 1px solid var(--border-soft);
    padding-top: 3rem;
  }
  .post-item {
    padding-top: 1rem;
    cursor: pointer;
    transition: opacity 0.3s;
    text-decoration: none;
    color: inherit;
  }
  .post-item:hover { opacity: 0.75; }
  .post-item-img {
    aspect-ratio: 4 / 3;
    border-radius: 3px;
    margin-bottom: 1.5rem;
    background: var(--petal);
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.6s cubic-bezier(.22,1,.36,1);
  }
  .post-item:hover .post-item-img { transform: scale(1.03); }
  .post-item:nth-child(1) .post-item-img { background-color: var(--petal); }
  .post-item:nth-child(2) .post-item-img { background-color: var(--peach); }
  .post-item:nth-child(3) .post-item-img { background-color: var(--blush); }
  .post-item-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0.08 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.4;
  }
  .post-item-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.4rem;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .post-item-meta {
    font-size: 0.62rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .posts-section { padding: 4rem 1.5rem; }
    .section-head { grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 3rem; }
    .section-meta { text-align: left; }
    .posts-feature { grid-template-columns: 1fr; gap: 2rem; margin-bottom: 4rem; }
    .posts-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
