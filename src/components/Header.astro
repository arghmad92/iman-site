---
const navLinks = [
  { label: 'Index', href: '#topics' },
  { label: 'Beauty', href: '/categories/' },
  { label: 'Motherhood', href: '/categories/' },
  { label: 'Journal', href: '/posts/' },
  { label: 'Find Your Glow', href: '/find-your-glow/', highlight: true },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-mark">
      <span class="logo-word">iman<sup>·</sup></span>
      <span class="logo-divider"></span>
      <span class="logo-sub">A Journal</span>
    </a>
    <nav>
      <ul class="nav-links">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class={link.highlight ? 'nav-highlight' : ''}>
              {link.highlight && <span class="nav-dot" aria-hidden="true"></span>}
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="header-right">
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
      <a href="/contact/" class="greeting animated-link">
        <span>Contact</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <button class="menu-toggle" aria-label="Toggle menu" id="menuToggle">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    {navLinks.map((link) => (
      <a href={link.href} class="mobile-link">{link.label}</a>
    ))}
    <a href="/contact/" class="mobile-link">Contact</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.2rem 2.5rem;
    background: rgba(253, 246, 240, 0.72);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-soft);
    transition: background 0.3s;
  }

  :global([data-theme="dark"]) .site-header {
    background: rgba(20, 16, 14, 0.78);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo-mark {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-shrink: 0;
  }

  .logo-word {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .logo-word sup { font-size: 0.45rem; color: var(--rose-gold); letter-spacing: 0.15em; vertical-align: super; }

  .logo-divider {
    width: 1px;
    height: 13px;
    background: var(--border);
  }

  .logo-sub {
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: 500;
    transition: color 0.3s;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links a:hover { color: var(--deep-rose); }

  /* Highlighted "Find Your Glow" nav item */
  .nav-highlight {
    color: var(--ink) !important;
    font-weight: 600 !important;
  }
  .nav-highlight:hover { color: var(--deep-rose) !important; }

  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--rose-gold);
    flex-shrink: 0;
    animation: navDotPulse 2.5s ease-in-out infinite;
  }
  @keyframes navDotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .theme-toggle {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--ink-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    padding: 0;
  }

  .theme-toggle:hover {
    background: var(--petal);
    border-color: var(--rose-gold);
    color: var(--ink);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }

  .greeting {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
    position: relative;
    padding-bottom: 2px;
  }

  .greeting::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    height: 1px; width: 0;
    background: var(--deep-rose);
    transition: width 0.4s cubic-bezier(.22,1,.36,1);
  }
  .greeting:hover { color: var(--deep-rose); }
  .greeting:hover::after { width: 100%; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .menu-toggle span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--ink);
    transition: all 0.3s;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--cream);
    border-top: 1px solid var(--border-soft);
    padding: 0.5rem 0;
    margin-top: 1rem;
  }

  .mobile-link {
    padding: 0.9rem 2rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1px solid var(--border-soft);
    font-weight: 500;
  }
  .mobile-link:hover { background: var(--petal); color: var(--ink); }
  .mobile-menu.open { display: flex; }

  @media (max-width: 1000px) {
    .nav-links { display: none; }
  }
  @media (max-width: 720px) {
    .site-header { padding: 1rem 1.2rem; }
    .greeting { display: none; }
    .menu-toggle { display: flex; }
    .logo-sub { display: none; }
    .logo-divider { display: none; }
  }
</style>

<script>
  const toggle = document.getElementById('menuToggle');
  const menu = document.getElementById('mobileMenu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => menu.classList.remove('open'));
  });
  document.getElementById('themeToggle')?.addEventListener('click', () => {
    (window as any).__toggleTheme?.();
  });
</script>
