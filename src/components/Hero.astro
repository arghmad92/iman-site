---
---

<section id="home" class="hero-wrap">
  <div class="aurora-card" id="auroraCard">
    <div class="aurora">
      <div class="a1"></div>
      <div class="a2"></div>
      <div class="a3"></div>
    </div>
    <div class="aurora-cursor" id="auroraCursor"></div>
    <div class="aurora-grain"></div>

    <!-- Corner bracket accents -->
    <div class="corner-accent corner-tl"></div>
    <div class="corner-accent corner-tr"></div>
    <div class="corner-accent corner-bl"></div>
    <div class="corner-accent corner-br"></div>

    <!-- Folio mark (top-right) -->
    <div class="folio-mark">
      <span class="folio-num">I</span>
      <span>·</span>
      <span>Cover</span>
    </div>

    <div class="dashboard-content">
      <div class="dashboard-top">
        <div class="dashboard-brand">
          <span class="dashboard-brand-name">iman<sup>·</sup></span>
          <span class="dashboard-brand-divider"></span>
          <span class="dashboard-brand-label">A Journal</span>
        </div>
        <span class="dashboard-brand-label">Kuala Lumpur · Est. 2015</span>
      </div>

      <div class="dashboard-body">
        <h1 class="chapter-title"><em>Iman</em> <span class="thin">Abdul Rahim</span></h1>
        <p class="chapter-sub">
          A writer from Malaysia sharing honest notes on beauty, motherhood,
          and the quiet moments in between.
        </p>
        <div class="chapter-actions">
          <a href="#posts" class="btn-pill">
            Read the journal
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="#topics" class="btn-pill btn-ghost">
            About
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <div class="dashboard-footer">
        <span class="footer-meta">285 chapters · Beauty · Motherhood · Lifestyle</span>
        <span class="footer-meta">Scroll to read ↓</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-wrap {
    padding: 6rem 2.5rem 4rem;
    position: relative;
  }

  .aurora-card {
    max-width: 1400px;
    margin: 0 auto;
    height: 82vh;
    min-height: 640px;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 40px 80px rgba(42, 26, 24, 0.12), 0 0 0 1px rgba(42, 26, 24, 0.04);
    background: var(--ivory);
  }

  :global([data-theme="dark"]) .aurora-card {
    background: var(--ivory);
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  /* Aurora gradients */
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    filter: saturate(1.05);
  }

  .aurora::before,
  .aurora::after,
  .aurora .a1,
  .aurora .a2,
  .aurora .a3 {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .aurora::before {
    width: 90%; height: 80%;
    background: radial-gradient(circle at 50% 50%, var(--blush) 0%, transparent 60%);
    top: -10%; left: -5%;
    animation: auroraFloat1 20s ease-in-out infinite;
  }

  .aurora::after {
    width: 70%; height: 70%;
    background: radial-gradient(circle at 50% 50%, var(--peach) 0%, transparent 60%);
    bottom: -15%; right: -10%;
    animation: auroraFloat2 24s ease-in-out infinite;
  }

  .aurora .a1 {
    width: 60%; height: 60%;
    background: radial-gradient(circle at 50% 50%, var(--petal) 0%, transparent 60%);
    top: 20%; right: 10%;
    animation: auroraFloat3 26s ease-in-out infinite;
  }

  .aurora .a2 {
    width: 55%; height: 55%;
    background: radial-gradient(circle at 50% 50%, var(--rose) 0%, transparent 55%);
    bottom: 10%; left: 20%;
    animation: auroraFloat1 22s ease-in-out infinite reverse;
    opacity: 0.7;
  }

  .aurora .a3 {
    width: 45%; height: 45%;
    background: radial-gradient(circle at 50% 50%, var(--blush-soft) 0%, transparent 60%);
    top: 40%; left: 45%;
    animation: auroraFloat2 18s ease-in-out infinite reverse;
  }

  @keyframes auroraFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(60px, 40px) scale(1.15); }
  }
  @keyframes auroraFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-50px, 60px) scale(1.1); }
  }
  @keyframes auroraFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, -50px) scale(1.2); }
  }

  /* Film grain */
  .aurora-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0 0.5 0 0 0 0.12 0'/></filter><rect width='200' height='200' filter='url(%23n)'/></svg>");
    mix-blend-mode: multiply;
    opacity: 0.6;
    pointer-events: none;
  }

  /* Cursor-follow aurora */
  .aurora-cursor {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(234, 164, 174, 0.5) 0%, transparent 60%);
    filter: blur(40px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.6s;
    transform: translate(-50%, -50%);
    z-index: 1;
    mix-blend-mode: soft-light;
  }
  .aurora-card:hover .aurora-cursor { opacity: 1; }

  /* Corner bracket accents */
  .corner-accent {
    position: absolute;
    width: 24px;
    height: 24px;
    z-index: 3;
    opacity: 0.5;
  }
  .corner-accent::before, .corner-accent::after {
    content: '';
    position: absolute;
    background: var(--ink);
  }
  .corner-accent::before { width: 100%; height: 1px; }
  .corner-accent::after { width: 1px; height: 100%; }
  .corner-tl { top: 1.2rem; left: 1.2rem; }
  .corner-tl::before, .corner-tl::after { top: 0; left: 0; }
  .corner-tr { top: 1.2rem; right: 1.2rem; }
  .corner-tr::before, .corner-tr::after { top: 0; right: 0; }
  .corner-bl { bottom: 1.2rem; left: 1.2rem; }
  .corner-bl::before, .corner-bl::after { bottom: 0; left: 0; }
  .corner-br { bottom: 1.2rem; right: 1.2rem; }
  .corner-br::before, .corner-br::after { bottom: 0; right: 0; }

  /* Folio mark */
  .folio-mark {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    z-index: 3;
    opacity: 0.7;
  }
  .folio-num { color: var(--rose-gold); }

  /* Dashboard content */
  .dashboard-content {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .dashboard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1rem;
  }
  .dashboard-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .dashboard-brand-name {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink);
  }
  .dashboard-brand-name sup {
    font-size: 0.5rem;
    color: var(--rose-gold);
  }
  .dashboard-brand-divider {
    width: 1px;
    height: 11px;
    background: var(--border);
  }
  .dashboard-brand-label {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  .dashboard-body { padding-bottom: 1.5rem; }

  .chapter-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.8rem;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.3);
  }
  .chapter-title .thin { font-weight: 300; color: var(--ink-soft); }
  .chapter-title em { font-style: italic; }

  .chapter-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: var(--ink);
    margin-bottom: 2rem;
    max-width: 560px;
    line-height: 1.5;
  }

  .chapter-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.75rem 1.6rem;
    border: 1px solid var(--ink);
    border-radius: 100px;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 500;
    background: transparent;
    transition: all 0.4s cubic-bezier(.22,1,.36,1);
    cursor: pointer;
    font-family: inherit;
  }
  .btn-pill:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  /* ─── Dark mode: visible aurora ─── */
  :global([data-theme="dark"]) .aurora-card {
    background: #1f1814;
  }
  :global([data-theme="dark"]) .aurora::before {
    background: radial-gradient(circle at 50% 50%, rgba(224, 168, 144, 0.32) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .aurora::after {
    background: radial-gradient(circle at 50% 50%, rgba(240, 144, 144, 0.25) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .aurora .a1 {
    background: radial-gradient(circle at 50% 50%, rgba(224, 168, 144, 0.28) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .aurora .a2 {
    background: radial-gradient(circle at 50% 50%, rgba(240, 168, 184, 0.28) 0%, transparent 55%);
  }
  :global([data-theme="dark"]) .aurora .a3 {
    background: radial-gradient(circle at 50% 50%, rgba(224, 168, 144, 0.2) 0%, transparent 60%);
  }
  :global([data-theme="dark"]) .aurora-grain {
    mix-blend-mode: overlay;
    opacity: 0.35;
  }
  :global([data-theme="dark"]) .corner-accent::before,
  :global([data-theme="dark"]) .corner-accent::after {
    background: var(--ink);
  }
  :global([data-theme="dark"]) .chapter-title {
    text-shadow: none;
  }
  .btn-pill svg { transition: transform 0.3s; }
  .btn-pill:hover svg { transform: translateX(3px); }

  .btn-ghost { border-color: transparent; }

  .dashboard-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-soft);
    padding-top: 1.5rem;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .footer-meta {
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .hero-wrap { padding: 5rem 1rem 3rem; }
    .aurora-card { min-height: 580px; }
    .dashboard-content { padding: 1.8rem; }
    .corner-accent { width: 16px; height: 16px; }
    .folio-mark { top: 1rem; right: 1rem; font-size: 0.7rem; }
    .chapter-actions { gap: 0.6rem; }
    .dashboard-footer { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  // Cursor-follow aurora in hero
  const auroraCard = document.getElementById('auroraCard');
  const auroraCursor = document.getElementById('auroraCursor');
  if (auroraCard && auroraCursor) {
    auroraCard.addEventListener('mousemove', (e) => {
      const rect = auroraCard.getBoundingClientRect();
      (auroraCursor as HTMLElement).style.left = (e.clientX - rect.left) + 'px';
      (auroraCursor as HTMLElement).style.top = (e.clientY - rect.top) + 'px';
    });
  }
</script>
