---
const rotatingWords = ['Beauty', 'Parenting', 'Lifestyle', 'Skincare', 'Motherhood'];
---

<section id="home" class="hero">
  <!-- Editorial sidebar -->
  <aside class="hero-sidebar" aria-hidden="true">
    <span class="hero-sidebar-text">EST. 2015 · KUALA LUMPUR · MY</span>
  </aside>

  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge reveal">
        <span class="badge-static">I write about</span>
        <span class="badge-rotator" id="heroRotator" aria-live="polite">
          <span class="rotator-word">Beauty</span>
        </span>
      </div>
      <h1 class="hero-name reveal">
        <span class="hero-name-row">Iman</span>
        <em class="hero-name-row">Abdul Rahim</em>
      </h1>
      <p class="hero-tagline reveal">
        Hello, welcome! I'm a content creator from Malaysia sharing honest stories
        about beauty, skincare, motherhood, and the everyday moments in between.
      </p>
      <div class="hero-actions reveal">
        <a href="#posts" class="btn-primary magnetic" data-magnetic>
          <span class="btn-label">Read My Posts</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#about" class="btn-ghost">About Me</a>
      </div>
    </div>

    <div class="hero-photo reveal-scale">
      <div class="hero-photo-frame">
        <img src="/raya-34.jpeg" alt="Iman Abdul Rahim" loading="eager" class="hero-photo-img" />
        <div class="hero-photo-tag">✦ 2026</div>
      </div>
      <div class="hero-photo-accent"></div>
      <div class="hero-photo-ring"></div>
    </div>
  </div>

  <div class="hero-scroll reveal">
    <span>scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
      <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="8" cy="7" r="2" fill="currentColor">
        <animate attributeName="cy" values="7;15;7" dur="2s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="1;0;1" dur="2s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>

  <div class="hero-deco" aria-hidden="true">
    <div class="deco-circle deco-1"></div>
    <div class="deco-circle deco-2"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 7rem 2rem 3rem;
  }

  /* Rotated sidebar text */
  .hero-sidebar {
    position: absolute;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: left center;
    z-index: 1;
    pointer-events: none;
  }

  .hero-sidebar-text {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
    font-weight: 500;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 4rem;
    align-items: center;
  }

  /* Typewriter / rotator badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: var(--blush);
    padding: 0.5rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    border: 1px solid rgba(224, 154, 159, 0.25);
  }

  .badge-static {
    color: var(--text-secondary);
  }

  .badge-rotator {
    display: inline-block;
    min-width: 88px;
    text-align: left;
    color: var(--deep-rose);
    font-weight: 600;
    position: relative;
  }

  .rotator-word {
    display: inline-block;
    animation: rotatorFade 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes rotatorFade {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-name {
    font-size: clamp(3.5rem, 8vw, 6.2rem);
    line-height: 1.0;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }

  .hero-name-row {
    display: block;
  }

  .hero-name em {
    font-style: italic;
    color: var(--rose-gold);
    font-weight: 300;
    margin-left: 0.6em;
  }

  .hero-tagline {
    max-width: 460px;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--text-primary);
    color: var(--cream);
    padding: 0.85rem 2rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    transition: background 0.3s, color 0.3s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s;
    box-shadow: 0 6px 18px rgba(58, 40, 32, 0.12);
    position: relative;
    will-change: transform;
  }

  .btn-primary svg {
    transition: transform 0.3s;
  }

  .btn-primary:hover {
    background: var(--plum);
    color: var(--cream);
    box-shadow: 0 10px 28px rgba(74, 30, 46, 0.25);
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    transition: border-color 0.3s, color 0.3s, transform 0.3s;
  }

  .btn-ghost:hover {
    border-color: var(--sage);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  /* Photo */
  .hero-photo {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-frame {
    position: relative;
    z-index: 2;
    border-radius: 200px 200px 24px 24px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(180, 90, 110, 0.15);
    max-width: 380px;
    width: 100%;
  }

  .hero-photo-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center top;
    display: block;
    animation: kenBurns 22s ease-in-out infinite alternate;
  }

  @keyframes kenBurns {
    0%   { transform: scale(1) translate(0, 0); }
    100% { transform: scale(1.08) translate(-1%, -2%); }
  }

  .hero-photo-tag {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--cream);
    background: rgba(58, 40, 32, 0.4);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    z-index: 3;
  }

  .hero-photo-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: var(--sage-light);
    opacity: 0.6;
    z-index: 1;
    animation: heroFloat2 18s ease-in-out infinite;
  }

  .hero-photo-ring {
    position: absolute;
    top: -20px;
    left: -20px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 1px solid var(--rose-gold);
    opacity: 0.35;
    z-index: 1;
    animation: heroFloat1 14s ease-in-out infinite;
  }

  /* Scroll indicator */
  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 3rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  /* Decorative background shapes */
  .hero-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
  }

  .deco-1 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, var(--blush) 0%, transparent 70%);
    top: -60px;
    right: -80px;
    opacity: 0.4;
    animation: heroFloat1 14s ease-in-out infinite;
  }

  .deco-2 {
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, var(--sage-light) 0%, transparent 70%);
    top: 50%;
    left: 20%;
    opacity: 0.35;
    animation: heroFloat3 16s ease-in-out infinite;
  }

  @keyframes heroFloat1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 25px); }
  }

  @keyframes heroFloat2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(12px, -12px); }
  }

  @keyframes heroFloat3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(15px, -15px); }
  }

  @media (max-width: 1024px) {
    .hero-sidebar { display: none; }
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      order: 2;
    }

    .hero-photo {
      order: 1;
    }

    .hero-photo-frame {
      max-width: 280px;
    }

    .hero-photo-img {
      height: 380px;
    }

    .hero-tagline {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-scroll {
      justify-content: center;
    }

    .hero-name {
      font-size: clamp(3rem, 14vw, 4.5rem);
      align-items: center;
    }

    .hero-name em {
      margin-left: 0;
    }

    .deco-1 {
      width: 220px;
      height: 220px;
      right: -60px;
    }
  }
</style>

<script>
  // ─────── Rotating badge words ───────
  const words = ['Beauty', 'Parenting', 'Lifestyle', 'Skincare', 'Motherhood'];
  const rotator = document.getElementById('heroRotator');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (rotator && !prefersReducedMotion) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      rotator.innerHTML = `<span class="rotator-word">${words[i]}</span>`;
    }, 2600);
  }

  // ─────── Magnetic button effect ───────
  const magneticButtons = document.querySelectorAll<HTMLElement>('[data-magnetic]');
  if (!prefersReducedMotion) {
    magneticButtons.forEach((btn) => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        btn.style.transform = `translate(${x * 0.15}px, ${y * 0.15}px) translateY(-2px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });
  }
</script>
