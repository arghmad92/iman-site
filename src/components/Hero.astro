---
---

<section id="home" class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">Beauty · Parenting · Lifestyle</div>
      <h1 class="hero-name">
        Iman<br />
        <em>Abdul Rahim</em>
      </h1>
      <p class="hero-tagline">
        Hello, welcome! I'm a content creator from Malaysia sharing honest stories
        about beauty, skincare, motherhood, and the everyday moments in between.
      </p>
      <div class="hero-actions">
        <a href="#posts" class="btn-primary">
          Read My Posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="#about" class="btn-ghost">About Me</a>
      </div>
    </div>
    <div class="hero-photo">
      <div class="hero-photo-frame">
        <img src="/raya-34.jpeg" alt="Iman Abdul Rahim" loading="eager" />
      </div>
      <div class="hero-photo-accent"></div>
    </div>
  </div>
  <div class="hero-scroll">
    <span>scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
      <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5"/>
      <circle cx="8" cy="7" r="2" fill="currentColor">
        <animate attributeName="cy" values="7;15;7" dur="2s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="1;0;1" dur="2s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>
  <div class="hero-deco">
    <div class="deco-circle deco-1"></div>
    <div class="deco-circle deco-2"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 7rem 2rem 3rem;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-secondary);
    background: var(--blush);
    padding: 0.4rem 1.1rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }

  .hero-name {
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 1.0;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 1.8rem;
  }

  .hero-name em {
    font-style: italic;
    color: var(--rose-gold);
    font-weight: 300;
  }

  .hero-tagline {
    max-width: 460px;
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 2.5rem;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--text-primary);
    color: var(--cream);
    padding: 0.85rem 2rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    transition: background 0.25s, transform 0.2s;
  }

  .btn-primary svg {
    transition: transform 0.25s;
  }

  .btn-primary:hover {
    background: var(--rose-gold);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  .btn-primary:hover svg {
    transform: translateX(3px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 2rem;
    border-radius: 100px;
    border: 1.5px solid var(--border);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    transition: border-color 0.25s, color 0.25s, transform 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--rose-gold);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  /* Photo */
  .hero-photo {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-frame {
    position: relative;
    z-index: 2;
    border-radius: 200px 200px 24px 24px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(180, 90, 110, 0.12);
    max-width: 380px;
    width: 100%;
  }

  .hero-photo-frame img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-photo-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: var(--blush);
    opacity: 0.5;
    z-index: 1;
    animation: heroFloat2 18s ease-in-out infinite;
  }

  /* Scroll indicator */
  .hero-scroll {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 3rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  /* Decorative background shapes */
  .hero-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
  }

  .deco-1 {
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, var(--blush) 0%, transparent 70%);
    top: -60px;
    right: -80px;
    opacity: 0.4;
    animation: heroFloat1 14s ease-in-out infinite;
  }

  .deco-2 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--petal) 0%, transparent 70%);
    top: 50%;
    left: -60px;
    opacity: 0.4;
    animation: heroFloat3 16s ease-in-out infinite;
  }

  @keyframes heroFloat1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 25px); }
  }

  @keyframes heroFloat2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(12px, -12px); }
  }

  @keyframes heroFloat3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(15px, -15px); }
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      order: 2;
    }

    .hero-photo {
      order: 1;
    }

    .hero-photo-frame {
      max-width: 280px;
    }

    .hero-photo-frame img {
      height: 380px;
    }

    .hero-tagline {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-scroll {
      justify-content: center;
    }

    .hero-name {
      font-size: clamp(3rem, 14vw, 4.5rem);
    }

    .deco-1 {
      width: 220px;
      height: 220px;
      right: -60px;
    }
  }
</style>
